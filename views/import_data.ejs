<%- include('partials/head') %>
<div class="layout">
    <%- include('partials/sidebar') %>
    <main class="main-content">
        <header class="topbar">
            <h1><%= page %></h1>
        </header>
        <div class="content-body">
            
            <% if(message) { %>
                <div class="alert alert-success"><%= message %></div>
            <% } %>
            <% if(error) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <!-- KHU VỰC DÀNH RIÊNG CHO ADMIN: RESET DATABASE KPI -->
            <% if(typeof currentUser !== 'undefined' && currentUser.role === 'admin') { %>
                <div class="card" style="margin-bottom: 20px; border-left: 4px solid #e74c3c; max-width: 600px;">
                    <h4 style="color: #c0392b; margin-top: 0; margin-bottom: 5px;">Khu Vực Admin: Làm Sạch Dữ Liệu KPI</h4>
                    <p style="font-size: 13px; color: #666; margin-bottom: 15px;">Dùng tính năng này để xóa <strong>toàn bộ</strong> dữ liệu KPI cũ và tiến hành Import lại từ đầu (Không thể hoàn tác).</p>
                    <div style="display: flex; gap: 10px;">
                        <form action="/kpi-data/reset/3g" method="POST" style="margin: 0;" onsubmit="return confirm('CẢNH BÁO NGUY HIỂM: Bạn có CHẮC CHẮN muốn xóa SẠCH toàn bộ dữ liệu KPI mạng 3G?');">
                            <button type="submit" class="btn-sm btn-danger">⚠ Reset KPI 3G</button>
                        </form>
                        <form action="/kpi-data/reset/4g" method="POST" style="margin: 0;" onsubmit="return confirm('CẢNH BÁO NGUY HIỂM: Bạn có CHẮC CHẮN muốn xóa SẠCH toàn bộ dữ liệu KPI mạng 4G?');">
                            <button type="submit" class="btn-sm btn-danger">⚠ Reset KPI 4G</button>
                        </form>
                        <form action="/kpi-data/reset/5g" method="POST" style="margin: 0;" onsubmit="return confirm('CẢNH BÁO NGUY HIỂM: Bạn có CHẮC CHẮN muốn xóa SẠCH toàn bộ dữ liệu KPI mạng 5G?');">
                            <button type="submit" class="btn-sm btn-danger">⚠ Reset KPI 5G</button>
                        </form>
                    </div>
                </div>
            <% } %>

            <div class="card" style="max-width: 600px;">
                <h3>Upload Dữ Liệu Tần Số & Hiệu Năng</h3>
                <p style="margin-bottom: 20px; color: #666;">Chấp nhận file định dạng .xlsx, .xls, .csv</p>
                
                <form action="/import-data" method="POST" enctype="multipart/form-data">
                    <div class="form-group">
                        <label>Chọn Database lưu trữ:</label>
                        <select name="networkType" required>
                            <optgroup label="Cơ sở dữ liệu trạm (RF)">
                                <option value="rf_3g">Trạm Mạng 3G (RF_3G)</option>
                                <option value="rf_4g">Trạm Mạng 4G (RF_4G)</option>
                                <option value="rf_5g">Trạm Mạng 5G (RF_5G)</option>
                            </optgroup>
                            <optgroup label="Cơ sở dữ liệu hiệu năng (KPI)">
                                <option value="kpi_3g">KPI Mạng 3G</option>
                                <option value="kpi_4g">KPI Mạng 4G</option>
                                <option value="kpi_5g">KPI Mạng 5G</option>
                            </optgroup>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Chọn File:</label>
                        <div style="border: 2px dashed #ddd; padding: 20px; text-align: center; border-radius: 4px; background: #fafafa;">
                            <input type="file" name="dataFile" accept=".csv, application/vnd.openxmlformats-officedocument.spreadsheetml.sheet, application/vnd.ms-excel" required>
                        </div>
                    </div>

                    <button type="submit" class="btn-primary" style="margin-top: 10px;">Bắt đầu Import</button>
                </form>
            </div>
        </div>
    </main>
</div>

<style>
    .alert { padding: 15px; margin-bottom: 20px; border-radius: 4px; }
    .alert-success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-danger { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .btn-danger { background: #c0392b; color: white; border: none; cursor: pointer; padding: 8px 12px; border-radius: 4px; font-weight: bold; font-size: 13px;}
    .btn-danger:hover { background: #e74c3c; }
</style>
</body>
</html>
