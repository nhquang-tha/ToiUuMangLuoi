<%- include('partials/head') %>
<div class="layout">
    <%- include('partials/sidebar') %>
    <main class="main-content">
        <header class="topbar">
            <h1><%= page %></h1>
        </header>
        <div class="content-body">
            
            <% if(message) { %> <div class="alert alert-success"><%= message %></div> <% } %>
            <% if(error) { %> <div class="alert alert-danger"><%= error %></div> <% } %>

            <div style="display: flex; gap: 20px;">
                <!-- Form Thêm User -->
                <div class="card" style="flex: 1; max-width: 350px;">
                    <h3>Tạo Tài Khoản Mới</h3>
                    <form action="/system/users/add" method="POST" style="margin-top: 15px;">
                        <div class="form-group">
                            <label>Tên Đăng Nhập (Username)</label>
                            <input type="text" name="username" class="form-control" required style="width: 100%; padding: 8px;">
                        </div>
                        <div class="form-group" style="margin-top: 15px;">
                            <label>Mật Khẩu</label>
                            <input type="password" name="password" class="form-control" required style="width: 100%; padding: 8px;">
                        </div>
                        <div class="form-group" style="margin-top: 15px;">
                            <label>Phân Quyền (Role)</label>
                            <select name="role" class="form-control" style="width: 100%; padding: 8px;">
                                <option value="user">User (Chỉ xem)</option>
                                <option value="admin">Admin (Toàn quyền)</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-success" style="margin-top: 20px; width: 100%; padding: 10px; border: none; border-radius: 4px; color: white; cursor: pointer;">Tạo Tài Khoản</button>
                    </form>
                </div>

                <!-- Danh Sách User -->
                <div class="card" style="flex: 2;">
                    <h3>Danh Sách Người Dùng Hệ Thống</h3>
                    <table class="data-table" style="width: 100%; margin-top: 15px; border-collapse: collapse;">
                        <thead style="background: #f8f9fa;">
                            <tr>
                                <th style="padding: 10px; border-bottom: 2px solid #ddd; text-align: left;">ID</th>
                                <th style="padding: 10px; border-bottom: 2px solid #ddd; text-align: left;">Username</th>
                                <th style="padding: 10px; border-bottom: 2px solid #ddd; text-align: left;">Role</th>
                                <th style="padding: 10px; border-bottom: 2px solid #ddd; text-align: center;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(user => { %>
                                <tr>
                                    <td style="padding: 10px; border-bottom: 1px solid #eee;"><%= user.id %></td>
                                    <td style="padding: 10px; border-bottom: 1px solid #eee;"><strong><%= user.username %></strong></td>
                                    <td style="padding: 10px; border-bottom: 1px solid #eee;">
                                        <span style="padding: 3px 8px; border-radius: 12px; font-size: 12px; background: <%= user.role === 'admin' ? '#e74c3c' : '#3498db' %>; color: white;">
                                            <%= user.role.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td style="padding: 10px; border-bottom: 1px solid #eee; text-align: center;">
                                        <% if(currentUser.id !== user.id) { %>
                                            <form action="/system/users/delete/<%= user.id %>" method="POST" onsubmit="return confirm('Xóa tài khoản này?');">
                                                <button type="submit" style="background: #e74c3c; color: white; border: none; padding: 5px 10px; border-radius: 3px; cursor: pointer;">Xóa</button>
                                            </form>
                                        <% } else { %>
                                            <span style="color: #95a5a6; font-size: 12px;">Đang đăng nhập</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>
</div>
<style>
    .alert { padding: 15px; margin-bottom: 20px; border-radius: 4px; }
    .alert-success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-danger { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    .btn-success { background: #27ae60;} .btn-success:hover{ background: #219653; }
</style>
</body>
</html>
