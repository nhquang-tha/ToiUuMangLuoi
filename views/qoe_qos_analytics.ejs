<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; border-top: 4px solid #f1c40f; }
    .filter-row { display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; }
    
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    @media (max-width: 1024px) { .charts-grid { grid-template-columns: 1fr; } }
    
    .chart-container { 
        background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
        height: 420px; position: relative; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;
        animation: fadeIn 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    }

    .chart-container:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.15); }
    .chart-container:hover .zoom-hint { color: #f39c12; font-weight: bold; }
    .zoom-hint { position: absolute; top: 15px; right: 20px; font-size: 12px; color: #bdc3c7; transition: 0.3s; pointer-events: none; z-index: 5;}

    @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    /* Modal Zoom */
    .modal-overlay {
        display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.7);
        align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;
    }
    .modal-overlay.show { display: flex; opacity: 1; }
    .modal-content {
        background: white; padding: 25px; border-radius: 12px; width: 90%; max-width: 1300px; height: 85vh; position: relative;
        transform: scale(0.8); transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94); box-shadow: 0 10px 30px rgba(0,0,0,0.3); display: flex; flex-direction: column;
    }
    .modal-overlay.show .modal-content { transform: scale(1); }
    .close-btn { position: absolute; top: 15px; right: 25px; font-size: 32px; font-weight: bold; color: #7f8c8d; cursor: pointer; transition: 0.2s; z-index: 10; }
    .close-btn:hover { color: #e74c3c; }
    .modal-body { flex: 1; position: relative; width: 100%; height: 100%; }

    /* CSS Cho Bảng Danh Sách */
    .table-wrapper { width: 100%; overflow-x: auto; background: #fff; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: none; animation: fadeIn 0.5s ease; margin-bottom: 30px;}
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; white-space: nowrap; }
    .data-table th, .data-table td { padding: 10px 15px; border-bottom: 1px solid #ecf0f1; text-align: center; }
    .data-table th { background-color: #f8f9fa; color: #2c3e50; font-weight: bold; position: sticky; top: 0; z-index: 10; font-size: 12px;}
    .data-table tbody tr:hover { background-color: #fdf2f2; }
    .note-input { border: 1px solid #bdc3c7; border-radius: 4px; padding: 6px 10px; width: 100%; min-width: 150px; outline: none; transition: 0.2s; }
    .note-input:focus { border-color: #3498db; box-shadow: 0 0 5px rgba(52, 152, 219, 0.3); }
    .btn-kpi { background: #3498db; color: white; padding: 5px 10px; border-radius: 4px; text-decoration: none; font-size: 11px; font-weight: bold; transition: 0.2s;}
    .btn-kpi:hover { background: #2980b9; }

    .trend-up { color: #27ae60; font-weight: bold; font-size: 11px;}
    .trend-down { color: #e74c3c; font-weight: bold; font-size: 11px;}
    .trend-flat { color: #95a5a6; font-size: 11px;}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>So Sánh & Phân Tích Trải Nghiệm (QoE / QoS)</h1>
        </header>
        
        <div class="content-body">
            
            <div class="filter-card">
                <div class="filter-row" style="width: 100%;">
                    <div style="flex: 1; min-width: 300px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#f39c12;">Nhập Tên Cell_Code hoặc Site_Code (Nhập nhiều cách nhau dấu phẩy):</label>
                        <input type="text" id="keywordInput" placeholder="Ví dụ: 4G-THA001M (tìm cả trạm), hoặc 4G-THA001M11, 4G-THA002M (so sánh các cell)" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; border-left: 4px solid #f1c40f;">
                    </div>
                    <div style="text-align: right;">
                        <button onclick="executeAnalysis()" class="btn-primary" style="background: #f39c12; color: white; border: none; padding: 12px 35px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 15px; transition: 0.2s; height: 44px;">
                            ⭐ Phân Tích Biểu Đồ
                        </button>
                    </div>
                </div>
            </div>

            <!-- Các thông báo hệ thống -->
            <div id="initMsg" style="text-align: center; padding: 50px; color: #7f8c8d; font-size: 15px; background: white; border-radius: 8px;">
                <i>Vui lòng nhập Cell_Code hoặc Site_Code và bấm "Phân Tích Biểu Đồ" để vẽ line Chart.<br>Hoặc bấm vào nút bên dưới để xem dữ liệu QoE/QoS của Tuần Mới Nhất.</i>
            </div>
            
            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #e67e22; font-size: 16px; font-weight: bold; background: white; border-radius: 8px; margin-bottom: 15px;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang xử lý...
            </div>
            
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px;"></div>

            <!-- KHU VỰC CHỨA BIỂU ĐỒ ĐỘNG -->
            <div id="dynamicChartsArea" style="display: none;">
                <div class="charts-grid">
                    <div class="chart-container" onclick="openModal('canvas_qoe')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <canvas id="canvas_qoe"></canvas>
                    </div>
                    <div class="chart-container" onclick="openModal('canvas_qos')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <canvas id="canvas_qos"></canvas>
                    </div>
                </div>
            </div>

            <!-- NÚT BẬT BẢNG TỔNG HỢP -->
            <div style="text-align: center; margin: 30px 0;">
                <button onclick="fetchAllList()" style="background: #27ae60; color: white; border: none; padding: 15px 40px; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 16px; transition: 0.3s; box-shadow: 0 4px 10px rgba(39, 174, 96, 0.3);">
                    📋 Xem Danh Sách QoE/QoS (Tuần Mới Nhất)
                </button>
            </div>

            <!-- BẢNG TỔNG HỢP CELL -->
            <div class="table-wrapper" id="listTableContainer">
                <div style="padding: 15px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center;">
                    <div style="font-weight: bold; color: #2c3e50;">Danh sách Tổng Hợp (<span id="totalCells">0</span> Cell)</div>
                    <input type="text" id="tableSearch" placeholder="Lọc nhanh Cell/Site..." onkeyup="filterTable()" style="padding: 6px 12px; border: 1px solid #bdc3c7; border-radius: 4px; outline: none;">
                </div>
                <table class="data-table" id="listTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th style="text-align: left;">Site Name</th>
                            <th style="text-align: left;">Cell Name</th>
                            <th>District</th>
                            <th>MIMO</th>
                            <th>QoE Rank<br><small style="color:#7f8c8d; font-weight:normal;">(Tuần mới nhất)</small></th>
                            <th>QoE Score<br><small style="color:#7f8c8d; font-weight:normal;">(So với TB 4 tuần)</small></th>
                            <th>QoS Rank<br><small style="color:#7f8c8d; font-weight:normal;">(Tuần mới nhất)</small></th>
                            <th>QoS Score<br><small style="color:#7f8c8d; font-weight:normal;">(So với TB 4 tuần)</small></th>
                            <th style="width: 200px;">Lịch Sử Tác Động<br><small style="color:#7f8c8d; font-weight:normal;">(Tự động lưu khi gõ)</small></th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="listTableBody"></tbody>
                </table>
            </div>

        </div>
    </main>
</div>

<!-- MODAL POPUP PHÓNG TO ĐỒ THỊ -->
<div id="chartModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <div class="modal-body" id="modalBodyContainer">
            <canvas id="modalCanvas"></canvas>
        </div>
    </div>
</div>

<script>
    Chart.defaults.font.family = "'Roboto', sans-serif";
    Chart.defaults.color = '#7f8c8d';

    const CHART_COLORS = ['#f39c12', '#e74c3c', '#3498db', '#2ecc71', '#9b59b6', '#1abc9c', '#34495e', '#d35400'];

    window.chartDataStore = {}; 
    window.chartInstances = {}; 
    let modalChartInstance = null;

    function hexToRgba(hex, alpha) {
        let r = parseInt(hex.slice(1, 3), 16);
        let g = parseInt(hex.slice(3, 5), 16);
        let b = parseInt(hex.slice(5, 7), 16);
        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    function sortWeeks(weeksArray) {
        return weeksArray.sort((a, b) => {
            let matchA = a.match(/Tuần (\d+) \((\d+)\)/);
            let matchB = b.match(/Tuần (\d+) \((\d+)\)/);
            if (matchA && matchB) {
                if (matchA[2] !== matchB[2]) return parseInt(matchA[2]) - parseInt(matchB[2]); 
                return parseInt(matchA[1]) - parseInt(matchB[1]); 
            }
            return 0;
        });
    }

    async function executeAnalysis() {
        const val = document.getElementById('keywordInput').value.trim();
        if (!val) return alert("Vui lòng nhập Tên Cell hoặc Site!");

        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('errorMsg').style.display = 'none';
        
        if (window.chartInstances) {
            for (let key in window.chartInstances) {
                if (window.chartInstances[key]) window.chartInstances[key].destroy();
            }
        }
        window.chartInstances = {};
        window.chartDataStore = {};

        document.getElementById('dynamicChartsArea').style.display = 'none';
        document.getElementById('loadingMsg').style.display = 'block';

        try {
            const res = await fetch(`/api/qoe-qos-data?value=${encodeURIComponent(val)}`);
            if (!res.ok) throw new Error("Mã lỗi máy chủ HTTP " + res.status);
            const data = await res.json();
            
            document.getElementById('loadingMsg').style.display = 'none';

            if ((!data.qoe || data.qoe.length === 0) && (!data.qos || data.qos.length === 0)) {
                document.getElementById('errorMsg').innerText = "Hệ thống không tìm thấy dữ liệu QoE hoặc QoS nào khớp với từ khóa của bạn.";
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            document.getElementById('dynamicChartsArea').style.display = 'block';
            
            buildChart('canvas_qoe', data.qoe, 'QoE_Score', '⭐ Điểm Trải Nghiệm (QoE Score)');
            buildChart('canvas_qos', data.qos, 'QoS_Score', '⚙️ Điểm Dịch Vụ (QoS Score)');

        } catch (error) {
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = "Lỗi xử lý hệ thống: " + error.message;
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    function buildChart(canvasId, rawData, valueKey, titleText) {
        if (!rawData || rawData.length === 0) return;

        let allWeeks = sortWeeks([...new Set(rawData.map(d => d.Tuan))].filter(Boolean));
        let allCells = [...new Set(rawData.map(d => d.Cell_Name))].filter(Boolean);

        let datasets = allCells.map((cellName, colorIndex) => {
            const color = CHART_COLORS[colorIndex % CHART_COLORS.length];
            const cellRows = rawData.filter(r => r.Cell_Name === cellName);
            
            const dataPoints = allWeeks.map(week => {
                const row = cellRows.find(r => r.Tuan === week);
                if (!row) return null;
                let val = parseFloat(row[valueKey]);
                return isNaN(val) ? null : val; 
            });

            return {
                label: cellName,
                data: dataPoints,
                borderColor: color,
                baseColor: color, 
                borderWidth: 3,
                pointBackgroundColor: '#fff',
                pointBorderColor: color,
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 8,
                tension: 0.4,
                fill: true, 
                spanGaps: true 
            };
        });

        window.chartDataStore[canvasId] = {
            labels: allWeeks,
            datasets: datasets,
            title: titleText
        };

        const ctx = document.getElementById(canvasId).getContext('2d');
        
        datasets.forEach(ds => {
            let gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, hexToRgba(ds.baseColor, 0.4));
            gradient.addColorStop(1, hexToRgba(ds.baseColor, 0.0));
            ds.backgroundColor = gradient;
        });

        window.chartInstances[canvasId] = new Chart(ctx, {
            type: 'line',
            data: { labels: allWeeks, datasets: datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                layout: { padding: { top: 15 } },
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    title: { display: true, text: titleText, font: { size: 16, weight: 'bold' }, color: '#34495e', padding: { bottom: 15 } },
                    legend: { display: datasets.length > 1, position: 'bottom', labels: { boxWidth: 15, font: { size: 12 } } },
                    tooltip: { 
                        backgroundColor: 'rgba(255, 255, 255, 0.95)', titleColor: '#2c3e50', bodyColor: '#2c3e50', borderColor: '#ecf0f1', borderWidth: 1, padding: 12, boxPadding: 6, usePointStyle: true, titleFont: { size: 14 }, bodyFont: { size: 15, weight: 'bold' }
                    } 
                },
                scales: {
                    x: { grid: { display: false } },
                    y: { beginAtZero: false, grid: { borderDash: [5, 5] } } 
                }
            }
        });
    }

    function openModal(canvasId) {
        const dataStore = window.chartDataStore[canvasId];
        if (!dataStore) return;

        const modal = document.getElementById('chartModal');
        modal.classList.add('show'); 

        setTimeout(() => {
            const ctx = document.getElementById('modalCanvas').getContext('2d');
            if (modalChartInstance) modalChartInstance.destroy(); 

            const zoomedDatasets = dataStore.datasets.map(ds => {
                let gradient = ctx.createLinearGradient(0, 0, 0, 600);
                gradient.addColorStop(0, hexToRgba(ds.baseColor, 0.5));
                gradient.addColorStop(1, hexToRgba(ds.baseColor, 0.0));

                return {
                    label: ds.label, data: [...ds.data], borderColor: ds.borderColor, backgroundColor: gradient, borderWidth: 4, pointBackgroundColor: '#ffffff', pointBorderColor: ds.borderColor, pointBorderWidth: 3, pointRadius: 6, pointHoverRadius: 10, fill: true, tension: 0.4, spanGaps: true
                };
            });

            modalChartInstance = new Chart(ctx, {
                type: 'line',
                data: { labels: dataStore.labels, datasets: zoomedDatasets },
                options: {
                    responsive: true, maintainAspectRatio: false, animation: { duration: 600, easing: 'easeOutQuart' },
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        title: { display: true, text: dataStore.title, font: { size: 24, weight: 'bold' }, color: '#2c3e50', padding: { bottom: 20 } },
                        legend: { display: zoomedDatasets.length > 1, position: 'bottom', labels: { font: { size: 16 } } },
                        tooltip: { backgroundColor: 'rgba(44, 62, 80, 0.95)', titleColor: '#fff', bodyColor: '#fff', titleFont: { size: 18 }, bodyFont: { size: 18, weight: 'bold' }, padding: 15, cornerRadius: 8, displayColors: true }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 16 } } },
                        y: { beginAtZero: false, grid: { borderDash: [5, 5], color: '#ecf0f1' }, ticks: { font: { size: 16 } } }
                    }
                }
            });
        }, 50); 
    }

    function closeModal() { document.getElementById('chartModal').classList.remove('show'); }
    window.onclick = function(e) { if (e.target === document.getElementById('chartModal')) closeModal(); }

    // =========================================================
    // HÀM XỬ LÝ BẢNG TỔNG HỢP LIST TOÀN BỘ CELL VÀ XU HƯỚNG
    // =========================================================
    function getTrendHtml(trendVal) {
        if (trendVal === 0 || trendVal === null || isNaN(trendVal)) return `<span class="trend-flat">-</span>`;
        if (trendVal > 0) return `<span class="trend-up">▲ +${trendVal.toFixed(2)}</span>`;
        return `<span class="trend-down">▼ ${trendVal.toFixed(2)}</span>`;
    }

    async function fetchAllList() {
        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('loadingMsg').style.display = 'block';
        document.getElementById('errorMsg').style.display = 'none';
        document.getElementById('listTableContainer').style.display = 'none';

        try {
            const res = await fetch('/api/qoe-qos-list-all');
            if(!res.ok) throw new Error("Lỗi API");
            const data = await res.json();

            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('totalCells').innerText = data.length;

            let tbodyHtml = '';
            data.forEach((r, idx) => {
                let qoeClass = (r.QoE_Rank !== null && r.QoE_Rank < 3) ? 'style="color:#e74c3c; font-weight:bold"' : '';
                let qosClass = (r.QoS_Rank !== null && r.QoS_Rank < 3) ? 'style="color:#e74c3c; font-weight:bold"' : '';

                tbodyHtml += `
                    <tr>
                        <td>${idx + 1}</td>
                        <td style="text-align:left;">${r.Site_Name || ''}</td>
                        <td style="text-align:left; font-weight:bold; color:#2980b9;">${r.Cell_Name}</td>
                        <td>${r.District || ''}</td>
                        <td>${r.MIMO || ''}</td>
                        <td ${qoeClass}>${r.QoE_Rank !== null ? r.QoE_Rank : '-'}</td>
                        <td><span style="font-weight:bold;">${r.QoE_Score !== null ? r.QoE_Score.toFixed(2) : '-'}</span><br>${getTrendHtml(r.QoE_Trend)}</td>
                        <td ${qosClass}>${r.QoS_Rank !== null ? r.QoS_Rank : '-'}</td>
                        <td><span style="font-weight:bold;">${r.QoS_Score !== null ? r.QoS_Score.toFixed(2) : '-'}</span><br>${getTrendHtml(r.QoS_Trend)}</td>
                        <td>
                            <input type="text" class="note-input" value="${r.lich_su_tac_dong || ''}" placeholder="Ghi chú xử lý..." onchange="saveNote('${r.Cell_Name}', this.value)">
                        </td>
                        <td>
                            <a href="/kpi-analytics?network=4g&cell=${encodeURIComponent(r.Cell_Name)}" target="_blank" class="btn-kpi">📊 Xem KPI</a>
                        </td>
                    </tr>
                `;
            });

            document.getElementById('listTableBody').innerHTML = tbodyHtml;
            document.getElementById('listTableContainer').style.display = 'block';

        } catch (e) {
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = "Không thể tải danh sách. Vui lòng đảm bảo bạn đã Import dữ liệu KPI 4G và QoE/QoS để kích hoạt bảng đồng bộ.";
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    async function saveNote(cellName, noteValue) {
        try {
            await fetch('/api/save-cell-note', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({cell_name: cellName, note: noteValue})
            });
        } catch(e) {
            alert('Lưu lịch sử thất bại. Vui lòng kiểm tra kết nối mạng!');
        }
    }

    function filterTable() {
        let input = document.getElementById("tableSearch");
        let filter = input.value.toUpperCase();
        let table = document.getElementById("listTable");
        let tr = table.getElementsByTagName("tr");

        for (let i = 1; i < tr.length; i++) {
            let tdSite = tr[i].getElementsByTagName("td")[1];
            let tdCell = tr[i].getElementsByTagName("td")[2];
            if (tdSite || tdCell) {
                let txtValueSite = tdSite.textContent || tdSite.innerText;
                let txtValueCell = tdCell.textContent || tdCell.innerText;
                if (txtValueSite.toUpperCase().indexOf(filter) > -1 || txtValueCell.toUpperCase().indexOf(filter) > -1) {
                    tr[i].style.display = "";
                } else {
                    tr[i].style.display = "none";
                }
            }       
        }
    }
</script>
</body>
</html>
