<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f5f7fa; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); margin-bottom: 25px; border-top: 4px solid #f1c40f; }
    .filter-row { display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; }
    
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    @media (max-width: 1024px) { .charts-grid { grid-template-columns: 1fr; } }
    
    .chart-container { 
        background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); 
        height: 420px; position: relative; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;
        animation: fadeIn 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards; border: 1px solid #ecf0f1;
    }

    .chart-container:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
    .chart-container:hover .zoom-hint { color: #f39c12; font-weight: bold; }
    .zoom-hint { position: absolute; top: 15px; right: 20px; font-size: 12px; color: #bdc3c7; transition: 0.3s; pointer-events: none; z-index: 5;}

    @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    .modal-overlay {
        display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.6);
        align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease; backdrop-filter: blur(4px);
    }
    .modal-overlay.show { display: flex; opacity: 1; }
    .modal-content {
        background: white; padding: 25px; border-radius: 12px; width: 90%; max-width: 1300px; height: 85vh; position: relative;
        transform: scale(0.8); transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94); box-shadow: 0 15px 40px rgba(0,0,0,0.2); display: flex; flex-direction: column;
    }
    .modal-overlay.show .modal-content { transform: scale(1); }
    .close-btn { position: absolute; top: 15px; right: 25px; font-size: 32px; font-weight: bold; color: #7f8c8d; cursor: pointer; transition: 0.2s; z-index: 10; }
    .close-btn:hover { color: #e74c3c; }
    .modal-body { flex: 1; position: relative; width: 100%; height: 100%; }

    .table-wrapper { width: 100%; max-height: 600px; overflow: auto; background: #fff; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); display: none; animation: fadeIn 0.5s ease; margin-bottom: 30px; border: 1px solid #ecf0f1;}
    .data-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: 13px; white-space: nowrap; }
    .data-table th, .data-table td { padding: 12px 15px; text-align: center; }
    .data-table th { background-color: #f8f9fa; color: #2c3e50; font-weight: bold; position: sticky; top: 0; z-index: 10; font-size: 12px; border-bottom: 2px solid #ecf0f1;}
    .data-table td { border-bottom: 1px solid #ecf0f1; }
    .data-table tbody tr:hover { background-color: #fdf2f2; }
    .note-input { border: 1px solid #dcdde1; border-radius: 6px; padding: 8px 12px; width: 100%; min-width: 150px; outline: none; transition: 0.2s; }
    .note-input:focus { border-color: #54a0ff; box-shadow: 0 0 0 3px rgba(84,160,255,0.15); }

    .trend-up { color: #27ae60; font-weight: bold; font-size: 11px;}
    .trend-down { color: #e74c3c; font-weight: bold; font-size: 11px;}
    .trend-flat { color: #95a5a6; font-size: 11px;}
    
    .table-controls { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; position: sticky; left: 15px;}
    .table-filter-select { padding: 8px 12px; border: 1px solid #dcdde1; border-radius: 6px; outline: none; font-size: 13px; color: #34495e;}
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>So Sánh & Phân Tích Trải Nghiệm (QoE / QoS)</h1>
        </header>
        
        <div class="content-body">
            
            <div class="filter-card">
                <div class="filter-row" style="width: 100%; align-items: flex-end;">
                    <div style="flex: 2; min-width: 250px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#f39c12;">Nhập Tên Cell_Code hoặc Site_Code (Nhập nhiều cách nhau dấu phẩy):</label>
                        <input type="text" id="keywordInput" placeholder="Ví dụ: 4G-THA001M (tìm cả trạm), hoặc 4G-THA001M11, 4G-THA002M (so sánh các cell)" style="width: 100%; outline: none; border-left: 4px solid #f1c40f; box-sizing: border-box;">
                    </div>
                    <div style="flex: 1; min-width: 150px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#f39c12;">Thời gian vẽ biểu đồ:</label>
                        <select id="chartWeeksLimit" style="width: 100%; outline: none; font-size: 13px; box-sizing: border-box; cursor: pointer;">
                            <option value="5">5 Tuần gần nhất</option>
                            <option value="10" selected>10 Tuần gần nhất</option>
                            <option value="20">20 Tuần gần nhất</option>
                            <option value="all">Tất cả các tuần</option>
                        </select>
                    </div>
                    <div style="text-align: right;">
                        <button onclick="executeAnalysis()" class="btn-primary" style="background: #f39c12; color: white; border: none; padding: 0 30px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 14px; transition: 0.2s; height: 38px; display: inline-flex; align-items: center; justify-content: center;">
                            ⭐ Phân Tích Biểu Đồ
                        </button>
                    </div>
                </div>
            </div>

            <div id="initMsg" style="text-align: center; padding: 50px; color: #7f8c8d; font-size: 14px; background: white; border-radius: 8px; border: 1px solid #ecf0f1;">
                <i>Vui lòng nhập Cell_Code hoặc Site_Code và bấm "Phân Tích Biểu Đồ" để vẽ line Chart.<br>Hoặc bấm vào nút bên dưới để xem dữ liệu QoE/QoS của Tuần Mới Nhất.</i>
            </div>
            
            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #e67e22; font-size: 15px; font-weight: bold; background: white; border-radius: 8px; margin-bottom: 15px; border: 1px solid #f9e79f;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang xử lý...
            </div>
            
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px; font-size: 14px;"></div>

            <div id="dynamicChartsArea" style="display: none;">
                <div class="charts-grid">
                    <div class="chart-container" onclick="openModal('canvas_qoe')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <canvas id="canvas_qoe"></canvas>
                    </div>
                    <div class="chart-container" onclick="openModal('canvas_qos')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <canvas id="canvas_qos"></canvas>
                    </div>
                </div>
            </div>

            <div style="text-align: center; margin: 30px 0;">
                <button onclick="fetchAllList()" class="btn-success" style="background: #27ae60; color: white; padding: 12px 35px; border-radius: 8px; font-weight: bold; font-size: 15px; box-shadow: 0 4px 10px rgba(39, 174, 96, 0.2);">
                    📋 Xem Bảng Danh Sách QoE/QoS (Tuần Mới Nhất)
                </button>
            </div>

            <!-- BẢNG TỔNG HỢP CELL -->
            <div class="table-wrapper" id="listTableContainer">
                <div style="padding: 15px 20px; border-bottom: 1px solid #ecf0f1; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; position: sticky; top: 0; left: 0; background: white; z-index: 11;">
                    <div style="font-weight: bold; color: #2c3e50; font-size: 15px; white-space: nowrap;">Danh sách (<span id="totalCells">0</span> Cell)</div>
                    <div class="table-controls">
                        <select id="districtFilter" class="table-filter-select" onchange="filterTable()">
                            <option value="">-- Tất cả District --</option>
                        </select>
                        <select id="qoeRankFilter" class="table-filter-select" onchange="filterTable()">
                            <option value="">-- Tất cả QoE Rank --</option>
                            <option value="1">Rank 1</option>
                            <option value="2">Rank 2</option>
                            <option value="3">Rank 3</option>
                            <option value="4">Rank 4</option>
                            <option value="5">Rank 5</option>
                        </select>
                        <select id="qosRankFilter" class="table-filter-select" onchange="filterTable()">
                            <option value="">-- Tất cả QoS Rank --</option>
                            <option value="1">Rank 1</option>
                            <option value="2">Rank 2</option>
                            <option value="3">Rank 3</option>
                            <option value="4">Rank 4</option>
                            <option value="5">Rank 5</option>
                        </select>
                        <input type="text" id="tableSearch" placeholder="Tìm Cell/Site..." onkeyup="filterTable()" style="padding: 8px 12px; border: 1px solid #dcdde1; border-radius: 6px; outline: none; font-size: 13px;">
                        <button onclick="exportTableToExcel()" class="btn-primary" style="background:#27ae60; white-space: nowrap;">📥 Xuất Excel</button>
                    </div>
                </div>
                <table class="data-table" id="listTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th style="text-align: left;">Site Name</th>
                            <th style="text-align: left;">Cell Name</th>
                            <th>District</th>
                            <th>MIMO</th>
                            <th>QoE Rank<br><small style="color:#7f8c8d; font-weight:normal;">(Tuần mới nhất)</small></th>
                            <th>QoE Score<br><small style="color:#7f8c8d; font-weight:normal;">(So với TB 4 tuần)</small></th>
                            <th>QoS Rank<br><small style="color:#7f8c8d; font-weight:normal;">(Tuần mới nhất)</small></th>
                            <th>QoS Score<br><small style="color:#7f8c8d; font-weight:normal;">(So với TB 4 tuần)</small></th>
                            <th style="width: 200px;">Lịch Sử Tác Động<br><small style="color:#7f8c8d; font-weight:normal;">(Tự động lưu khi gõ)</small></th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="listTableBody"></tbody>
                </table>
            </div>

        </div>
    </main>
</div>

<!-- MODAL POPUP PHÓNG TO ĐỒ THỊ -->
<div id="chartModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <div class="modal-body" id="modalBodyContainer">
            <canvas id="modalCanvas"></canvas>
        </div>
    </div>
</div>

<script>
    Chart.defaults.font.family = "'Inter', sans-serif";
    Chart.defaults.color = '#7f8c8d';

    const CHART_COLORS = ['#f39c12', '#e74c3c', '#3498db', '#2ecc71', '#9b59b6', '#1abc9c', '#34495e', '#d35400'];

    window.chartDataStore = {}; 
    window.chartInstances = {}; 
    window.allQoeQosData = []; 
    let modalChartInstance = null;

    document.addEventListener('DOMContentLoaded', function() {
        const xlsxScript = document.createElement('script');
        xlsxScript.src = atob('aHR0cHM6Ly91bnBrZy5jb20veGxzeC9kaXN0L3hsc3guZnVsbC5taW4uanM=');
        document.head.appendChild(xlsxScript);
    });

    function hexToRgba(hex, alpha) {
        let r = parseInt(hex.slice(1, 3), 16);
        let g = parseInt(hex.slice(3, 5), 16);
        let b = parseInt(hex.slice(5, 7), 16);
        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    function sortWeeks(weeksArray) {
        return weeksArray.sort((a, b) => {
            let matchA = a.match(/Tuần (\d+) \((\d+)\)/);
            let matchB = b.match(/Tuần (\d+) \((\d+)\)/);
            if (matchA && matchB) {
                if (matchA[2] !== matchB[2]) return parseInt(matchA[2]) - parseInt(matchB[2]); 
                return parseInt(matchA[1]) - parseInt(matchB[1]); 
            }
            return 0;
        });
    }

    async function executeAnalysis() {
        const val = document.getElementById('keywordInput').value.trim();
        const limitVal = document.getElementById('chartWeeksLimit').value;
        if (!val) return alert("Vui lòng nhập Tên Cell hoặc Site!");

        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('errorMsg').style.display = 'none';
        
        if (window.chartInstances) {
            for (let key in window.chartInstances) {
                if (window.chartInstances[key]) window.chartInstances[key].destroy();
            }
        }
        window.chartInstances = {};
        window.chartDataStore = {};

        document.getElementById('dynamicChartsArea').style.display = 'none';
        document.getElementById('loadingMsg').style.display = 'block';

        try {
            const res = await fetch(`/api/qoe-qos-data?value=${encodeURIComponent(val)}`);
            if (!res.ok) throw new Error("Mã lỗi máy chủ HTTP " + res.status);
            const data = await res.json();
            
            document.getElementById('loadingMsg').style.display = 'none';

            if ((!data.qoe || data.qoe.length === 0) && (!data.qos || data.qos.length === 0)) {
                document.getElementById('errorMsg').innerText = "Hệ thống không tìm thấy dữ liệu QoE hoặc QoS nào khớp với từ khóa của bạn.";
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            document.getElementById('dynamicChartsArea').style.display = 'block';
            
            buildChart('canvas_qoe', data.qoe, 'QoE_Score', '⭐ Điểm Trải Nghiệm (QoE Score)', limitVal);
            buildChart('canvas_qos', data.qos, 'QoS_Score', '⚙️ Điểm Dịch Vụ (QoS Score)', limitVal);

        } catch (error) {
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = "Lỗi xử lý hệ thống: " + error.message;
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    function buildChart(canvasId, rawData, valueKey, titleText, limitVal) {
        if (!rawData || rawData.length === 0) return;

        let allWeeks = sortWeeks([...new Set(rawData.map(d => d.Tuan))].filter(Boolean));
        
        if (limitVal !== 'all') {
            let limit = parseInt(limitVal);
            if (allWeeks.length > limit) {
                allWeeks = allWeeks.slice(-limit);
            }
        }

        let allCells = [...new Set(rawData.map(d => d.Cell_Name))].filter(Boolean);

        let datasets = allCells.map((cellName, colorIndex) => {
            const color = CHART_COLORS[colorIndex % CHART_COLORS.length];
            const cellRows = rawData.filter(r => r.Cell_Name === cellName);
            
            const dataPoints = allWeeks.map(week => {
                const row = cellRows.find(r => r.Tuan === week);
                if (!row) return null;
                let val = parseFloat(row[valueKey]);
                return isNaN(val) ? null : val; 
            });

            return {
                label: cellName, data: dataPoints, borderColor: color, baseColor: color, 
                borderWidth: 3, pointBackgroundColor: '#fff', pointBorderColor: color,
                pointBorderWidth: 2, pointRadius: 4, pointHoverRadius: 8, tension: 0.4, fill: true, spanGaps: true 
            };
        });

        window.chartDataStore[canvasId] = { labels: allWeeks, datasets: datasets, title: titleText };
        const ctx = document.getElementById(canvasId).getContext('2d');
        
        datasets.forEach(ds => {
            let gradient = ctx.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, hexToRgba(ds.baseColor, 0.4));
            gradient.addColorStop(1, hexToRgba(ds.baseColor, 0.0));
            ds.backgroundColor = gradient;
        });

        window.chartInstances[canvasId] = new Chart(ctx, {
            type: 'line', data: { labels: allWeeks, datasets: datasets },
            options: {
                responsive: true, maintainAspectRatio: false, layout: { padding: { top: 15 } }, interaction: { mode: 'index', intersect: false },
                plugins: {
                    title: { display: true, text: titleText, font: { size: 16, weight: 'bold' }, color: '#34495e', padding: { bottom: 15 } },
                    legend: { display: datasets.length > 1, position: 'bottom', labels: { boxWidth: 15, font: { size: 12 } } },
                    tooltip: { backgroundColor: 'rgba(255, 255, 255, 0.95)', titleColor: '#2c3e50', bodyColor: '#2c3e50', borderColor: '#ecf0f1', borderWidth: 1, padding: 12, boxPadding: 6, usePointStyle: true, titleFont: { size: 14 }, bodyFont: { size: 15, weight: 'bold' } } 
                },
                scales: { x: { grid: { display: false } }, y: { beginAtZero: false, grid: { borderDash: [5, 5] } } }
            }
        });
    }

    function openModal(canvasId) {
        const dataStore = window.chartDataStore[canvasId];
        if (!dataStore) return;

        const modal = document.getElementById('chartModal');
        modal.classList.add('show'); 

        setTimeout(() => {
            const ctx = document.getElementById('modalCanvas').getContext('2d');
            if (modalChartInstance) modalChartInstance.destroy(); 

            const zoomedDatasets = dataStore.datasets.map(ds => {
                let gradient = ctx.createLinearGradient(0, 0, 0, 600);
                gradient.addColorStop(0, hexToRgba(ds.baseColor, 0.5));
                gradient.addColorStop(1, hexToRgba(ds.baseColor, 0.0));
                return {
                    label: ds.label, data: [...ds.data], borderColor: ds.borderColor, backgroundColor: gradient, borderWidth: 4, pointBackgroundColor: '#ffffff', pointBorderColor: ds.borderColor, pointBorderWidth: 3, pointRadius: 6, pointHoverRadius: 10, fill: true, tension: 0.4, spanGaps: true
                };
            });

            modalChartInstance = new Chart(ctx, {
                type: 'line', data: { labels: dataStore.labels, datasets: zoomedDatasets },
                options: {
                    responsive: true, maintainAspectRatio: false, animation: { duration: 600, easing: 'easeOutQuart' }, interaction: { mode: 'index', intersect: false },
                    plugins: {
                        title: { display: true, text: dataStore.title, font: { size: 24, weight: 'bold' }, color: '#2c3e50', padding: { bottom: 20 } },
                        legend: { display: zoomedDatasets.length > 1, position: 'bottom', labels: { font: { size: 16 } } },
                        tooltip: { backgroundColor: 'rgba(44, 62, 80, 0.95)', titleColor: '#fff', bodyColor: '#fff', titleFont: { size: 18 }, bodyFont: { size: 18, weight: 'bold' }, padding: 15, cornerRadius: 8, displayColors: true }
                    },
                    scales: { x: { grid: { display: false }, ticks: { font: { size: 16 } } }, y: { beginAtZero: false, grid: { borderDash: [5, 5], color: '#ecf0f1' }, ticks: { font: { size: 16 } } } }
                }
            });
        }, 50); 
    }

    function closeModal() { document.getElementById('chartModal').classList.remove('show'); }
    window.onclick = function(e) { if (e.target === document.getElementById('chartModal')) closeModal(); }

    function getTrendHtml(trendVal) {
        if (trendVal === 0 || trendVal === null || isNaN(trendVal)) return `<span class="trend-flat">-</span>`;
        if (trendVal > 0) return `<span class="trend-up">▲ +${trendVal.toFixed(2)}</span>`;
        return `<span class="trend-down">▼ ${Math.abs(trendVal).toFixed(2)}</span>`;
    }

    async function fetchAllList() {
        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('loadingMsg').style.display = 'block';
        document.getElementById('errorMsg').style.display = 'none';
        document.getElementById('listTableContainer').style.display = 'none';

        try {
            const res = await fetch('/api/qoe-qos-list-all');
            window.allQoeQosData = await res.json();

            document.getElementById('loadingMsg').style.display = 'none';
            
            // Xử lý an toàn: Chỉ thông báo khi dữ liệu THỰC SỰ trống
            if (!window.allQoeQosData || window.allQoeQosData.length === 0) {
                document.getElementById('errorMsg').innerText = "Bảng dữ liệu QoE/QoS hiện đang trống. Hãy kiểm tra lại Database (bảng qoe_qos).";
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }
            
            let districts = new Set();
            window.allQoeQosData.forEach(r => { if(r.District) districts.add(r.District); });

            const districtSelect = document.getElementById('districtFilter');
            districtSelect.innerHTML = '<option value="">-- Tất cả District --</option>';
            Array.from(districts).sort().forEach(d => {
                let opt = document.createElement('option');
                opt.value = d; opt.textContent = d;
                districtSelect.appendChild(opt);
            });

            document.getElementById('listTableContainer').style.display = 'block';
            renderTableHTML(window.allQoeQosData);

        } catch (e) {
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = "Đã xảy ra lỗi khi lấy danh sách. Vui lòng kiểm tra lại hệ thống máy chủ.";
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    function renderTableHTML(dataToRender) {
        let tbodyHtml = '';
        dataToRender.forEach((r, idx) => {
            let qoeClass = (r.QoE_Rank !== null && r.QoE_Rank < 3) ? 'style="color:#e74c3c; font-weight:bold"' : '';
            let qosClass = (r.QoS_Rank !== null && r.QoS_Rank < 3) ? 'style="color:#e74c3c; font-weight:bold"' : '';

            tbodyHtml += `
                <tr>
                    <td class="stt-col">${idx + 1}</td>
                    <td style="text-align:left;">${r.Site_Name || ''}</td>
                    <td style="text-align:left; font-weight:bold; color:#3498db;">${r.Cell_Name}</td>
                    <td>${r.District || ''}</td>
                    <td>${r.MIMO || ''}</td>
                    <td ${qoeClass}>${r.QoE_Rank !== null ? r.QoE_Rank : '-'}</td>
                    <td><span style="font-weight:bold;">${r.QoE_Score !== null ? r.QoE_Score.toFixed(2) : '-'}</span><br>${getTrendHtml(r.QoE_Trend)}</td>
                    <td ${qosClass}>${r.QoS_Rank !== null ? r.QoS_Rank : '-'}</td>
                    <td><span style="font-weight:bold;">${r.QoS_Score !== null ? r.QoS_Score.toFixed(2) : '-'}</span><br>${getTrendHtml(r.QoS_Trend)}</td>
                    <td>
                        <input type="text" class="note-input" value="${r.lich_su_tac_dong || ''}" placeholder="Ghi chú xử lý..." onchange="saveNote('${r.Cell_Name}', this.value)">
                    </td>
                    <td>
                        <a href="/kpi-analytics?network=4g&cell=${encodeURIComponent(r.Cell_Name)}" target="_blank" class="btn-kpi">📊 Xem KPI</a>
                    </td>
                </tr>
            `;
        });
        
        document.getElementById('listTableBody').innerHTML = tbodyHtml;
        document.getElementById("totalCells").innerText = dataToRender.length;
    }

    async function saveNote(cellName, noteValue) {
        try {
            await fetch('/api/save-cell-note', {
                method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({cell_name: cellName, note: noteValue})
            });
            let cell = window.allQoeQosData.find(c => c.Cell_Name === cellName);
            if (cell) cell.lich_su_tac_dong = noteValue;
        } catch(e) { alert('Lưu lịch sử thất bại. Vui lòng kiểm tra kết nối mạng!'); }
    }

    let filterTimeout;
    function filterTable() {
        clearTimeout(filterTimeout);
        filterTimeout = setTimeout(() => {
            let searchInput = document.getElementById("tableSearch").value.toUpperCase();
            let districtFilter = document.getElementById("districtFilter").value.toUpperCase();
            let qoeRankFilter = document.getElementById("qoeRankFilter").value;
            let qosRankFilter = document.getElementById("qosRankFilter").value;

            let filteredData = window.allQoeQosData.filter(r => {
                let siteText = (r.Site_Name || '').toUpperCase();
                let cellText = (r.Cell_Name || '').toUpperCase();
                let districtText = (r.District || '').toUpperCase();
                let qoeRankText = r.QoE_Rank !== null ? String(r.QoE_Rank) : '';
                let qosRankText = r.QoS_Rank !== null ? String(r.QoS_Rank) : '';

                let matchSearch = (siteText.includes(searchInput) || cellText.includes(searchInput));
                let matchDistrict = (districtFilter === "" || districtText === districtFilter);
                let matchQoeRank = (qoeRankFilter === "" || qoeRankText === qoeRankFilter);
                let matchQosRank = (qosRankFilter === "" || qosRankText === qosRankFilter);

                return matchSearch && matchDistrict && matchQoeRank && matchQosRank;
            });

            renderTableHTML(filteredData);
        }, 150); 
    }

    function exportTableToExcel() {
        if (typeof XLSX === 'undefined') {
            alert('Thư viện Excel chưa tải xong, vui lòng đợi...'); return;
        }
        
        let searchInput = document.getElementById("tableSearch").value.toUpperCase();
        let districtFilter = document.getElementById("districtFilter").value.toUpperCase();
        let qoeRankFilter = document.getElementById("qoeRankFilter").value;
        let qosRankFilter = document.getElementById("qosRankFilter").value;

        let filteredData = window.allQoeQosData.filter(r => {
            let siteText = (r.Site_Name || '').toUpperCase();
            let cellText = (r.Cell_Name || '').toUpperCase();
            let districtText = (r.District || '').toUpperCase();
            let qoeRankText = r.QoE_Rank !== null ? String(r.QoE_Rank) : '';
            let qosRankText = r.QoS_Rank !== null ? String(r.QoS_Rank) : '';

            return (siteText.includes(searchInput) || cellText.includes(searchInput)) &&
                   (districtFilter === "" || districtText === districtFilter) &&
                   (qoeRankFilter === "" || qoeRankText === qoeRankFilter) &&
                   (qosRankFilter === "" || qosRankText === qosRankFilter);
        });

        let exportData = filteredData.map((r, i) => ({
            "STT": i + 1,
            "Site Name": r.Site_Name || '',
            "Cell Name": r.Cell_Name || '',
            "District": r.District || '',
            "MIMO": r.MIMO || '',
            "QoE Rank (Mới nhất)": r.QoE_Rank !== null ? r.QoE_Rank : '-',
            "QoE Score (Mới nhất)": r.QoE_Score !== null ? r.QoE_Score.toFixed(2) : '-',
            "QoE Trend (Biến động)": r.QoE_Trend ? r.QoE_Trend.toFixed(2) : '-',
            "QoS Rank (Mới nhất)": r.QoS_Rank !== null ? r.QoS_Rank : '-',
            "QoS Score (Mới nhất)": r.QoS_Score !== null ? r.QoS_Score.toFixed(2) : '-',
            "QoS Trend (Biến động)": r.QoS_Trend ? r.QoS_Trend.toFixed(2) : '-',
            "Lịch Sử Tác Động": r.lich_su_tac_dong || ''
        }));

        let ws = XLSX.utils.json_to_sheet(exportData);
        let wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Danh_Sach_QoE_QoS");
        XLSX.writeFile(wb, "Danh_Sach_Tong_Hop_QoE_QoS.xlsx");
    }
</script>
</body>
</html>
