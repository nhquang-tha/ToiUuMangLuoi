<aside class="sidebar">
    <div class="sidebar-header">
        <h2>TELECOM DB</h2>
        <p style="font-size: 12px; color: #bdc3c7;">Xin chào, <%= typeof currentUser !== 'undefined' ? currentUser.username : 'Guest' %></p>
    </div>
    <ul class="nav-links">
        <li class="nav-group">Báo Cáo & Phân Tích</li>
        <li><a href="/" class="<%= page === 'Dashboard' ? 'active' : '' %>">Dashboard</a></li>
        <li><a href="/kpi-analytics" class="<%= page === 'KPI Analytics' ? 'active' : '' %>">KPI Analytics</a></li>
        <li><a href="/poi-report" class="<%= page === 'POI Report' ? 'active' : '' %>">POI Report</a></li>
        <li><a href="/worst-cells" class="<%= page === 'Worst Cells' ? 'active' : '' %>">Worst Cells</a></li>
        <li><a href="/congestion-3g" class="<%= page === 'Congestion 3G' ? 'active' : '' %>">Congestion 3G</a></li>
        <li><a href="/traffic-down" class="<%= page === 'Traffic Down' ? 'active' : '' %>">Traffic Down</a></li>

        <li class="nav-group" style="margin-top: 15px;">Quản Lý Dữ Liệu</li>
        <li><a href="/rf-database" class="<%= page === 'RF Database' ? 'active' : '' %>">RF Database</a></li>
        <li><a href="/scrip" class="<%= page === 'Scrip' ? 'active' : '' %>">Scrip</a></li>
        
        <!-- Chỉ Admin mới thấy menu Import Data -->
        <% if(typeof currentUser !== 'undefined' && currentUser.role === 'admin') { %>
            <li><a href="/import-data" class="<%= page === 'Import Data' ? 'active' : '' %>">Import Data (Admin)</a></li>
        <% } %>

        <li class="nav-group" style="margin-top: 15px;">Hệ Thống (System)</li>
        
        <!-- Chỉ Admin mới có quyền Quản lý User -->
        <% if(typeof currentUser !== 'undefined' && currentUser.role === 'admin') { %>
            <li><a href="/system/users" class="<%= page === 'User Manager' ? 'active' : '' %>">User Manager</a></li>
        <% } %>
        
        <li><a href="/system/profile" class="<%= page === 'Profile' ? 'active' : '' %>">Profile (Đổi Mật Khẩu)</a></li>
        <li><a href="/logout" style="color: #e74c3c;">Logout</a></li>
    </ul>
</aside>

<style>
    .sidebar { width: 250px; background: #2c3e50; color: white; height: 100vh; overflow-y: auto; }
    .sidebar-header { padding: 20px; background: #1a252f; text-align: center; }
    .sidebar-header h2 { margin: 0; font-size: 20px; letter-spacing: 1px; }
    .nav-links { list-style: none; padding: 0; margin: 0; }
    .nav-links li a { display: block; padding: 12px 20px; color: #ecf0f1; text-decoration: none; border-bottom: 1px solid #34495e; transition: 0.3s; }
    .nav-links li a:hover, .nav-links li a.active { background: #34495e; border-left: 4px solid #3498db; padding-left: 16px; }
    .nav-group { padding: 10px 20px 5px 20px; font-size: 11px; text-transform: uppercase; color: #95a5a6; font-weight: bold; letter-spacing: 1px; background: #243342; }
</style>
