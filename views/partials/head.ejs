<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'VNPT Telecom Dashboard' %></title>
    
    <!-- 1. FONT CHỮ HIỆN ĐẠI INTER -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- 2. BỘ ICON PHOSPHOR SIÊU NÉT -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <script>
        // Script chạy ngay lập tức để tránh nhấp nháy màn hình (FOUC) khi bật Dark Mode
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>

    <style>
        /* ==========================================
           HỆ THỐNG MÀU SẮC TOÀN CỤC (COLOR PALETTE)
           ========================================== */
        :root {
            /* 1. CHẾ ĐỘ SÁNG (LIGHT MODE) - Tông màu Trung tính, Earthy */
            --bg-body: #f4f6f8;       /* 60% Nền tảng: Xám nhạt thanh lịch */
            --bg-surface: #ffffff;    /* Màu mặt thẻ (Card) */
            
            --text-main: #1e293b;     /* 30% Chủ đạo: Chữ màu Slate 800 */
            --text-muted: #64748b;    /* Chữ phụ Slate 500 */
            
            --border-color: #e2e8f0;  /* Viền mềm mại */
            
            /* 10% Điểm nhấn (Vibrant CTA) */
            --primary: #3b82f6;       /* Xanh Electric */
            --primary-hover: #2563eb;
            --cta-gradient: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%); /* Chuyển màu mượt mà */
            --cta-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);

            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --info: #0ea5e9;
            
            --radius-md: 12px;
            --radius-sm: 8px;
            --shadow-card: 0 4px 20px rgba(0,0,0,0.03);
            --transition-theme: background-color 0.4s ease, color 0.4s ease, border-color 0.4s ease;
        }

        [data-theme="dark"] {
            /* 2. CHẾ ĐỘ TỐI (DARK MODE) - Navy thẳm, Sang trọng, Không mỏi mắt */
            --bg-body: #0f172a;       /* Nền xanh đen (Deep Navy) */
            --bg-surface: #1e293b;    /* Mặt thẻ nổi bật hơn một chút */
            
            --text-main: #f1f5f9;     /* Chữ xám trắng sáng */
            --text-muted: #94a3b8;    /* Chữ phụ tối hơn */
            
            --border-color: #334155;  /* Viền tối, hòa vào nền */
            
            /* Điểm nhấn trong Dark Mode (Dùng Cam hoàng hôn/Vàng kim) */
            --primary: #f59e0b;
            --primary-hover: #d97706;
            --cta-gradient: linear-gradient(135deg, #f97316 0%, #eab308 100%);
            --cta-shadow: 0 4px 15px rgba(249, 115, 22, 0.2);

            --shadow-card: 0 8px 25px rgba(0,0,0,0.4);
        }

        body { 
            font-family: 'Inter', -apple-system, sans-serif; 
            margin: 0; 
            background-color: var(--bg-body); 
            color: var(--text-main); 
            font-size: 13.5px;
            line-height: 1.6;
            transition: var(--transition-theme);
        }

        /* Tối ưu thanh cuộn */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-body); }
        ::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

        /* ÉP KIỂU Ô NHẬP LIỆU (INPUTS) */
        select, input[type="text"], input[type="number"], input[type="password"], textarea {
            padding: 8px 14px !important;
            font-size: 13.5px !important;
            height: 38px !important; 
            border-radius: var(--radius-sm) !important;
            border: 1.5px solid var(--border-color) !important;
            color: var(--text-main) !important;
            background-color: var(--bg-body) !important; /* Dùng màu nền chìm */
            box-sizing: border-box;
            transition: all 0.3s ease;
        }
        textarea { height: auto !important; }
        
        select:focus, input:focus, textarea:focus {
            border-color: var(--primary) !important;
            outline: none !important;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15) !important;
            background-color: var(--bg-surface) !important;
        }

        /* NÚT BẤM (BUTTONS) - Vibrant CTA */
        button, .btn-primary, .btn-success, .btn-danger, .btn-kpi {
            padding: 8px 18px !important;
            font-size: 13.5px !important;
            font-weight: 600 !important;
            height: 38px !important;
            border-radius: var(--radius-sm) !important;
            display: inline-flex !important;
            align-items: center !important;
            justify-content: center !important;
            gap: 8px !important;
            transition: all 0.3s ease !important;
            border: none !important;
            cursor: pointer;
            letter-spacing: 0.3px;
        }
        
        .btn-primary { 
            background: var(--cta-gradient) !important; 
            color: white !important; 
            box-shadow: var(--cta-shadow) !important; 
        }
        .btn-primary:hover { 
            transform: translateY(-2px) !important; 
            filter: brightness(1.1);
        }

        /* Nút KPI siêu nhỏ trong các bảng */
        .btn-kpi { background: var(--info) !important; color: white !important; height: 30px !important; padding: 4px 12px !important; font-size: 12px !important; border-radius: 6px !important; box-shadow: none !important;}
        
        /* Bắt buộc các khối trắng (White) cũ chuyển sang dùng biến Surface */
        .card, .filter-card, .chart-container, .process-card, .visual-card, .calc-card, .table-wrapper, .modal-content, .topbar {
            background-color: var(--bg-surface) !important;
            border: 1px solid var(--border-color) !important;
            box-shadow: var(--shadow-card) !important;
            transition: var(--transition-theme);
            border-radius: var(--radius-md);
        }

        /* Ép chữ các thẻ tiêu đề (H1-H6) */
        h1, h2, h3, h4, h5, h6 { color: var(--text-main) !important; transition: color 0.4s ease;}

        /* Bảng dữ liệu: Thích nghi Dark Mode */
        .data-table { width: 100%; border-collapse: separate; border-spacing: 0; }
        .data-table th { 
            background-color: var(--bg-body) !important; 
            color: var(--text-muted) !important; 
            border-bottom: 2px solid var(--border-color) !important;
        }
        .data-table td { 
            color: var(--text-main) !important; 
            border-bottom: 1px solid var(--border-color) !important;
        }
        .data-table tbody tr:hover td { background-color: var(--bg-body) !important; }

        /* Bố cục khung sườn chung */
        .layout { display: flex; height: 100vh; overflow: hidden; background-color: var(--bg-body); transition: background-color 0.4s ease;}
        .main-content { flex: 1; overflow-y: auto; padding: 24px; position: relative; }
        .topbar { padding: 16px 24px; margin-bottom: 24px; display: flex; align-items: center; justify-content: space-between; }
        .topbar h1 { margin: 0; font-size: 20px; font-weight: 700; letter-spacing: -0.5px;}

        @media (max-width: 768px) {
            .main-content { padding: 16px; }
            .topbar { padding: 12px 16px; flex-direction: column; align-items: flex-start; gap: 10px; margin-bottom: 16px;}
            .table-wrapper { overflow-x: auto; width: 100%; -webkit-overflow-scrolling: touch; }
        }
    </style>
</head>
<body>
