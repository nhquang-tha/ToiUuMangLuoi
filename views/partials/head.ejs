<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'VNPT Dashboard' %></title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Roboto', sans-serif; margin: 0; background-color: #f4f7f6; color: #2c3e50; }
        .sidebar { width: 250px; background: #2c3e50; color: white; height: 100vh; padding-top: 20px; overflow-y: auto; }
        .sidebar h2 { text-align: center; margin-bottom: 30px; font-size: 20px; border-bottom: 1px solid #34495e; padding-bottom: 15px;}
        .sidebar ul { list-style: none; padding: 0; margin: 0; }
        .sidebar ul li a { display: block; padding: 12px 20px; color: #ecf0f1; text-decoration: none; transition: 0.3s; font-size: 14px; font-weight: 500;}
        .sidebar ul li a:hover, .sidebar ul li a.active { background: #34495e; border-left: 4px solid #3498db; padding-left: 16px; color: white; }
        .topbar { background: white; padding: 15px 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 20px; border-radius: 8px;}
        .topbar h1 { margin: 0; font-size: 20px; color: #2c3e50; }
        .card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 20px; }
        .btn-primary { background: #3498db; color: white; border: none; padding: 10px 15px; border-radius: 4px; cursor: pointer; font-weight: bold; }
        .btn-primary:hover { background: #2980b9; }
    </style>
</head>
<body>
