<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .top-panel { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; border-top: 4px solid #9b59b6; display: flex; gap: 20px; flex-wrap: wrap; justify-content: space-between;}
    
    .filter-group { flex: 1; min-width: 300px; }
    .filter-group label { display: block; margin-bottom: 8px; font-weight: bold; color: #2c3e50; font-size: 14px;}
    .filter-group select { width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; font-size: 14px; font-weight: bold; color: #8e44ad; cursor: pointer; }

    .export-panel { flex: 1; min-width: 350px; background: #fdf4fdf2; padding: 15px; border-radius: 8px; border: 1px solid #e1cbed;}
    .export-panel h4 { margin: 0 0 10px 0; color: #8e44ad; font-size: 15px; }
    .export-controls { display: flex; gap: 10px; margin-bottom: 10px; }
    .export-controls select { flex: 1; padding: 8px; border: 1px solid #bdc3c7; border-radius: 4px; outline: none; font-size: 13px; }
    .btn-export { background: #27ae60; color: white; border: none; padding: 10px 15px; border-radius: 6px; font-weight: bold; cursor: pointer; width: 100%; font-size: 14px; transition: 0.2s; display: flex; justify-content: center; align-items: center; gap: 8px;}
    .btn-export:hover { background: #219653; transform: translateY(-2px); }

    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    @media (max-width: 1024px) { .charts-grid { grid-template-columns: 1fr; } }

    .chart-box { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); height: 350px; position: relative; }
    .chart-title { font-size: 15px; font-weight: bold; color: #34495e; margin: 0 0 15px 0; text-align: center;}

    .loading-overlay { display: none; position: fixed; inset: 0; background: rgba(255,255,255,0.8); z-index: 1000; justify-content: center; align-items: center; flex-direction: column; }
    .spinner { border: 4px solid #f3f3f3; border-top: 4px solid #9b59b6; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; margin-bottom: 10px;}
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://unpkg.com/xlsx/dist/xlsx.full.min.js"></script>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>📍 Báo Cáo Điểm Quan Tâm (POI Report)</h1>
            <p style="margin: 5px 0 0 0; color: #7f8c8d; font-size: 13px;">Theo dõi và trích xuất dữ liệu tổng hợp các khu vực trọng điểm.</p>
        </header>
        
        <div class="content-body">
            
            <div class="top-panel">
                <!-- Chọn POI để xem biểu đồ -->
                <div class="filter-group">
                    <label>📍 Chọn Điểm POI (Hiển thị biểu đồ):</label>
                    <select id="poiSelect" onchange="fetchAndDrawCharts()">
                        <option value="">Đang tải danh sách POI...</option>
                    </select>
                    <p style="font-size: 12px; color: #7f8c8d; margin-top: 10px;">Dữ liệu hiển thị trên biểu đồ bên dưới là dữ liệu <b>Theo Ngày</b> của POI được chọn.</p>
                </div>

                <!-- Bảng điều khiển Xuất Excel -->
                <div class="export-panel">
                    <h4>📥 Tùy chọn Xuất File Excel</h4>
                    <div class="export-controls">
                        <select id="exportScope">
                            <option value="current">Chỉ POI Đang Xem</option>
                            <option value="all">Toàn bộ danh sách POI</option>
                        </select>
                        <select id="exportTime">
                            <option value="day">Dữ liệu Theo Ngày</option>
                            <option value="week">Gộp Theo Tuần (Week)</option>
                            <option value="month">Gộp Theo Tháng (Month)</option>
                        </select>
                    </div>
                    <button class="btn-export" onclick="executeExcelExport()">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                        Trích Xuất File Excel
                    </button>
                    <p style="font-size: 11px; color: #8e44ad; margin: 8px 0 0 0; font-style: italic;">* Mẹo: Mở file Excel, bôi đen bảng và ấn F11 để vẽ biểu đồ tự động!</p>
                </div>
            </div>

            <!-- Vùng chứa Biểu đồ -->
            <div id="chartArea" style="display: none;">
                <div class="charts-grid">
                    <div class="chart-box">
                        <h4 class="chart-title">Lưu Lượng Traffic 4G & 5G (GB)</h4>
                        <div style="height: calc(100% - 30px);"><canvas id="chartTraffic"></canvas></div>
                    </div>
                    <div class="chart-box">
                        <h4 class="chart-title">Tốc Độ Tải Xuống (Throughput)</h4>
                        <div style="height: calc(100% - 30px);"><canvas id="chartThput"></canvas></div>
                    </div>
                </div>
                <div class="chart-box" style="height: 300px;">
                    <h4 class="chart-title">Chất Lượng Sóng (CQI 4G & 5G)</h4>
                    <div style="height: calc(100% - 30px);"><canvas id="chartCQI"></canvas></div>
                </div>
            </div>

            <!-- Thông báo trống -->
            <div id="emptyState" style="text-align: center; padding: 50px; color: #7f8c8d; font-size: 15px; background: white; border-radius: 12px; margin-top: 20px;">
                Vui lòng chọn 1 POI để xem biểu đồ chi tiết.
            </div>

        </div>
    </main>
</div>

<!-- Loading Overlay -->
<div id="loadingOverlay" class="loading-overlay">
    <div class="spinner"></div>
    <div style="color: #8e44ad; font-weight: bold; font-size: 16px;" id="loadingText">Đang xử lý dữ liệu...</div>
</div>

<script>
    Chart.defaults.font.family = "'Roboto', sans-serif";
    let chartInstances = {};
    let currentPoiRawData = []; // Lưu trữ Data của POI hiện tại để xuất Excel nhánh

    // 1. Tải danh sách POI khi mới vào trang
    window.onload = async () => {
        try {
            const res = await fetch('/api/poi-list');
            const list = await res.json();
            const select = document.getElementById('poiSelect');
            select.innerHTML = '<option value="">-- Chọn Địa Điểm POI --</option>';
            list.forEach(poi => {
                select.insertAdjacentHTML('beforeend', `<option value="${poi}">${poi}</option>`);
            });

            // Tự động nhận diện POI từ URL (Nếu ấn từ trang Traffic Down qua)
            const urlParams = new URLSearchParams(window.location.search);
            const poiParam = urlParams.get('poi');
            if (poiParam) {
                setTimeout(() => {
                    select.value = poiParam;
                    if(select.value === poiParam) fetchAndDrawCharts();
                }, 200);
            }
        } catch (e) {
            document.getElementById('poiSelect').innerHTML = '<option value="">Lỗi tải danh sách POI</option>';
        }
    };

    // 2. Tiện ích gộp nhóm mảng Object theo Ngày, Tuần, Tháng
    function getWeekNumber(dateStr) {
        let parts = dateStr.split('/');
        if (parts.length !== 3) return dateStr;
        let d = new Date(parts[2], parts[1] - 1, parts[0]);
        let startDate = new Date(d.getFullYear(), 0, 1);
        let days = Math.floor((d - startDate) / (24 * 60 * 60 * 1000));
        let weekNumber = Math.ceil((d.getDay() + 1 + days) / 7);
        return `Tuần ${weekNumber} (${parts[2]})`;
    }

    function getMonthName(dateStr) {
        let parts = dateStr.split('/');
        if (parts.length !== 3) return dateStr;
        return `Tháng ${parts[1]}/${parts[2]}`;
    }

    function sortDates(arr) {
        return arr.sort((a, b) => {
            let pA = a.Thoi_gian.split('/'); let pB = b.Thoi_gian.split('/');
            if(pA.length === 3 && pB.length === 3) {
                return new Date(`${pA[2]}-${pA[1]}-${pA[0]}`) - new Date(`${pB[2]}-${pB[1]}-${pB[0]}`);
            }
            return a.Thoi_gian.localeCompare(b.Thoi_gian);
        });
    }

    // Hàm Group By (Gom nhóm và tính Trung bình / Tổng)
    function aggregateData(rawData, timeType) {
        let grouped = {};
        
        rawData.forEach(row => {
            if (!row.Thoi_gian) return;
            
            let timeKey = row.Thoi_gian;
            if (timeType === 'week') timeKey = getWeekNumber(row.Thoi_gian);
            if (timeType === 'month') timeKey = getMonthName(row.Thoi_gian);
            
            let compositeKey = `${row.POI}_${timeKey}`;

            if (!grouped[compositeKey]) {
                grouped[compositeKey] = {
                    POI: row.POI, Thoi_gian: timeKey, sortDate: row.Thoi_gian,
                    Traf_4G: 0, Thput_4G: 0, CQI_4G: 0, count_4G: 0,
                    Traf_5G: 0, Thput_5G: 0, CQI_5G: 0, count_5G: 0
                };
            }

            let g = grouped[compositeKey];
            
            if (parseFloat(row.Traf_4G) > 0 || parseFloat(row.CQI_4G) > 0) {
                g.Traf_4G += parseFloat(row.Traf_4G) || 0;
                g.Thput_4G += parseFloat(row.Thput_4G) || 0;
                g.CQI_4G += parseFloat(row.CQI_4G) || 0;
                g.count_4G++;
            }
            
            if (parseFloat(row.Traf_5G) > 0 || parseFloat(row.CQI_5G) > 0) {
                g.Traf_5G += parseFloat(row.Traf_5G) || 0;
                g.Thput_5G += parseFloat(row.Thput_5G) || 0;
                g.CQI_5G += parseFloat(row.CQI_5G) || 0;
                g.count_5G++;
            }
        });

        // Tính trung bình
        let result = Object.values(grouped).map(g => {
            if (g.count_4G > 0) {
                g.Thput_4G = g.Thput_4G / g.count_4G;
                g.CQI_4G = g.CQI_4G / g.count_4G;
            }
            if (g.count_5G > 0) {
                g.Thput_5G = g.Thput_5G / g.count_5G;
                g.CQI_5G = g.CQI_5G / g.count_5G;
            }
            return g;
        });

        // Sắp xếp
        result.sort((a, b) => {
            if (a.POI !== b.POI) return a.POI.localeCompare(b.POI);
            let pA = a.sortDate.split('/'); let pB = b.sortDate.split('/');
            if(pA.length === 3 && pB.length === 3) return new Date(`${pA[2]}-${pA[1]}-${pA[0]}`) - new Date(`${pB[2]}-${pB[1]}-${pB[0]}`);
            return a.sortDate.localeCompare(b.sortDate);
        });

        return result;
    }

    // 3. Lấy dữ liệu và Vẽ biểu đồ (Chỉ POI hiện tại, luôn theo Ngày)
    async function fetchAndDrawCharts() {
        const poi = document.getElementById('poiSelect').value;
        if (!poi) {
            document.getElementById('chartArea').style.display = 'none';
            document.getElementById('emptyState').style.display = 'block';
            return;
        }

        document.getElementById('loadingText').innerText = "Đang tải biểu đồ...";
        document.getElementById('loadingOverlay').style.display = 'flex';
        document.getElementById('emptyState').style.display = 'none';

        try {
            // Lấy data 4G
            const res4 = await fetch(`/api/kpi-data?network=4g&type=poi&value=${encodeURIComponent(poi)}`);
            const data4 = await res4.json();
            
            // Lấy data 5G
            const res5 = await fetch(`/api/kpi-data?network=5g&type=poi&value=${encodeURIComponent(poi)}`);
            const data5 = await res5.json();

            // Khớp nối cấu trúc cho biểu đồ
            let mergedMap = {};
            data4.forEach(r => {
                if(!mergedMap[r.Thoi_gian]) mergedMap[r.Thoi_gian] = { POI: poi, Thoi_gian: r.Thoi_gian, Traf_4G:0, Thput_4G:0, CQI_4G:0, Traf_5G:0, Thput_5G:0, CQI_5G:0 };
                mergedMap[r.Thoi_gian].Traf_4G += parseFloat(r.Total_Data_Traffic_Volume_GB) || 0;
            });

            // Re-fetch chuẩn bị cho Export Branch 1
            const exportRes = await fetch('/api/export-all-poi');
            const allPoiData = await exportRes.json();
            
            // Lọc riêng Data của POI này để lưu Cache
            currentPoiRawData = allPoiData.filter(r => r.POI === poi);
            let sortedData = sortDates(currentPoiRawData);

            document.getElementById('loadingOverlay').style.display = 'none';
            document.getElementById('chartArea').style.display = 'block';

            const labels = sortedData.map(d => d.Thoi_gian);

            drawChart('chartTraffic', labels, [
                { label: 'Traffic 4G (GB)', data: sortedData.map(d => d.Traf_4G), color: '#3498db', type: 'bar' },
                { label: 'Traffic 5G (GB)', data: sortedData.map(d => d.Traf_5G), color: '#2980b9', type: 'bar' }
            ]);

            drawChart('chartThput', labels, [
                { label: 'Throughput 4G (Kbps)', data: sortedData.map(d => d.Thput_4G), color: '#e67e22', type: 'line' },
                { label: 'Throughput 5G (Mbps)', data: sortedData.map(d => d.Thput_5G), color: '#d35400', type: 'line' }
            ]);

            drawChart('chartCQI', labels, [
                { label: 'CQI 4G (%)', data: sortedData.map(d => d.CQI_4G), color: '#2ecc71', type: 'line' },
                { label: 'CQI 5G (%)', data: sortedData.map(d => d.CQI_5G), color: '#27ae60', type: 'line' }
            ]);

        } catch (e) {
            document.getElementById('loadingOverlay').style.display = 'none';
            alert("Lỗi tải dữ liệu biểu đồ POI.");
        }
    }

    function drawChart(canvasId, labels, datasetsConfig) {
        const ctx = document.getElementById(canvasId).getContext('2d');
        if (chartInstances[canvasId]) chartInstances[canvasId].destroy();

        const datasets = datasetsConfig.map(c => ({
            label: c.label,
            data: c.data,
            backgroundColor: c.type === 'bar' ? c.color : 'transparent',
            borderColor: c.color,
            borderWidth: 2,
            type: c.type,
            tension: 0.3,
            pointRadius: c.type === 'line' ? 3 : 0,
            fill: false
        }));

        chartInstances[canvasId] = new Chart(ctx, {
            type: 'bar', 
            data: { labels: labels, datasets: datasets },
            options: {
                responsive: true, maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { position: 'bottom', labels: { boxWidth: 12 } } },
                scales: { x: { grid: { display: false } }, y: { beginAtZero: true, grid: { borderDash: [5, 5] } } }
            }
        });
    }

    // 4. THUẬT TOÁN XUẤT EXCEL SIÊU TỐC
    async function executeExcelExport() {
        if (typeof XLSX === 'undefined') {
            alert('Thư viện Excel chưa tải xong, vui lòng đợi...'); return;
        }

        const scope = document.getElementById('exportScope').value;
        const timeType = document.getElementById('exportTime').value;
        
        let targetData = [];
        
        document.getElementById('loadingText').innerText = "Đang tổng hợp dữ liệu Excel...";
        document.getElementById('loadingOverlay').style.display = 'flex';

        try {
            if (scope === 'current') {
                if (currentPoiRawData.length === 0) {
                    document.getElementById('loadingOverlay').style.display = 'none';
                    return alert("Vui lòng chọn 1 POI trước khi xuất file!");
                }
                targetData = currentPoiRawData;
            } else {
                // Tải toàn bộ Data của mọi POI
                const res = await fetch('/api/export-all-poi');
                targetData = await res.json();
            }

            // Gộp dữ liệu theo Tuần / Tháng nếu người dùng yêu cầu
            let finalData = aggregateData(targetData, timeType);

            // Chuẩn hóa tên cột để xuất Excel đẹp
            let excelRows = finalData.map(row => ({
                "Khu vực (POI)": row.POI,
                "Thời gian": row.Thoi_gian,
                "Traffic 4G (GB)": parseFloat(row.Traf_4G || 0).toFixed(2),
                "Throughput 4G (Kbps)": parseFloat(row.Thput_4G || 0).toFixed(2),
                "CQI 4G (%)": parseFloat(row.CQI_4G || 0).toFixed(2),
                "Traffic 5G (GB)": parseFloat(row.Traf_5G || 0).toFixed(2),
                "Throughput 5G (Mbps)": parseFloat(row.Thput_5G || 0).toFixed(2),
                "CQI 5G (%)": parseFloat(row.CQI_5G || 0).toFixed(2)
            }));

            let ws = XLSX.utils.json_to_sheet(excelRows);
            let wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "POI_Data");

            let scopeName = scope === 'current' ? document.getElementById('poiSelect').value : "ALL_POI";
            let safeName = scopeName.replace(/[\\\/\:\*\?\"\<\>\|]/g, '_').replace(/\s+/g, '_');
            let fileName = `Bao_Cao_${safeName}_Theo_${timeType.toUpperCase()}.xlsx`;
            
            XLSX.writeFile(wb, fileName);
            document.getElementById('loadingOverlay').style.display = 'none';

        } catch (e) {
            console.error(e);
            document.getElementById('loadingOverlay').style.display = 'none';
            alert("Đã xảy ra lỗi khi tạo file Excel!");
        }
    }
</script>
</body>
</html>
