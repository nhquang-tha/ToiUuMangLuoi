<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; border-top: 4px solid #f39c12;}
    
    .table-wrapper { width: 100%; overflow-x: auto; background: #fff; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: none; animation: fadeIn 0.5s ease;}
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; white-space: nowrap; }
    .data-table th, .data-table td { padding: 12px 15px; border-bottom: 1px solid #ecf0f1; text-align: left; }
    .data-table th { background-color: #f8f9fa; color: #2c3e50; font-weight: bold; position: sticky; top: 0; z-index: 10;}
    .data-table tbody tr:hover { background-color: #fcf3cf; }
    
    .bad-cell { color: #d35400; font-weight: bold; }
    .violation-badge { background: #fef5e7; color: #d35400; padding: 4px 8px; border-radius: 4px; border: 1px solid #fad7a1; font-size: 11px;}

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>Cảnh Báo Nghẽn Mạng: Congestion 3G</h1>
        </header>
        
        <div class="content-body">
            
            <!-- BỘ LỌC DỮ LIỆU -->
            <div class="filter-card">
                <div style="flex: 1; min-width: 250px;">
                    <label style="display:block; margin-bottom:8px; font-weight:bold; color:#2c3e50;">Khoảng thời gian liên tiếp:</label>
                    <select id="daysSelect" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; cursor: pointer; font-size: 14px; border-left: 4px solid #f39c12;">
                        <option value="3" selected>Lỗi liên tiếp 3 Ngày</option>
                        <option value="5">Lỗi liên tiếp 5 Ngày</option>
                        <option value="7">Lỗi liên tiếp 7 Ngày</option>
                    </select>
                </div>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <button onclick="fetchCongestionCells()" class="btn-primary" style="background: #f39c12; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 45px; font-size: 14px; transition: 0.2s;">
                        🔍 Bắt Đầu Lọc Cell Nghẽn
                    </button>
                    <button onclick="exportToExcel()" id="btnExport" class="btn-success" style="background: #27ae60; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 45px; font-size: 14px; display: none;">
                        📥 Xuất File Excel
                    </button>
                </div>
            </div>

            <!-- HƯỚNG DẪN / THÔNG BÁO -->
            <div id="initMsg" style="background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 20px; font-size: 14px; color: #34495e;">
                <strong>💡 Tiêu chí Congestion 3G:</strong><br>
                Thỏa mãn ít nhất 1 trong 2 điều kiện sau liên tục qua các ngày:<br>
                1. (CS_CONGES > 2%) VÀ (CS_SO_ATT > 100)<br>
                2. (PS_CONGES > 2%) VÀ (PS_SO_ATT > 500)
            </div>

            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #f39c12; font-size: 16px; font-weight: bold; background: white; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 15px;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang phân tích nghẽn mạng 3G...
            </div>
            
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px;"></div>

            <!-- BẢNG KẾT QUẢ -->
            <div class="table-wrapper" id="tableContainer">
                <div style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #d35400;">
                    Tổng số Cell nghẽn mạng 3G: <span id="totalCount">0</span> Cell.
                    <span style="font-size: 12px; font-weight: normal; color: #7f8c8d; margin-left: 10px;">(Dữ liệu chi tiết hiển thị của ngày mới nhất)</span>
                </div>
                <table class="data-table" id="congestionTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tên Cell 3G</th>
                            <th>Ngày Mới Nhất</th>
                            <th>CS CONGES (%)</th>
                            <th>CS ATT</th>
                            <th>PS CONGES (%)</th>
                            <th>PS ATT</th>
                            <th>Lý do Nghẽn (Ngày mới nhất)</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                    </tbody>
                </table>
            </div>

        </div>
    </main>
</div>

<!-- TÍCH HỢP THƯ VIỆN EXCEL -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const xlsxScript = document.createElement('script');
        xlsxScript.src = atob('aHR0cHM6Ly91bnBrZy5jb20veGxzeC9kaXN0L3hsc3guZnVsbC5taW4uanM=');
        document.head.appendChild(xlsxScript);
    });

    async function fetchCongestionCells() {
        const days = document.getElementById('daysSelect').value;
        
        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('loadingMsg').style.display = 'block';
        document.getElementById('errorMsg').style.display = 'none';
        document.getElementById('tableContainer').style.display = 'none';
        document.getElementById('btnExport').style.display = 'none';
        document.getElementById('tableBody').innerHTML = '';

        try {
            const response = await fetch(`/api/congestion-3g-data?days=${days}`);
            if (!response.ok) throw new Error('Lỗi máy chủ');
            const data = await response.json();
            
            document.getElementById('loadingMsg').style.display = 'none';

            if (data.length === 0) {
                document.getElementById('errorMsg').innerText = `Tuyệt vời! Không có Cell 3G nào bị nghẽn mạng liên tục trong ${days} ngày.`;
                document.getElementById('errorMsg').className = 'alert alert-success';
                document.getElementById('errorMsg').style.color = '#27ae60';
                document.getElementById('errorMsg').style.backgroundColor = '#e8f8f5';
                document.getElementById('errorMsg').style.borderColor = '#bce8e0';
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            document.getElementById('totalCount').innerText = data.length;
            const tbody = document.getElementById('tableBody');
            
            data.forEach((row, index) => {
                const tr = document.createElement('tr');
                
                const csCong = parseFloat(row.CSCONGES);
                const csAtt = parseFloat(row.CS_SO_ATT);
                const psCong = parseFloat(row.PSCONGES);
                const psAtt = parseFloat(row.PS_SO_ATT);

                const isCsCongested = (!isNaN(csCong) && csCong > 2) && (!isNaN(csAtt) && csAtt > 100);
                const isPsCongested = (!isNaN(psCong) && psCong > 2) && (!isNaN(psAtt) && psAtt > 500);

                const csStyle = isCsCongested ? 'bad-cell' : '';
                const psStyle = isPsCongested ? 'bad-cell' : '';

                tr.innerHTML = `
                    <td>${index + 1}</td>
                    <td style="font-weight: bold; color: #2980b9;">${row.Cell_name}</td>
                    <td>${row.Latest_Date}</td>
                    <td class="${csStyle}">${row.CSCONGES}</td>
                    <td class="${csStyle}">${row.CS_SO_ATT}</td>
                    <td class="${psStyle}">${row.PSCONGES}</td>
                    <td class="${psStyle}">${row.PS_SO_ATT}</td>
                    <td><span class="violation-badge">${row.Violations}</span></td>
                `;
                tbody.appendChild(tr);
            });

            document.getElementById('tableContainer').style.display = 'block';
            document.getElementById('btnExport').style.display = 'block';

        } catch (error) {
            console.error(error);
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = 'Lỗi truy xuất dữ liệu từ Database.';
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    function exportToExcel() {
        if (typeof XLSX === 'undefined') {
            alert('Thư viện Excel chưa tải xong, vui lòng đợi...');
            return;
        }
        
        let table = document.getElementById('congestionTable');
        let wb = XLSX.utils.table_to_book(table, {sheet: "Congestion_3G"});
        let days = document.getElementById('daysSelect').value;
        let fileName = `Bao_Cao_Congestion_3G_Lien_Tiep_${days}_Ngay.xlsx`;
        
        XLSX.writeFile(wb, fileName);
    }
</script>
</body>
</html>
