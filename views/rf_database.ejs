<!-- Bọc nút Thêm Mới góc trên cùng -->
<% if(typeof currentUser !== 'undefined' && currentUser.role === 'admin') { %>
    <a href="/rf-database/add/<%= currentNetwork %>" class="btn-primary" style="margin-left: 15px; background: #27ae60; border: none; text-decoration: none;">+ Thêm Trạm Mới</a>
<% } %>

<!-- ------------------------------------------------ -->
<!-- Trong vòng lặp <table ...> hiển thị dữ liệu -->
<!-- ------------------------------------------------ -->

<!-- Cột Tiêu đề thao tác -->
<% if(typeof currentUser !== 'undefined' && currentUser.role === 'admin') { %>
    <th style="width: 120px; text-align: center; position: sticky; right: 0; background-color: #f4f6f8; z-index: 2;">Thao Tác</th>
<% } %>

<!-- Các nút Sửa/Xóa của từng hàng -->
<% if(typeof currentUser !== 'undefined' && currentUser.role === 'admin') { %>
    <td style="text-align: center; position: sticky; right: 0; background-color: #fff; z-index: 1; border-left: 2px solid #ddd;">
        <div style="display: flex; gap: 5px; justify-content: center;">
            <a href="/rf-database/edit/<%= currentNetwork %>/<%= row.id %>" class="btn-sm btn-primary" style="background: #f39c12; border: none; text-decoration: none;">Sửa</a>
            <form action="/rf-database/delete/<%= currentNetwork %>/<%= row.id %>" method="POST" style="margin:0;" onsubmit="return confirm('Chắc chắn xóa trạm này?');">
                <button type="submit" class="btn-sm btn-danger" style="background: #c0392b; border: none;">Xóa</button>
            </form>
        </div>
    </td>
<% } %>
