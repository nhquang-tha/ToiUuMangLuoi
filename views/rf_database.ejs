<%- include('partials/head') %>

<%
    // SỬ DỤNG LOCALS ĐỂ CHỐNG LỖI CRASH (500 INTERNAL SERVER ERROR) TỐI ĐA
    const currentNet = locals.currentNetwork || locals.network || '3g';
    const rfData = locals.rfData || locals.data || locals.rows || [];
    const isAdmin = locals.currentUser && locals.currentUser.role === 'admin';
    
    // Các biến phục vụ phân trang & tìm kiếm
    const searchVal = locals.searchQuery || '';
    const currentPage = locals.currentPage || 1;
    const totalPages = locals.totalPages || 1;
    const totalRecords = locals.totalRecords || 0;
%>

<style>
    /* BỔ SUNG CSS BỐ CỤC ĐỂ ĐẢM BẢO HIỂN THỊ ĐÚNG SIDEBAR & CONTENT */
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; }

    .table-wrapper { width: 100%; overflow-x: auto; background: #fff; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; white-space: nowrap; }
    .data-table th, .data-table td { padding: 10px 15px; border-bottom: 1px solid #ecf0f1; text-align: left; }
    .data-table th { background-color: #f8f9fa; color: #2c3e50; font-weight: bold; position: sticky; top: 0; z-index: 10;}
    .data-table tbody tr:hover { background-color: #f4f6f8; }
    
    /* Cột thao tác dính chặt lề phải */
    .sticky-col { position: sticky; right: 0; background-color: #fff; border-left: 2px solid #ecf0f1; text-align: center !important;}
    .data-table th.sticky-col { background-color: #f8f9fa; z-index: 11; }

    .btn-success { background: #27ae60; color: white; border: none; padding: 10px 15px; border-radius: 4px; cursor: pointer; font-weight: bold; }
    .btn-success:hover { background: #219653; }
    
    /* Nút phân trang */
    .page-btn { padding: 6px 12px; background: #bdc3c7; color: white; text-decoration: none; border-radius: 3px; font-weight: bold; transition: 0.2s;}
    .page-btn:hover { background: #95a5a6; }
    .page-btn.active { background: #3498db; }
</style>

<div class="layout">
    <%- include('partials/sidebar') %>
    <main class="main-content">
        <header class="topbar">
            <h1>Quản Lý Cơ Sở Dữ Liệu Trạm (RF Database)</h1>
        </header>
        
        <div class="content-body">
            
            <!-- THANH CÔNG CỤ TÌM KIẾM & BỘ LỌC -->
            <div class="card" style="margin-bottom: 20px; display: flex; flex-direction: column; gap: 15px;">
                
                <!-- Hàng 1: Tiêu đề và Thêm/Xuất -->
                <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                    <h3 style="margin: 0; color: #2c3e50;">Dữ liệu: <%= currentNet.toUpperCase() %></h3>
                    <div style="display: flex; gap: 10px;">
                        <!-- Nút Xuất Excel (Hiển thị cho tất cả mọi người) -->
                        <% if (rfData.length > 0) { %>
                            <button onclick="exportToExcel()" class="btn-success" id="btnExport">📥 Xuất Excel (Toàn bộ)</button>
                        <% } %>

                        <!-- Nút Thêm mới chỉ hiện cho Admin -->
                        <% if (isAdmin) { %>
                            <a href="/rf-database/add/<%= currentNet %>" class="btn-primary" style="background: #2980b9; border: none; text-decoration: none; padding: 10px 15px;">➕ Thêm Trạm Mới</a>
                        <% } %>
                    </div>
                </div>

                <!-- Hàng 2: Form Tìm kiếm & Lọc mạng -->
                <form action="/rf-database" method="GET" style="margin: 0; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; background: #f8f9fa; padding: 10px; border-radius: 6px; border: 1px solid #ecf0f1;">
                    
                    <label style="font-weight: bold; color: #2c3e50;">Chọn Mạng:</label>
                    <select name="network" id="networkSelect" onchange="this.form.submit()" style="padding: 8px; border-radius: 4px; border: 1px solid #bdc3c7; outline: none; cursor: pointer;">
                        <option value="3g" <%= currentNet === '3g' ? 'selected' : '' %>>Trạm 3G</option>
                        <option value="4g" <%= currentNet === '4g' ? 'selected' : '' %>>Trạm 4G</option>
                        <option value="5g" <%= currentNet === '5g' ? 'selected' : '' %>>Trạm 5G</option>
                    </select>
                    
                    <span style="color: #ccc;">|</span>

                    <input type="text" name="search" value="<%= searchVal %>" placeholder="Nhập Cell Code hoặc Tên Cell..." style="padding: 8px; border: 1px solid #bdc3c7; border-radius: 4px; flex: 1; min-width: 250px;">
                    <button type="submit" class="btn-primary" style="padding: 8px 15px; border: none; background: #34495e; color: white; border-radius: 4px; cursor: pointer;">🔍 Tìm Kiếm</button>
                    
                    <% if (searchVal) { %>
                        <a href="/rf-database?network=<%= currentNet %>" style="color: #e74c3c; text-decoration: none; font-size: 13px; font-weight: bold; padding: 8px;">✖ Xóa lọc</a>
                    <% } %>

                </form>
            </div>

            <!-- BẢNG DỮ LIỆU -->
            <div class="table-wrapper">
                <table class="data-table" id="rfTable">
                    <% if (rfData.length > 0) { %>
                        <thead>
                            <tr>
                                <!-- Tự động sinh tên cột dựa trên dữ liệu thật trả về từ DB -->
                                <% Object.keys(rfData[0]).forEach(key => { %>
                                    <th><%= key %></th>
                                <% }) %>
                                
                                <% if (isAdmin) { %>
                                    <th class="sticky-col">Thao Tác</th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% rfData.forEach(row => { %>
                                <tr>
                                    <% Object.values(row).forEach(val => { %>
                                        <td><%= val !== null && val !== undefined ? val : '' %></td>
                                    <% }) %>
                                    
                                    <% if (isAdmin) { %>
                                        <td class="sticky-col">
                                            <div style="display: flex; gap: 5px; justify-content: center;">
                                                <a href="/rf-database/edit/<%= currentNet %>/<%= row.id || row.ID %>" class="btn-primary" style="background: #f39c12; border: none; padding: 5px 10px; font-size: 12px; text-decoration: none;">Sửa</a>
                                                <form action="/rf-database/delete/<%= currentNet %>/<%= row.id || row.ID %>" method="POST" style="margin:0;" onsubmit="return confirm('Chắc chắn xóa trạm này?');">
                                                    <button type="submit" class="btn-danger" style="background: #c0392b; border: none; padding: 5px 10px; font-size: 12px;">Xóa</button>
                                                </form>
                                            </div>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    <% } else { %>
                        <tbody>
                            <tr>
                                <td style="text-align: center; padding: 30px; color: #7f8c8d;">
                                    Không tìm thấy dữ liệu trạm phù hợp. Vui lòng kiểm tra lại từ khóa hoặc Import dữ liệu mới.
                                </td>
                            </tr>
                        </tbody>
                    <% } %>
                </table>
            </div>

            <!-- THANH ĐIỀU HƯỚNG PHÂN TRANG (PAGINATION) -->
            <% if (totalPages > 0) { %>
                <div style="margin-top: 20px; display: flex; justify-content: center; align-items: center; gap: 10px;">
                    <!-- Nút Trang trước -->
                    <% if (currentPage > 1) { %>
                        <a href="/rf-database?network=<%= currentNet %>&search=<%= searchVal %>&page=<%= currentPage - 1 %>" class="page-btn">&laquo; Trang trước</a>
                    <% } %>
                    
                    <!-- Thông tin tổng quan -->
                    <span style="padding: 5px 15px; background: #fff; border: 1px solid #bdc3c7; border-radius: 4px; color: #2c3e50; font-weight: bold; font-size: 13px;">
                        Trang <%= currentPage %> / <%= totalPages %> (Tổng: <%= totalRecords %> trạm)
                    </span>

                    <!-- Nút Trang sau -->
                    <% if (currentPage < totalPages) { %>
                        <a href="/rf-database?network=<%= currentNet %>&search=<%= searchVal %>&page=<%= currentPage + 1 %>" class="page-btn active">Trang kế tiếp &raquo;</a>
                    <% } %>
                </div>
            <% } %>

        </div>
    </main>
</div>

<!-- TÍCH HỢP THƯ VIỆN XUẤT EXCEL VÀ JAVASCRIPT -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Tải thư viện SheetJS thông qua Base64 để chống lỗi định dạng
        const xlsxScript = document.createElement('script');
        xlsxScript.src = atob('aHR0cHM6Ly91bnBrZy5jb20veGxzeC9kaXN0L3hsc3guZnVsbC5taW4uanM=');
        document.head.appendChild(xlsxScript);
    });

    async function exportToExcel() {
        if (typeof XLSX === 'undefined') {
            alert('Thư viện Excel chưa tải xong, vui lòng đợi vài giây và thử lại.');
            return;
        }

        // Lấy thông số Mạng và Từ khóa tìm kiếm hiện tại
        let networkName = document.getElementById('networkSelect').value;
        const searchParams = new URLSearchParams(window.location.search);
        const search = searchParams.get('search') || '';

        // Hiệu ứng Loading cho nút bấm
        const btn = document.getElementById('btnExport');
        const originalText = btn.innerHTML;
        btn.innerHTML = '⏳ Đang trích xuất dữ liệu...';
        btn.disabled = true;
        btn.style.opacity = '0.7';

        try {
            // Gọi API Backend lấy TOÀN BỘ dữ liệu thay vì HTML DOM
            const response = await fetch(`/rf-database/export?network=${networkName}&search=${encodeURIComponent(search)}`);
            if (!response.ok) throw new Error('Lỗi mạng');
            const data = await response.json();

            if (data.length === 0) {
                alert('Không có dữ liệu để xuất!');
                return;
            }

            // Biến đổi JSON thành File Excel
            let worksheet = XLSX.utils.json_to_sheet(data);
            let workbook = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(workbook, worksheet, "RF_Data");
            
            let fileName = `RF_Data_${networkName.toUpperCase()}_ToanBo.xlsx`;
            XLSX.writeFile(workbook, fileName);
            
        } catch (error) {
            console.error("Lỗi xuất file:", error);
            alert('Có lỗi xảy ra khi tải dữ liệu Excel từ máy chủ!');
        } finally {
            // Trả lại trạng thái gốc cho nút bấm
            btn.innerHTML = originalText;
            btn.disabled = false;
            btn.style.opacity = '1';
        }
    }
</script>
</body>
</html>
