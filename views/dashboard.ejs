<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>

<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body { font-family: 'Roboto', sans-serif; background-color: #f4f7f6; margin: 0; }
    .layout { display: flex; height: 100vh; overflow: hidden; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; }
    
    .dashboard-header { margin-bottom: 25px; border-bottom: 2px solid #e0e6ed; padding-bottom: 10px; }
    .dashboard-header h1 { margin: 0; color: #2c3e50; font-size: 24px; font-weight: 700; }
    .dashboard-header p { margin: 5px 0 0 0; color: #7f8c8d; font-size: 14px; }

    .network-section { margin-bottom: 40px; background: #fff; padding: 20px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); border-top: 4px solid #3498db; }
    .network-section.n5g { border-top-color: #9b59b6; }
    .network-title { font-size: 18px; color: #34495e; margin-top: 0; margin-bottom: 20px; font-weight: 700; display: flex; align-items: center; gap: 10px;}
    .network-title span { padding: 4px 10px; background: #ecf0f1; border-radius: 20px; font-size: 12px; color: #7f8c8d; font-weight: normal; }

    /* Lưới hiển thị 4 biểu đồ cho mỗi mạng */
    .charts-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    @media (max-width: 1300px) { .charts-grid { grid-template-columns: 1fr; } }

    /* HIỆU ỨNG BOX VÀ CLICK TƯƠNG TÁC */
    .chart-box { 
        height: 280px; position: relative; border: 1px solid #edf2f7; border-radius: 8px; padding: 15px; 
        background: #fff; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .chart-box:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.15); }
    .chart-box:hover .zoom-hint { color: #3498db; font-weight: bold; }
    
    .chart-title { position: absolute; top: 15px; left: 15px; font-size: 14px; font-weight: bold; color: #34495e; z-index: 2; margin: 0;}
    .zoom-hint { position: absolute; top: 15px; right: 20px; font-size: 12px; color: #bdc3c7; transition: 0.3s; pointer-events: none; z-index: 5;}
    
    .loading-overlay { position: absolute; inset: 0; background: rgba(255,255,255,0.8); display: flex; justify-content: center; align-items: center; font-weight: bold; color: #2980b9; z-index: 10; border-radius: 12px; }
    .empty-state { padding: 40px; text-align: center; color: #95a5a6; font-size: 15px; background: white; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    /* CSS MODAL PHÓNG TO */
    .modal-overlay {
        display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.7);
        align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;
    }
    .modal-overlay.show { display: flex; opacity: 1; }
    .modal-content {
        background: white; padding: 25px; border-radius: 12px; width: 90%; max-width: 1300px; height: 85vh; position: relative;
        transform: scale(0.8); transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94); box-shadow: 0 10px 30px rgba(0,0,0,0.3); display: flex; flex-direction: column;
    }
    .modal-overlay.show .modal-content { transform: scale(1); }
    .close-btn { position: absolute; top: 15px; right: 25px; font-size: 32px; font-weight: bold; color: #7f8c8d; cursor: pointer; transition: 0.2s; z-index: 10; }
    .close-btn:hover { color: #e74c3c; }
    .modal-body { flex: 1; position: relative; width: 100%; height: 100%; }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        
        <div class="dashboard-header">
            <h1>Tổng Quan Hệ Thống (Network Dashboard)</h1>
            <p>Dữ liệu tự động tổng hợp từ tất cả các trạm dựa trên phân tích KPI mới nhất.</p>
        </div>

        <div id="loadingIndicator" class="loading-overlay">
            <span style="display: inline-block; animation: spin 1s linear infinite; margin-right: 10px; font-size: 20px;">⏳</span> Đang đồng bộ và vẽ biểu đồ...
        </div>

        <div id="dashboardContent" style="display: none;">
            
            <!-- KHU VỰC 4G (4 Biểu đồ) -->
            <div class="network-section">
                <h3 class="network-title">📡 Hiệu Năng Toàn Mạng 4G LTE <span>Tự động cập nhật</span></h3>
                <div class="charts-grid">
                    <div class="chart-box" onclick="openModal('chart4g_Traffic')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <h4 class="chart-title">Tổng Traffic (GB)</h4>
                        <canvas id="chart4g_Traffic"></canvas>
                    </div>
                    <div class="chart-box" onclick="openModal('chart4g_Thput')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <h4 class="chart-title">Trung bình Throughput DL (Kbps)</h4>
                        <canvas id="chart4g_Thput"></canvas>
                    </div>
                    <div class="chart-box" onclick="openModal('chart4g_PRB')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <h4 class="chart-title">Trung bình PRB DL (%)</h4>
                        <canvas id="chart4g_PRB"></canvas>
                    </div>
                    <div class="chart-box" onclick="openModal('chart4g_CQI')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <h4 class="chart-title">Trung bình CQI (%)</h4>
                        <canvas id="chart4g_CQI"></canvas>
                    </div>
                </div>
            </div>

            <!-- KHU VỰC 5G (3 Biểu đồ - Đã bỏ PRB 5G) -->
            <div class="network-section n5g">
                <h3 class="network-title">🚀 Hiệu Năng Toàn Mạng 5G NR <span>Tự động cập nhật</span></h3>
                <div class="charts-grid">
                    <div class="chart-box" onclick="openModal('chart5g_Traffic')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <h4 class="chart-title">Tổng Traffic (GB)</h4>
                        <canvas id="chart5g_Traffic"></canvas>
                    </div>
                    <div class="chart-box" onclick="openModal('chart5g_Thput')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <h4 class="chart-title">Trung bình Throughput DL (Mbps)</h4>
                        <canvas id="chart5g_Thput"></canvas>
                    </div>
                    <div class="chart-box" onclick="openModal('chart5g_CQI')">
                        <span class="zoom-hint">🔍 Click để phóng to</span>
                        <h4 class="chart-title">Trung bình CQI (%)</h4>
                        <canvas id="chart5g_CQI"></canvas>
                    </div>
                </div>
            </div>

        </div>

        <div id="emptyIndicator" class="empty-state" style="display: none;">
            <p style="font-size: 40px; margin-bottom: 10px;">📉</p>
            Chưa có dữ liệu tổng hợp. Vui lòng chuyển đến tab <b>Import Data</b> và tải lên file Báo cáo KPI 4G/5G để hệ thống kích hoạt biểu đồ.
        </div>

    </main>
</div>

<!-- MODAL POPUP PHÓNG TO ĐỒ THỊ -->
<div id="chartModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <div class="modal-body">
            <canvas id="modalCanvas"></canvas>
        </div>
    </div>
</div>

<script>
    // Cấu hình font chữ chung cho Chart.js
    Chart.defaults.font.family = "'Roboto', sans-serif";
    Chart.defaults.color = '#7f8c8d';

    // Lưu trữ thông tin đồ thị để vẽ lại trên modal popup
    window.chartDataStore = {};
    let modalChartInstance = null;

    // Hàm chuyển đổi chuỗi ngày DD/MM/YYYY thành số để Sắp xếp
    function parseDateForSort(dateStr) {
        if (!dateStr) return 0;
        let parts = dateStr.split('/');
        if (parts.length === 3) {
            return new Date(`${parts[2]}-${parts[1]}-${parts[0]}`).getTime();
        }
        return 0;
    }

    // Hex to RGBA Converter dùng cho Gradient
    function hexToRgba(hex, alpha) {
        let r = parseInt(hex.slice(1, 3), 16);
        let g = parseInt(hex.slice(3, 5), 16);
        let b = parseInt(hex.slice(5, 7), 16);
        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    // Hàm vẽ Biểu đồ Line động chuẩn mực
    function drawLineChart(canvasId, labels, data, colorHex, labelName, fullTitle) {
        // Lưu dữ liệu vào biến toàn cục để dùng cho Popup Modal
        window.chartDataStore[canvasId] = { labels, data, colorHex, labelName, fullTitle };
        
        const ctx = document.getElementById(canvasId).getContext('2d');
        
        // Tạo Gradient (đổ bóng xuống dưới mượt mà)
        let gradient = ctx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, hexToRgba(colorHex, 0.5));
        gradient.addColorStop(1, hexToRgba(colorHex, 0.0));

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: labelName,
                    data: data,
                    borderColor: colorHex,
                    backgroundColor: gradient,
                    borderWidth: 2.5,
                    fill: true, // Bật đổ bóng
                    tension: 0.4, // Đường cong mượt
                    pointRadius: 0, // Ẩn điểm chấm khi bình thường
                    pointHoverRadius: 6, // Hiển thị to lên khi trỏ chuột vào
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: colorHex,
                    pointBorderWidth: 2
                }]
            },
            options: {
                responsive: true, 
                maintainAspectRatio: false,
                layout: {
                    padding: { top: 35 } // Cách title HTML bên trên ra một chút
                },
                interaction: {
                    mode: 'index',
                    intersect: false, // Hiệu ứng hover theo cột dọc giống bên KPI Analytics
                },
                plugins: {
                    legend: { display: false }, // Đã có title HTML bên ngoài
                    tooltip: {
                        backgroundColor: 'rgba(255, 255, 255, 0.95)',
                        titleColor: '#2c3e50',
                        bodyColor: '#2c3e50',
                        borderColor: '#ecf0f1',
                        borderWidth: 1,
                        padding: 10,
                        boxPadding: 5,
                        usePointStyle: true,
                        titleFont: { size: 13 },
                        bodyFont: { size: 14, weight: 'bold' }
                    }
                },
                scales: {
                    x: { grid: { display: false } },
                    y: { 
                        beginAtZero: true, 
                        grid: { borderDash: [5, 5], color: '#ecf0f1' } 
                    }
                }
            }
        });
    }

    async function loadDashboard() {
        try {
            const res = await fetch('/api/dashboard-data');
            if (!res.ok) throw new Error('API Error');
            let data = await res.json();

            document.getElementById('loadingIndicator').style.display = 'none';

            if (!data || data.length === 0) {
                document.getElementById('emptyIndicator').style.display = 'block';
                return;
            }

            document.getElementById('dashboardContent').style.display = 'block';

            // 1. Sắp xếp theo thời gian tăng dần
            data.sort((a, b) => parseDateForSort(a.thoi_gian) - parseDateForSort(b.thoi_gian));

            // 2. Trích xuất mảng dữ liệu (Labels)
            const labels = data.map(d => d.thoi_gian);
            
            // --- DATA 4G ---
            const traf4g = data.map(d => d.sum_TRAFFIC_4G);
            const thput4g = data.map(d => d.AVG_USER_DL_AVG_THPUT_4G);
            const prb4g = data.map(d => d.AVG_RES_BLK_DL_4G);
            const cqi4g = data.map(d => d.AVG_CQI_4G);

            // --- DATA 5G ---
            const traf5g = data.map(d => d.sum_TRAFFIC_5G);
            const thput5g = data.map(d => d.AVG_USER_DL_AVG_THPUT_5G);
            const cqi5g = data.map(d => d.AVG_CQI_5G);

            // 3. VẼ 7 BIỂU ĐỒ LINE ĐỘC LẬP
            
            // Mạng 4G
            drawLineChart('chart4g_Traffic', labels, traf4g, '#3498db', 'Traffic (GB)', 'Tổng Traffic 4G (GB)');
            drawLineChart('chart4g_Thput', labels, thput4g, '#9b59b6', 'Throughput (Kbps)', 'Trung bình Throughput DL 4G (Kbps)');
            drawLineChart('chart4g_PRB', labels, prb4g, '#e67e22', 'PRB DL (%)', 'Trung bình PRB DL 4G (%)');
            drawLineChart('chart4g_CQI', labels, cqi4g, '#2ecc71', 'CQI (%)', 'Trung bình CQI 4G (%)');

            // Mạng 5G
            drawLineChart('chart5g_Traffic', labels, traf5g, '#2980b9', 'Traffic (GB)', 'Tổng Traffic 5G (GB)');
            drawLineChart('chart5g_Thput', labels, thput5g, '#8e44ad', 'Throughput (Mbps)', 'Trung bình Throughput DL 5G (Mbps)');
            drawLineChart('chart5g_CQI', labels, cqi5g, '#27ae60', 'CQI (%)', 'Trung bình CQI 5G (%)');

        } catch (error) {
            console.error("Lỗi vẽ đồ thị trang chủ:", error);
            document.getElementById('loadingIndicator').innerHTML = "❌ Lỗi không thể tải dữ liệu từ máy chủ.";
            document.getElementById('loadingIndicator').style.color = "#e74c3c";
        }
    }

    // =====================================
    // CÁC HÀM XỬ LÝ MỞ / ĐÓNG MODAL POPUP
    // =====================================
    function openModal(canvasId) {
        const config = window.chartDataStore[canvasId];
        if (!config) return;

        const modal = document.getElementById('chartModal');
        modal.classList.add('show'); 

        setTimeout(() => {
            const ctx = document.getElementById('modalCanvas').getContext('2d');
            
            if (modalChartInstance) {
                modalChartInstance.destroy(); 
            }

            // Tạo lại Gradient nhưng dài hơn để hợp với kích thước màn hình to
            let gradient = ctx.createLinearGradient(0, 0, 0, 600);
            gradient.addColorStop(0, hexToRgba(config.colorHex, 0.5));
            gradient.addColorStop(1, hexToRgba(config.colorHex, 0.0));

            modalChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: config.labels,
                    datasets: [{
                        label: config.labelName,
                        data: config.data, 
                        borderColor: config.colorHex,
                        backgroundColor: gradient,
                        borderWidth: 4, 
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: config.colorHex,
                        pointBorderWidth: 3,
                        pointRadius: 5,
                        pointHoverRadius: 9,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true, 
                    maintainAspectRatio: false, 
                    animation: { duration: 600, easing: 'easeOutQuart' },
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    plugins: {
                        title: { display: true, text: config.fullTitle, font: { size: 24, weight: 'bold' }, color: '#2c3e50', padding: { bottom: 20 } },
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: 'rgba(44, 62, 80, 0.95)', titleFont: { size: 16 }, bodyFont: { size: 16, weight: 'bold' }, 
                            padding: 15, cornerRadius: 8, displayColors: false
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 20, font: { size: 14 } } },
                        y: { beginAtZero: true, grid: { borderDash: [5, 5], color: '#ecf0f1' }, ticks: { font: { size: 14 } } }
                    }
                }
            });
        }, 50); 
    }

    function closeModal() { document.getElementById('chartModal').classList.remove('show'); }
    
    // Đóng Modal khi bấm chuột ra vùng nền ngoài
    window.onclick = function(e) { 
        if (e.target === document.getElementById('chartModal')) closeModal(); 
    }

    window.onload = loadDashboard;
</script>
</body>
</html>
