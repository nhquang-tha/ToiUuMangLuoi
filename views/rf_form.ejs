<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .form-card { 
        background: white; 
        padding: 30px; 
        border-radius: 12px; 
        box-shadow: 0 4px 20px rgba(0,0,0,0.05); 
        border-top: 4px solid #3498db; 
        max-width: 1000px; 
        margin: 0 auto; 
    }
    
    .form-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); 
        gap: 20px; 
    }
    
    .form-group { display: flex; flex-direction: column; }
    .form-group label { 
        font-weight: bold; 
        color: #2c3e50; 
        font-size: 13px; 
        margin-bottom: 8px; 
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .form-group input { 
        padding: 12px 15px; 
        border: 1.5px solid #bdc3c7; 
        border-radius: 8px; 
        font-size: 14px; 
        outline: none; 
        transition: 0.3s; 
        background: #fdfdfd; 
        color: #34495e;
        font-weight: bold;
    }
    
    .form-group input:focus { 
        border-color: #3498db; 
        box-shadow: 0 0 0 3px rgba(52,152,219,0.15); 
        background: #fff;
    }
    
    .form-actions { 
        margin-top: 30px; 
        padding-top: 20px; 
        border-top: 1px dashed #bdc3c7; 
        display: flex; 
        justify-content: flex-end; 
        gap: 15px; 
    }
    
    .btn-cancel { 
        padding: 12px 25px; 
        background: #95a5a6; 
        color: white; 
        border-radius: 8px; 
        font-weight: bold; 
        text-decoration: none; 
        transition: 0.2s; 
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    .btn-cancel:hover { background: #7f8c8d; }
    
    .btn-save { 
        padding: 12px 25px; 
        background: #27ae60; 
        color: white; 
        border: none; 
        border-radius: 8px; 
        font-weight: bold; 
        cursor: pointer; 
        transition: 0.2s; 
        font-size: 14px; 
    }
    .btn-save:hover { 
        background: #219653; 
        transform: translateY(-2px); 
        box-shadow: 0 4px 10px rgba(39,174,96,0.3); 
    }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1><%= action === 'add' ? '✨ Thêm Mới' : '✏️ Chỉnh Sửa' %> Cấu Hình Trạm <%= currentNetwork.toUpperCase() %></h1>
            <p style="margin: 5px 0 0 0; color: #7f8c8d; font-size: 13px;">Cập nhật thông tin chi tiết cho cơ sở dữ liệu RF</p>
        </header>

        <div class="content-body">
            <div class="form-card">
                <!-- Xử lý an toàn URL (Sửa lỗi ID is not defined) -->
                <% 
                    let submitUrl = '/rf-database/' + action + '/' + currentNetwork;
                    if (action === 'edit' && locals.data && data.id) {
                        submitUrl += '/' + data.id;
                    }
                %>
                <form action="<%= submitUrl %>" method="POST">
                    <div class="form-grid">
                        <!-- Tự động quét và sinh Input dựa trên cấu trúc cột của Database -->
                        <% if (typeof columns !== 'undefined' && columns.length > 0) { %>
                            <% columns.forEach(function(col) { %>
                                <% if (col.toLowerCase() !== 'id' && col.toLowerCase() !== 'created_at') { %>
                                    <div class="form-group">
                                        <label><%= col.replace(/_/g, ' ') %></label>
                                        <input type="text" name="<%= col %>" value="<%= locals.data && data[col] !== null ? data[col] : '' %>" placeholder="Nhập <%= col %>...">
                                    </div>
                                <% } %>
                            <% }) %>
                        <% } else { %>
                            <div style="color: #e74c3c; font-weight: bold; grid-column: 1 / -1;">❌ Lỗi: Không thể tải cấu trúc Database. Vui lòng kiểm tra kết nối mạng.</div>
                        <% } %>
                    </div>

                    <div class="form-actions">
                        <a href="/rf-database?network=<%= currentNetwork %>" class="btn-cancel">✖ Hủy Bỏ</a>
                        <button type="submit" class="btn-save">💾 Lưu Dữ Liệu</button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>
</body>
</html>
```eof

Chỉ cần lưu lại, trang web sẽ không bao giờ văng lỗi "ID is not defined" nữa và giao diện cũng sẽ gọn gàng, chia làm các ô (Grid) để bạn thao tác dễ dàng hơn!
