<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .calc-container { display: flex; flex-wrap: wrap; gap: 20px; }
    
    .calc-card { 
        background: white; padding: 25px; border-radius: 12px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); flex: 1; min-width: 350px; 
        border-top: 4px solid #3498db;
    }
    
    .visual-card { 
        background: white; padding: 25px; border-radius: 12px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); flex: 2; min-width: 400px;
        border-top: 4px solid #9b59b6; display: flex; flex-direction: column;
    }

    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; margin-bottom: 8px; font-weight: bold; color: #34495e; font-size: 13px;}
    .input-wrapper { display: flex; align-items: center; border: 1px solid #bdc3c7; border-radius: 6px; overflow: hidden; background: #fdfdfd;}
    .input-wrapper input { flex: 1; border: none; padding: 10px 15px; outline: none; font-size: 15px; color: #2c3e50; font-weight: bold; }
    .input-wrapper span { background: #ecf0f1; padding: 10px 15px; color: #7f8c8d; font-weight: bold; border-left: 1px solid #bdc3c7; font-size: 13px;}

    .btn-calc { background: #3498db; color: white; border: none; padding: 12px; border-radius: 6px; font-weight: bold; cursor: pointer; width: 100%; font-size: 15px; transition: 0.2s; margin-top: 10px; }
    .btn-calc:hover { background: #2980b9; transform: translateY(-2px); box-shadow: 0 4px 10px rgba(52, 152, 219, 0.3); }

    .result-box { background: #f4f9fd; border: 1px solid #d6eaf8; border-radius: 8px; padding: 20px; margin-top: 20px; }
    .result-item { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px dashed #bdc3c7; }
    .result-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
    .result-label { color: #34495e; font-weight: bold; font-size: 14px; }
    .result-value { font-size: 18px; font-weight: 900; color: #e74c3c; }
    .result-value.ok { color: #27ae60; }

    canvas { width: 100%; height: 350px; background: #fdfdfd; border: 1px solid #ecf0f1; border-radius: 8px; margin-top: 15px; }

    .help-text { font-size: 12px; color: #7f8c8d; margin-top: 5px; line-height: 1.4; }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>📐 Antenna Downtilt & Coverage Calculator</h1>
            <p style="margin: 5px 0 0 0; color: #7f8c8d; font-size: 14px;">Công cụ tối ưu hóa góc ngẩng ăng ten để kiểm soát vùng phủ sóng và chống nhiễu đè (Overshoot).</p>
        </header>
        
        <div class="content-body">
            <div class="calc-container">
                
                <!-- BẢNG NHẬP LIỆU -->
                <div class="calc-card">
                    <h3 style="margin-top: 0; color: #2980b9; border-bottom: 2px solid #ecf0f1; padding-bottom: 10px;">⚙️ Thông Số Đầu Vào</h3>
                    
                    <div class="form-group">
                        <label>Chiều cao Ăng ten (Antenna Height - Ht)</label>
                        <div class="input-wrapper">
                            <input type="number" id="h_t" value="30" step="1">
                            <span>Mét (m)</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Chiều cao Thiết bị thu UE (User Height - Hr)</label>
                        <div class="input-wrapper">
                            <input type="number" id="h_r" value="1.5" step="0.1">
                            <span>Mét (m)</span>
                        </div>
                        <div class="help-text">Mặc định 1.5m (chiều cao người cầm điện thoại).</div>
                    </div>

                    <div class="form-group">
                        <label>Góc gục ăng ten (Total Downtilt - M.Tilt + E.Tilt)</label>
                        <div class="input-wrapper">
                            <input type="number" id="tilt" value="6" step="0.5">
                            <span>Độ (°)</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Búp sóng đứng (Vertical Beamwidth)</label>
                        <div class="input-wrapper">
                            <input type="number" id="beamwidth" value="10" step="0.5">
                            <span>Độ (°)</span>
                        </div>
                        <div class="help-text">Khoảng 6° - 12° tùy loại ăng ten (Tra cứu Datasheet).</div>
                    </div>

                    <button class="btn-calc" onclick="calculateCoverage()">⚡ TÍNH TOÁN VÙNG PHỦ</button>

                    <!-- KẾT QUẢ -->
                    <div class="result-box">
                        <div class="result-item">
                            <span class="result-label">Bán kính trong (Inner Radius)</span>
                            <span class="result-value ok" id="res_inner">-- m</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Bán kính ngoài (Outer Radius)</span>
                            <span class="result-value" id="res_outer">-- m</span>
                        </div>
                        <div class="result-item">
                            <span class="result-label">Bán kính tâm búp (Main Beam)</span>
                            <span class="result-value" id="res_main" style="color: #3498db;">-- m</span>
                        </div>
                    </div>
                </div>

                <!-- MÔ PHỎNG VISUALIZER -->
                <div class="visual-card">
                    <h3 style="margin-top: 0; color: #8e44ad; border-bottom: 2px solid #ecf0f1; padding-bottom: 10px;">🌍 Mô Phỏng Đồ Họa Búp Sóng</h3>
                    <div style="flex: 1; display: flex; flex-direction: column;">
                        <p style="font-size: 13px; color: #7f8c8d; margin-bottom: 0;">Mô phỏng mặt cắt dọc của vùng phủ sóng so với mặt đất.</p>
                        <canvas id="coverageCanvas"></canvas>
                    </div>
                    
                    <div style="margin-top: 15px; padding: 15px; background: #fffcf5; border-left: 4px solid #f1c40f; border-radius: 4px; font-size: 13px; color: #34495e; line-height: 1.5;">
                        <b>💡 Khuyến nghị tối ưu (RNO):</b><br>
                        - Nếu <b>Outer Radius = Vô cực</b>: Cảnh báo ăng ten đang phát vượt qua đường chân trời, gây nhiễu đè (Overshoot) nghiêm trọng cho các trạm lân cận. Hãy tăng góc Tilt.<br>
                        - Nếu vùng phủ quá hẹp (Inner Radius lớn): Tín hiệu sát chân cột sẽ rất yếu (Vùng lõm chân trạm). Nên sử dụng ăng ten có Null-Fill hoặc giảm Tilt.
                    </div>
                </div>

            </div>
        </div>
    </main>
</div>

<script>
    // Hàm khởi chạy lần đầu
    window.onload = () => {
        calculateCoverage();
    };

    function calculateCoverage() {
        const ht = parseFloat(document.getElementById('h_t').value);
        const hr = parseFloat(document.getElementById('h_r').value);
        const tilt = parseFloat(document.getElementById('tilt').value);
        const bw = parseFloat(document.getElementById('beamwidth').value);

        if (isNaN(ht) || isNaN(hr) || isNaN(tilt) || isNaN(bw)) {
            alert("Vui lòng nhập đầy đủ các số liệu hợp lệ.");
            return;
        }

        const deltaH = ht - hr;
        if (deltaH <= 0) {
            alert("Chiều cao ăng ten phải lớn hơn chiều cao User!");
            return;
        }

        // Tính góc tính từ mặt phẳng ngang (Horizon) xuống
        const angle_main = tilt;
        const angle_inner = tilt + (bw / 2);
        const angle_outer = tilt - (bw / 2);

        // Chuyển sang Radian
        const rad_main = angle_main * (Math.PI / 180);
        const rad_inner = angle_inner * (Math.PI / 180);
        const rad_outer = angle_outer * (Math.PI / 180);

        // Tính toán khoảng cách (D = Delta_H / tan(Angle))
        let d_inner = deltaH / Math.tan(rad_inner);
        let d_main = deltaH / Math.tan(rad_main);
        let d_outer = Infinity;

        let outerText = "Vô cực (Nhiễu đè)";
        if (angle_outer > 0) {
            d_outer = deltaH / Math.tan(rad_outer);
            outerText = d_outer.toFixed(1) + " m";
            document.getElementById('res_outer').style.color = "#27ae60"; // Xanh nếu an toàn
        } else {
            document.getElementById('res_outer').style.color = "#c0392b"; // Đỏ nếu vô cực
        }

        document.getElementById('res_inner').innerText = Math.abs(d_inner).toFixed(1) + " m";
        document.getElementById('res_main').innerText = Math.abs(d_main).toFixed(1) + " m";
        document.getElementById('res_outer').innerText = outerText;

        // Vẽ mô phỏng
        drawCanvas(ht, d_inner, d_main, d_outer, angle_outer <= 0);
    }

    function drawCanvas(ht, d_inner, d_main, d_outer, isInfinity) {
        const canvas = document.getElementById('coverageCanvas');
        const ctx = canvas.getContext('2d');
        
        // Cập nhật lại kích thước thật cho Canvas sắc nét
        canvas.width = canvas.clientWidth;
        canvas.height = canvas.clientHeight;
        
        const w = canvas.width;
        const h = canvas.height;

        ctx.clearRect(0, 0, w, h);

        // Lề quy hoạch
        const padX = 50; 
        const padY = 50;
        
        // Tọa độ Gốc cột ăng ten
        const towerBaseX = padX;
        const towerBaseY = h - padY;
        
        // Tìm tỷ lệ (Scale)
        // Nếu d_outer vô cực, ta giả lập khoảng cách xa bằng d_main * 3
        const maxDist = isInfinity ? Math.max(d_main * 2.5, 1000) : d_outer;
        const scaleX = (w - padX * 2) / maxDist;
        const scaleY = (h - padY * 2) / ht; // Ht = Chiều cao max

        // Vẽ bầu trời và mặt đất
        ctx.fillStyle = '#f0f8ff';
        ctx.fillRect(0, 0, w, towerBaseY);
        ctx.fillStyle = '#e8f6e9';
        ctx.fillRect(0, towerBaseY, w, h - towerBaseY);
        
        // Đường chân trời (Đất)
        ctx.beginPath();
        ctx.moveTo(0, towerBaseY);
        ctx.lineTo(w, towerBaseY);
        ctx.strokeStyle = '#27ae60';
        ctx.lineWidth = 3;
        ctx.stroke();

        // Vẽ Tháp Ăng ten (Tower)
        const towerTopY = towerBaseY - (ht * scaleY);
        ctx.beginPath();
        ctx.moveTo(towerBaseX - 5, towerBaseY);
        ctx.lineTo(towerBaseX, towerTopY);
        ctx.lineTo(towerBaseX + 5, towerBaseY);
        ctx.fillStyle = '#7f8c8d';
        ctx.fill();

        // Ăng ten màu đỏ trên đỉnh
        ctx.beginPath();
        ctx.rect(towerBaseX - 3, towerTopY, 6, 15);
        ctx.fillStyle = '#c0392b';
        ctx.fill();

        // Tọa độ búp sóng trên màn hình
        const px_inner = towerBaseX + (d_inner * scaleX);
        const px_main = towerBaseX + (d_main * scaleX);
        const px_outer = isInfinity ? w : towerBaseX + (d_outer * scaleX);

        // Vẽ chùm tia sáng (Beam)
        ctx.beginPath();
        ctx.moveTo(towerBaseX, towerTopY);
        ctx.lineTo(px_outer, isInfinity ? towerTopY + ((h - padY - towerTopY)/2) : towerBaseY); // Nếu vô cực thì tia phóng ra khỏi màn hình
        ctx.lineTo(px_inner, towerBaseY);
        ctx.closePath();
        
        // Đổ màu Gradient cho tia sóng
        let gradient = ctx.createLinearGradient(towerBaseX, towerTopY, px_main, towerBaseY);
        gradient.addColorStop(0, 'rgba(52, 152, 219, 0.6)');
        gradient.addColorStop(1, 'rgba(46, 204, 113, 0.2)');
        ctx.fillStyle = gradient;
        ctx.fill();
        ctx.strokeStyle = 'rgba(52, 152, 219, 0.8)';
        ctx.lineWidth = 1;
        ctx.stroke();

        // Vẽ tia Main Beam (Tia trung tâm)
        ctx.beginPath();
        ctx.setLineDash([5, 5]);
        ctx.moveTo(towerBaseX, towerTopY);
        ctx.lineTo(px_main, towerBaseY);
        ctx.strokeStyle = '#e74c3c';
        ctx.lineWidth = 2;
        ctx.stroke();
        ctx.setLineDash([]); // Reset line dash

        // Đánh dấu các mốc cự ly
        ctx.fillStyle = '#2c3e50';
        ctx.font = 'bold 12px Arial';
        
        // Vẽ Inner
        ctx.beginPath(); ctx.arc(px_inner, towerBaseY, 4, 0, 2*Math.PI); ctx.fillStyle = '#3498db'; ctx.fill();
        ctx.fillText(`Inner: ${d_inner.toFixed(0)}m`, px_inner - 30, towerBaseY + 20);
        
        // Vẽ Main
        ctx.beginPath(); ctx.arc(px_main, towerBaseY, 4, 0, 2*Math.PI); ctx.fillStyle = '#e74c3c'; ctx.fill();
        ctx.fillText(`Main: ${d_main.toFixed(0)}m`, px_main - 30, towerBaseY + 35);
        
        // Vẽ Outer
        if (!isInfinity) {
            ctx.beginPath(); ctx.arc(px_outer, towerBaseY, 4, 0, 2*Math.PI); ctx.fillStyle = '#9b59b6'; ctx.fill();
            ctx.fillText(`Outer: ${d_outer.toFixed(0)}m`, px_outer - 40, towerBaseY + 20);
        } else {
            ctx.fillStyle = '#c0392b';
            ctx.fillText(`Outer: Vô cực ➡`, w - 100, towerBaseY - 20);
        }

        // Vẽ nhãn Chiều cao
        ctx.fillStyle = '#34495e';
        ctx.fillText(`Ht = ${ht}m`, towerBaseX - 45, towerTopY - 10);
    }

    // Tự động tính lại khi người dùng thay đổi giá trị
    document.querySelectorAll('input').forEach(input => {
        input.addEventListener('input', calculateCoverage);
    });
</script>
</body>
</html>
