<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; border-top: 4px solid #3498db;}
    
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    @media (max-width: 1024px) { .charts-grid { grid-template-columns: 1fr; } }
    
    .chart-container { 
        background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
        height: 380px; position: relative; 
        opacity: 0; /* Ẩn đi chờ hiệu ứng popup */
        cursor: pointer; /* Hiển thị trỏ chuột dạng nút bấm */
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    /* Hiệu ứng khi hover vào biểu đồ để báo hiệu có thể click */
    .chart-container:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }
    .chart-container:hover .zoom-hint {
        color: #3498db;
        font-weight: bold;
    }

    .zoom-hint {
        position: absolute;
        top: 15px;
        right: 20px;
        font-size: 12px;
        color: #bdc3c7;
        transition: 0.3s;
        pointer-events: none;
    }

    /* HIỆU ỨNG POPUP NẢY (BOUNCING) CHUYÊN NGHIỆP */
    @keyframes popInBouncing {
        0% { opacity: 0; transform: scale(0.8) translateY(30px); }
        60% { opacity: 1; transform: scale(1.03) translateY(-5px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    .popup-anim-1 { animation: popInBouncing 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.1s forwards; }
    .popup-anim-2 { animation: popInBouncing 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.2s forwards; }
    .popup-anim-3 { animation: popInBouncing 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.3s forwards; }
    .popup-anim-4 { animation: popInBouncing 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.4s forwards; }

    /* CSS CHO MODAL PHÓNG TO BIỂU ĐỒ */
    .modal-overlay {
        display: none; position: fixed; z-index: 1000; left: 0; top: 0;
        width: 100%; height: 100%; background-color: rgba(0,0,0,0.7);
        align-items: center; justify-content: center;
        opacity: 0; transition: opacity 0.3s ease;
    }
    .modal-overlay.show {
        display: flex; opacity: 1;
    }
    .modal-content {
        background: white; padding: 25px; border-radius: 12px;
        width: 90%; max-width: 1300px; height: 85vh; position: relative;
        transform: scale(0.8); transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        display: flex; flex-direction: column;
    }
    .modal-overlay.show .modal-content {
        transform: scale(1);
    }
    .close-btn {
        position: absolute; top: 15px; right: 25px; font-size: 32px;
        font-weight: bold; color: #7f8c8d; cursor: pointer; transition: 0.2s;
        z-index: 10;
    }
    .close-btn:hover { color: #e74c3c; }
    .modal-body { flex: 1; position: relative; width: 100%; height: 100%; }

</style>

<!-- Load thư viện vẽ biểu đồ Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>Phân Tích Hiệu Năng Mạng (KPI Analytics)</h1>
        </header>
        
        <div class="content-body">
            
            <!-- BỘ LỌC DỮ LIỆU -->
            <div class="filter-card">
                <div style="flex: 1; min-width: 200px;">
                    <label style="display:block; margin-bottom:8px; font-weight:bold; color:#2c3e50;">Chọn Mạng Lưới:</label>
                    <select id="networkSelect" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; cursor: pointer; font-size: 14px;">
                        <option value="4g" selected>Mạng 4G LTE</option>
                        <option value="3g">Mạng 3G WCDMA</option>
                        <option value="5g">Mạng 5G NR</option>
                    </select>
                </div>
                <div style="flex: 2; min-width: 250px;">
                    <label style="display:block; margin-bottom:8px; font-weight:bold; color:#2c3e50;">Tên Cell (Bỏ trống để xem toàn mạng):</label>
                    <input type="text" id="cellNameInput" placeholder="Ví dụ: 4G-HHA021M41-THA..." style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; font-size: 14px;">
                </div>
                <button onclick="fetchAndDrawCharts()" class="btn-primary" style="background: #2980b9; color: white; border: none; padding: 12px 30px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 45px; font-size: 15px; transition: 0.2s;">
                    📊 Trích Xuất Biểu Đồ
                </button>
            </div>

            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #e67e22; font-size: 16px; font-weight: bold; background: white; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 15px;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang tải và phân tích dữ liệu...
            </div>
            
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px;"></div>

            <!-- KHU VỰC HIỂN THỊ ĐỒ THỊ (Gắn sự kiện Click để phóng to) -->
            <div class="charts-grid" id="chartsArea" style="display: none;">
                <div class="chart-container" id="box1" onclick="openModal('chartThroughput')">
                    <span class="zoom-hint">🔍 Click để phóng to</span>
                    <canvas id="chartThroughput"></canvas>
                </div>
                <div class="chart-container" id="box2" onclick="openModal('chartTraffic')">
                    <span class="zoom-hint">🔍 Click để phóng to</span>
                    <canvas id="chartTraffic"></canvas>
                </div>
                <div class="chart-container" id="box3" onclick="openModal('chartCSSR')">
                    <span class="zoom-hint">🔍 Click để phóng to</span>
                    <canvas id="chartCSSR"></canvas>
                </div>
                <div class="chart-container" id="box4" onclick="openModal('chartCDR')">
                    <span class="zoom-hint">🔍 Click để phóng to</span>
                    <canvas id="chartCDR"></canvas>
                </div>
            </div>

        </div>
    </main>
</div>

<!-- MODAL POPUP PHÓNG TO ĐỒ THỊ -->
<div id="chartModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <div class="modal-body">
            <canvas id="modalCanvas"></canvas>
        </div>
    </div>
</div>

<style>
    @keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<script>
    // Biến toàn cục để lưu trữ dữ liệu của các biểu đồ đã vẽ
    window.chartDataStore = {};
    let modalChartInstance = null;
    let throughputChart, trafficChart, cssrChart, cdrChart;

    // Hàm sắp xếp dữ liệu theo ngày tháng
    function sortDataByDate(data) {
        return data.sort((a, b) => {
            const parseDate = (dateStr) => {
                if (!dateStr) return 0;
                const parts = dateStr.split('/');
                if (parts.length === 3) return new Date(`${parts[2]}-${parts[1]}-${parts[0]}`).getTime();
                return 0;
            };
            return parseDate(a.Thoi_gian) - parseDate(b.Thoi_gian);
        });
    }

    async function fetchAndDrawCharts() {
        const network = document.getElementById('networkSelect').value;
        const cellName = document.getElementById('cellNameInput').value.trim();

        document.getElementById('loadingMsg').style.display = 'block';
        document.getElementById('errorMsg').style.display = 'none';
        
        // Reset trạng thái hiển thị của khung chứa đồ thị để chạy lại Animation
        document.getElementById('chartsArea').style.display = 'none';
        const boxes = ['box1', 'box2', 'box3', 'box4'];
        boxes.forEach(id => document.getElementById(id).className = 'chart-container'); 

        try {
            const response = await fetch(`/api/kpi-data?network=${network}&cellName=${encodeURIComponent(cellName)}`);
            if (!response.ok) throw new Error('Lỗi truy xuất từ máy chủ');
            let data = await response.json();

            if (data.length === 0) {
                document.getElementById('loadingMsg').style.display = 'none';
                document.getElementById('errorMsg').innerText = 'Không tìm thấy dữ liệu KPI nào phù hợp với bộ lọc!';
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            // Sắp xếp dữ liệu theo thời gian
            data = sortDataByDate(data);

            const labels = data.map(d => d.Thoi_gian || 'N/A');
            let throughputData, trafficData, cssrData, cdrData;
            let throughputLabel = '', trafficLabel = '', cssrLabel = '', cdrLabel = '';

            // ÁNH XẠ DỮ LIỆU TỪ DATABASE
            if (network === '4g') {
                throughputLabel = 'USER DL AVG THPUT (Kbps)';
                throughputData = data.map(d => parseFloat(d.User_DL_Avg_Throughput_Kbps) || 0);
                
                trafficLabel = 'Total Data Traffic Volume (GB)';
                trafficData = data.map(d => parseFloat(d.Total_Data_Traffic_Volume_GB) || 0);
                
                cssrLabel = 'Call Setup Success Rate (%)';
                cssrData = data.map(d => parseFloat(d.Call_Setup_SR) || parseFloat(d.RRC_Conn_Estab_SR) || 0);
                
                cdrLabel = 'Service Drop All (%)';
                cdrData = data.map(d => parseFloat(d.Service_Drop_all) || parseFloat(d.Call_Drop_Rate_VoLTE) || 0);
            } 
            else if (network === '3g') {
                throughputLabel = 'HSDPA Throughput (Kbps)';
                throughputData = data.map(d => parseFloat(d.HSDPATHROUGHPUT) || parseFloat(d.R99DLTHROUGHPUT) || 0);
                trafficLabel = 'Traffic (Erlang/GB)';
                trafficData = data.map(d => parseFloat(d.TRAFFIC) || parseFloat(d.PSR99TRAFFICGB) || 0);
                cssrLabel = 'CSSR (%)';
                cssrData = data.map(d => parseFloat(d.CSSR) || 0);
                cdrLabel = 'DCR (%)';
                cdrData = data.map(d => parseFloat(d.DCR) || 0);
            } 
            else if (network === '5g') {
                throughputLabel = 'User DL Avg Throughput (Kbps)';
                throughputData = data.map(d => parseFloat(d.A_User_DL_Avg_Throughput) || 0);
                trafficLabel = 'DL Traffic Volume (GB)';
                trafficData = data.map(d => parseFloat(d.DL_Traffic_Volume_GB) || parseFloat(d.Total_Data_Traffic_Volume_GB) || 0);
                cssrLabel = 'SgNB Addition SR (%)';
                cssrData = data.map(d => parseFloat(d.SgNB_Addition_SR) || 0);
                cdrLabel = 'SgNB Abnormal Release Rate (%)';
                cdrData = data.map(d => parseFloat(d.SgNB_Abnormal_Release_Rate) || 0);
            }

            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('chartsArea').style.display = 'grid';

            // KÍCH HOẠT HIỆU ỨNG POPUP NẢY LẦN LƯỢT CHO CÁC KHUNG ĐỒ THỊ
            document.getElementById('box1').classList.add('popup-anim-1');
            document.getElementById('box2').classList.add('popup-anim-2');
            document.getElementById('box3').classList.add('popup-anim-3');
            document.getElementById('box4').classList.add('popup-anim-4');

            // Vẽ đồ thị (Mọi biểu đồ giờ đều là Line)
            drawChart('chartThroughput', labels, throughputData, throughputLabel, '#9b59b6');
            drawChart('chartTraffic', labels, trafficData, trafficLabel, '#3498db');
            drawChart('chartCSSR', labels, cssrData, cssrLabel, '#27ae60');
            drawChart('chartCDR', labels, cdrData, cdrLabel, '#e74c3c');

        } catch (error) {
            console.error(error);
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = 'Lỗi hệ thống khi vẽ biểu đồ. Vui lòng kiểm tra lại kết nối mạng.';
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    // Hàm lõi chuyên dùng để Render Chart.js
    function drawChart(canvasId, labels, dataArr, title, color) {
        // Lưu cấu hình vào biến toàn cục để tái sử dụng lúc phóng to Modal
        window.chartDataStore[canvasId] = { labels, dataArr, title, color };

        const ctx = document.getElementById(canvasId).getContext('2d');
        
        if (Chart.getChart(canvasId)) {
            Chart.getChart(canvasId).destroy();
        }

        return new Chart(ctx, {
            type: 'line', // Chuyển toàn bộ đồ thị thành đường line
            data: {
                labels: labels,
                datasets: [{
                    label: title,
                    data: dataArr,
                    backgroundColor: color + '22', // Trong suốt nhẹ cho biểu đồ đường
                    borderColor: color,
                    borderWidth: 3, 
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: color,
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 7,
                    fill: true,
                    tension: 0.4 // Làm cong mượt đường line
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 1500,
                    easing: 'easeOutQuart'
                },
                plugins: {
                    title: { display: true, text: title, font: { size: 16, weight: 'bold', family: "'Segoe UI', sans-serif" }, color: '#34495e', padding: { bottom: 15 } },
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(44, 62, 80, 0.9)',
                        titleFont: { size: 14 },
                        bodyFont: { size: 14, weight: 'bold' },
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return context.parsed.y.toLocaleString('vi-VN') + (title.includes('%') ? ' %' : '');
                            }
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { maxTicksLimit: 12, font: { size: 11 } } },
                    y: { beginAtZero: true, grid: { borderDash: [5, 5], color: '#ecf0f1' }, ticks: { font: { size: 12 } } }
                }
            }
        });
    }

    // --- CÁC HÀM XỬ LÝ MODAL PHÓNG TO ĐỒ THỊ ---
    function openModal(canvasId) {
        const config = window.chartDataStore[canvasId];
        if (!config) return;

        document.getElementById('chartModal').classList.add('show');
        const ctx = document.getElementById('modalCanvas').getContext('2d');

        if (modalChartInstance) {
            modalChartInstance.destroy();
        }

        // Vẽ lại phiên bản cực đại trên Modal
        modalChartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: config.labels,
                datasets: [{
                    label: config.title,
                    data: config.dataArr,
                    backgroundColor: config.color + '22',
                    borderColor: config.color,
                    borderWidth: 4, // Đậm hơn khi phóng to
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: config.color,
                    pointBorderWidth: 3,
                    pointRadius: 6,
                    pointHoverRadius: 9,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: { duration: 600, easing: 'easeOutQuart' },
                plugins: {
                    title: { display: true, text: config.title, font: { size: 24, weight: 'bold', family: "'Segoe UI', sans-serif" }, color: '#2c3e50', padding: { bottom: 20 } },
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(44, 62, 80, 0.95)',
                        titleFont: { size: 16 },
                        bodyFont: { size: 16, weight: 'bold' },
                        padding: 15,
                        cornerRadius: 8,
                        displayColors: false,
                        callbacks: {
                            label: function(context) {
                                return context.parsed.y.toLocaleString('vi-VN') + (config.title.includes('%') ? ' %' : '');
                            }
                        }
                    }
                },
                scales: {
                    x: { grid: { display: false }, ticks: { maxTicksLimit: 20, font: { size: 14 } } },
                    y: { beginAtZero: true, grid: { borderDash: [5, 5], color: '#ecf0f1' }, ticks: { font: { size: 14 } } }
                }
            }
        });
    }

    function closeModal() {
        document.getElementById('chartModal').classList.remove('show');
    }

    // Đóng Modal khi click ra khoảng trống tối (overlay) bên ngoài khung biểu đồ
    window.onclick = function(event) {
        const modal = document.getElementById('chartModal');
        if (event.target === modal) {
            closeModal();
        }
    }

    // Tự động load dữ liệu 4G khi mới vào trang
    window.onload = () => {
        fetchAndDrawCharts();
    };
</script>
</body>
</html>
