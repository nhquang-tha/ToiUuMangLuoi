<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; border-top: 4px solid #3498db; }
    .filter-row { display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; margin-bottom: 15px; }
    
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
    @media (max-width: 1024px) { .charts-grid { grid-template-columns: 1fr; } }
    
    .chart-container { 
        background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
        height: 380px; position: relative; cursor: pointer; transition: transform 0.3s ease, box-shadow 0.3s ease;
        animation: fadeIn 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    }

    .chart-container:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.15); }
    .chart-container:hover .zoom-hint { color: #3498db; font-weight: bold; }
    .zoom-hint { position: absolute; top: 15px; right: 20px; font-size: 12px; color: #bdc3c7; transition: 0.3s; pointer-events: none; z-index: 5;}

    @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    /* Modal Zoom */
    .modal-overlay {
        display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.7);
        align-items: center; justify-content: center; opacity: 0; transition: opacity 0.3s ease;
    }
    .modal-overlay.show { display: flex; opacity: 1; }
    .modal-content {
        background: white; padding: 25px; border-radius: 12px; width: 90%; max-width: 1300px; height: 85vh; position: relative;
        transform: scale(0.8); transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94); box-shadow: 0 10px 30px rgba(0,0,0,0.3); display: flex; flex-direction: column;
    }
    .modal-overlay.show .modal-content { transform: scale(1); }
    .close-btn { position: absolute; top: 15px; right: 25px; font-size: 32px; font-weight: bold; color: #7f8c8d; cursor: pointer; transition: 0.2s; z-index: 10; }
    .close-btn:hover { color: #e74c3c; }
    .modal-body { flex: 1; position: relative; width: 100%; height: 100%; }
    
    .section-title { font-size: 18px; color: #2c3e50; border-bottom: 2px solid #ecf0f1; padding-bottom: 8px; margin-bottom: 15px; font-weight: bold; }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>So Sánh & Phân Tích KPI (Đa Luồng)</h1>
        </header>
        
        <div class="content-body">
            
            <div class="filter-card">
                <!-- Chế độ tra cứu -->
                <div class="filter-row" style="width: 100%; border-bottom: 1px solid #eee; padding-bottom: 15px;">
                    <div style="min-width: 250px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#2c3e50;">Chế độ tra cứu:</label>
                        <select id="searchMode" onchange="toggleSearchMode()" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; background: #fdfdfd; font-weight:bold; color:#34495e;">
                            <option value="keyword">🔍 Tra cứu theo Cell / Site</option>
                            <option value="poi">📍 Tra cứu theo POI (Hiển thị chung 4G & 5G)</option>
                        </select>
                    </div>
                </div>

                <!-- Input Tra cứu Cell/Site -->
                <div id="keywordControls" class="filter-row" style="width: 100%;">
                    <div style="flex: 1; min-width: 200px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#2c3e50;">Chọn Mạng:</label>
                        <select id="networkSelect" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none;">
                            <option value="4g">Mạng 4G LTE</option>
                            <option value="3g">Mạng 3G WCDMA</option>
                            <option value="5g">Mạng 5G NR</option>
                        </select>
                    </div>
                    <div style="flex: 3; min-width: 300px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#e74c3c;">Nhập Tên Cell / Site (Nhập nhiều cách nhau dấu phẩy):</label>
                        <input type="text" id="keywordInput" placeholder="Ví dụ: 4G-HHA021M (tìm cả trạm), hoặc 4G-HHA021M41, 4G-HHA022M31 (so sánh 2 cell)" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; border-left: 4px solid #e74c3c;">
                    </div>
                </div>

                <!-- Input Tra cứu POI -->
                <div id="poiControls" class="filter-row" style="width: 100%; display: none;">
                    <div style="flex: 1; min-width: 300px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#9b59b6;">Chọn khu vực POI:</label>
                        <select id="poiSelect" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; border-left: 4px solid #9b59b6;">
                            <option value="">Đang tải danh sách POI...</option>
                        </select>
                    </div>
                </div>

                <div style="width: 100%; text-align: right; margin-top: 5px;">
                    <button onclick="executeAnalysis()" class="btn-primary" style="background: #2980b9; color: white; border: none; padding: 12px 35px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 15px; transition: 0.2s;">
                        🚀 Phân Tích & Vẽ Biểu Đồ
                    </button>
                </div>
            </div>

            <!-- Các thông báo hệ thống -->
            <div id="initMsg" style="text-align: center; padding: 50px; color: #7f8c8d; font-size: 15px; background: white; border-radius: 8px;">
                <i>Vui lòng nhập dữ liệu tra cứu và bấm "Phân Tích & Vẽ Biểu Đồ".</i>
            </div>
            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #e67e22; font-size: 16px; font-weight: bold; background: white; border-radius: 8px; margin-bottom: 15px;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang tải & phân tích dữ liệu đa luồng...
            </div>
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px;"></div>

            <!-- KHU VỰC CHỨA BIỂU ĐỒ ĐỘNG -->
            <div id="dynamicChartsArea" style="display: none;"></div>

        </div>
    </main>
</div>

<!-- MODAL POPUP PHÓNG TO ĐỒ THỊ -->
<div id="chartModal" class="modal-overlay">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <div class="modal-body" id="modalBodyContainer">
            <canvas id="modalCanvas"></canvas>
        </div>
    </div>
</div>

<script>
    // --- KHAI BÁO CẤU HÌNH KPI CHO TỪNG MẠNG ---
    const KPI_CONFIG = {
        '3g': [
            { key: 'PSTRAFFIC', title: 'PS TRAFFIC (Erl/GB)' },
            { key: 'PSCONGES', title: 'PS CONGES (%)' },
            { key: 'TRAFFIC', title: 'TRAFFIC (Erl/GB)' },
            { key: 'CSCONGES', title: 'CS CONGES (%)' }
        ],
        '4g': [
            { key: 'Total_Data_Traffic_Volume_GB', title: 'TRAFFIC (Total Data Volume GB)' },
            { key: 'User_DL_Avg_Throughput_Kbps', title: 'USER DL AVG THPUT (Kbps)' },
            { key: 'RB_Util_Rate_DL', title: 'RES BLK DL (RB Util Rate DL %)' },
            { key: 'CQI_4G', title: 'CQI 4G' }
        ],
        '5g': [
            { key: 'Total_Data_Traffic_Volume_GB', title: 'TRAFFIC (Total Data Volume GB)' },
            { key: 'Cell_DL_Avg_Throughput', title: 'CELL DL AVG THROUGHPUT (Kbps)' },
            { key: 'CQI_5G', title: 'CQI 5G' }
        ]
    };

    const CHART_COLORS = ['#3498db', '#e74c3c', '#2ecc71', '#9b59b6', '#f1c40f', '#e67e22', '#1abc9c', '#34495e', '#d35400', '#c0392b'];

    window.chartDataStore = {}; 
    window.chartInstances = {}; 
    let modalChartInstance = null;

    // Tự động load danh sách POI và xử lý Deep Link từ các trang Cảnh Báo
    window.onload = async () => {
        try {
            const res = await fetch('/api/poi-list');
            const list = await res.json();
            const select = document.getElementById('poiSelect');
            select.innerHTML = '<option value="">-- Click để Chọn POI --</option>';
            list.forEach(poi => select.insertAdjacentHTML('beforeend', `<option value="${poi}">${poi}</option>`));
        } catch (e) {}

        // ĐỌC THAM SỐ TỪ URL ĐỂ TỰ ĐỘNG CHẠY BIỂU ĐỒ (DEEP LINKING)
        const urlParams = new URLSearchParams(window.location.search);
        const cellParam = urlParams.get('cell');
        const poiParam = urlParams.get('poi');
        const networkParam = urlParams.get('network');

        if (cellParam) {
            document.getElementById('searchMode').value = 'keyword';
            toggleSearchMode();
            if (networkParam) document.getElementById('networkSelect').value = networkParam;
            document.getElementById('keywordInput').value = cellParam;
            executeAnalysis(); // Tự động click nút vẽ
        } else if (poiParam) {
            document.getElementById('searchMode').value = 'poi';
            toggleSearchMode();
            // Cần một chút thời gian để select box được đổ danh sách POI
            setTimeout(() => {
                document.getElementById('poiSelect').value = poiParam;
                executeAnalysis();
            }, 300);
        }
    };

    // Đổi giao diện UI tùy theo chế độ tra cứu
    function toggleSearchMode() {
        const mode = document.getElementById('searchMode').value;
        if (mode === 'keyword') {
            document.getElementById('keywordControls').style.display = 'flex';
            document.getElementById('poiControls').style.display = 'none';
        } else {
            document.getElementById('keywordControls').style.display = 'none';
            document.getElementById('poiControls').style.display = 'flex';
        }
    }

    function sortUniqueDates(datesArray) {
        return datesArray.sort((a, b) => {
            const pa = a.split('/'); const pb = b.split('/');
            return new Date(`${pa[2]}-${pa[1]}-${pa[0]}`).getTime() - new Date(`${pb[2]}-${pb[1]}-${pb[0]}`).getTime();
        });
    }

    async function executeAnalysis() {
        const mode = document.getElementById('searchMode').value;
        let requests = [];

        if (mode === 'keyword') {
            const val = document.getElementById('keywordInput').value.trim();
            if (!val) return alert("Vui lòng nhập Tên Cell hoặc Site!");
            const net = document.getElementById('networkSelect').value;
            requests.push({ network: net, url: `/api/kpi-data?network=${net}&type=keyword&value=${encodeURIComponent(val)}` });
        } else {
            const val = document.getElementById('poiSelect').value;
            if (!val) return alert("Vui lòng chọn 1 POI từ danh sách!");
            requests.push({ network: '4g', url: `/api/kpi-data?network=4g&type=poi&value=${encodeURIComponent(val)}` });
            requests.push({ network: '5g', url: `/api/kpi-data?network=5g&type=poi&value=${encodeURIComponent(val)}` });
        }

        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('errorMsg').style.display = 'none';
        document.getElementById('dynamicChartsArea').style.display = 'none';
        document.getElementById('dynamicChartsArea').innerHTML = ''; 
        document.getElementById('loadingMsg').style.display = 'block';

        let hasData = false;

        try {
            for (let req of requests) {
                const res = await fetch(req.url);
                const data = await res.json();
                
                if (data && data.length > 0) {
                    hasData = true;
                    buildChartSection(data, req.network, mode === 'poi');
                }
            }

            document.getElementById('loadingMsg').style.display = 'none';
            
            if (hasData) {
                document.getElementById('dynamicChartsArea').style.display = 'block';
            } else {
                document.getElementById('errorMsg').innerText = "Hệ thống không tìm thấy dữ liệu KPI nào khớp với thông tin bạn cung cấp.";
                document.getElementById('errorMsg').style.display = 'block';
            }

        } catch (error) {
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = "Có lỗi xảy ra khi truy vấn CSDL.";
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    function buildChartSection(rawData, network, showTitle) {
        const area = document.getElementById('dynamicChartsArea');
        const configKeys = KPI_CONFIG[network];
        const cellNameKey = (network === '4g') ? 'Cell_name' : 'Ten_CELL';

        let allDates = sortUniqueDates([...new Set(rawData.map(d => d.Thoi_gian))].filter(Boolean));
        let allCells = [...new Set(rawData.map(d => d[cellNameKey]))].filter(Boolean);

        if (showTitle) {
            area.insertAdjacentHTML('beforeend', `<div class="section-title">📊 Dữ liệu Mạng ${network.toUpperCase()} thuộc POI</div>`);
        }
        
        const gridId = `grid_${network}_${Math.random().toString(36).substr(2, 5)}`;
        area.insertAdjacentHTML('beforeend', `<div class="charts-grid" id="${gridId}"></div>`);
        const gridEl = document.getElementById(gridId);

        configKeys.forEach((config, idx) => {
            const canvasId = `canvas_${network}_${config.key}`;
            const boxHtml = `
                <div class="chart-container" onclick="openModal('${canvasId}')">
                    <span class="zoom-hint">🔍 Click để phóng to</span>
                    <canvas id="${canvasId}"></canvas>
                </div>
            `;
            gridEl.insertAdjacentHTML('beforeend', boxHtml);

            let datasets = allCells.map((cellName, colorIndex) => {
                const color = CHART_COLORS[colorIndex % CHART_COLORS.length];
                const cellRows = rawData.filter(r => r[cellNameKey] === cellName);
                
                const dataPoints = allDates.map(date => {
                    const row = cellRows.find(r => r.Thoi_gian === date);
                    if (!row) return null;
                    let rawVal = row[config.key];
                    if (rawVal === undefined && config.key.includes('Kbps')) rawVal = row[config.key.replace('Kbps', 'kbps')];
                    let val = parseFloat(rawVal);
                    return isNaN(val) ? null : val; 
                });

                return {
                    label: cellName,
                    data: dataPoints,
                    borderColor: color,
                    backgroundColor: color + '22',
                    borderWidth: 2,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: color,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    tension: 0.3,
                    fill: false, 
                    spanGaps: true 
                };
            });

            window.chartDataStore[canvasId] = {
                labels: allDates,
                datasets: datasets.map(ds => ({ label: ds.label, data: ds.data, borderColor: ds.borderColor, backgroundColor: ds.backgroundColor })),
                title: config.title
            };

            const ctx = document.getElementById(canvasId).getContext('2d');
            window.chartInstances[canvasId] = new Chart(ctx, {
                type: 'line',
                data: { labels: allDates, datasets: datasets },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: {
                        title: { display: true, text: config.title, font: { size: 14, weight: 'bold' }, color: '#34495e', padding: { bottom: 15 } },
                        legend: { display: datasets.length > 1, position: 'bottom', labels: { boxWidth: 12, font: { size: 11 } } },
                        tooltip: { mode: 'index', intersect: false } 
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 12 } },
                        y: { beginAtZero: true, grid: { borderDash: [5, 5] } }
                    }
                }
            });
        });
    }

    function openModal(canvasId) {
        const dataStore = window.chartDataStore[canvasId];
        if (!dataStore) return;

        const modal = document.getElementById('chartModal');
        modal.classList.add('show'); 

        setTimeout(() => {
            const ctx = document.getElementById('modalCanvas').getContext('2d');
            
            if (modalChartInstance) {
                modalChartInstance.destroy(); 
            }

            const zoomedDatasets = dataStore.datasets.map(ds => ({
                label: ds.label,
                data: [...ds.data], 
                borderColor: ds.borderColor,
                backgroundColor: ds.backgroundColor,
                borderWidth: 3, 
                pointBackgroundColor: '#ffffff',
                pointBorderColor: ds.borderColor,
                pointBorderWidth: 2,
                pointRadius: 5,
                pointHoverRadius: 8,
                fill: false,
                tension: 0.3,
                spanGaps: true
            }));

            modalChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: dataStore.labels,
                    datasets: zoomedDatasets
                },
                options: {
                    responsive: true, 
                    maintainAspectRatio: false, 
                    animation: { duration: 600, easing: 'easeOutQuart' },
                    plugins: {
                        title: { display: true, text: dataStore.title, font: { size: 22, weight: 'bold' }, color: '#2c3e50', padding: { bottom: 20 } },
                        legend: { display: zoomedDatasets.length > 1, position: 'bottom', labels: { font: { size: 14 } } },
                        tooltip: {
                            mode: 'index', intersect: false,
                            backgroundColor: 'rgba(44, 62, 80, 0.95)', titleFont: { size: 16 }, bodyFont: { size: 16, weight: 'bold' }, 
                            padding: 15, cornerRadius: 8, displayColors: true
                        }
                    },
                    scales: {
                        x: { grid: { display: false }, ticks: { maxTicksLimit: 20, font: { size: 14 } } },
                        y: { beginAtZero: true, grid: { borderDash: [5, 5], color: '#ecf0f1' }, ticks: { font: { size: 14 } } }
                    }
                }
            });
        }, 50); 
    }

    function closeModal() { document.getElementById('chartModal').classList.remove('show'); }
    window.onclick = function(e) { if (e.target === document.getElementById('chartModal')) closeModal(); }
</script>
</body>
</html>
