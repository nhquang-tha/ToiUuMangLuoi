<%- include('partials/head') %>
<div class="layout">
    <%- include('partials/sidebar') %>
    <main class="main-content">
        <header class="topbar">
            <h1><%= page %></h1>
        </header>
        <div class="content-body">
            
            <div class="card" style="margin-bottom: 20px;">
                <form id="kpiSearchForm" style="display: flex; gap: 15px; align-items: flex-end;">
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Công Nghệ</label>
                        <select id="networkSelect" class="form-control" required style="width: 150px; padding: 10px;">
                            <option value="3g">Mạng 3G</option>
                            <option value="4g">Mạng 4G</option>
                            <option value="5g">Mạng 5G</option>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom: 0; flex: 1; max-width: 400px;">
                        <label>Tên Cell (Cell Name)</label>
                        <input type="text" id="cellInput" class="form-control" placeholder="Ví dụ: 3G_TXN026M23_THA hoặc 4G-HHA021M41-THA" required style="padding: 10px; width: 100%;">
                    </div>
                    <button type="submit" class="btn-primary" style="width: auto; padding: 10px 20px;">Xem Biểu Đồ</button>
                </form>
                <div id="statusMessage" style="margin-top: 15px; font-weight: bold;"></div>
            </div>

            <div id="chartsContainer" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 20px;">
                <!-- HTML của các biểu đồ sẽ được tự động chèn vào đây -->
            </div>

        </div>
    </main>
</div>

<!-- MODAL POPUP PHÓNG TO BIỂU ĐỒ KHI CLICK -->
<div id="chartModal" style="display:none; position:fixed; z-index:9999; left:0; top:0; width:100%; height:100%; overflow:auto; background-color:rgba(0,0,0,0.85); backdrop-filter: blur(4px);">
    <div style="background-color:#fff; margin: 3% auto; padding: 25px; width: 90%; max-width: 1200px; border-radius: 12px; position: relative; box-shadow: 0 5px 15px rgba(0,0,0,0.5);">
        <span id="closeModal" style="position:absolute; right:20px; top:15px; color:#555; font-size:32px; font-weight:bold; cursor:pointer; line-height:1;">&times;</span>
        <h2 id="modalTitle" style="text-align:center; margin-top:0; margin-bottom:20px; color:#2c3e50;">Chi Tiết Biểu Đồ</h2>
        <div style="width:100%; height:70vh; position:relative;">
            <canvas id="modalCanvas"></canvas>
        </div>
    </div>
</div>

<!-- KỸ THUẬT NHÚNG AN TOÀN: Ghép chuỗi thủ công để chống Chat tự động tạo link làm hỏng code -->
<script>
    (function() {
        var scriptTag = document.createElement('script');
        var p1 = 'https://';
        var p2 = 'cdn.jsdelivr.net';
        var p3 = '/npm/chart.js';
        scriptTag.src = p1 + p2 + p3;
        document.head.appendChild(scriptTag);
    })();
</script>

<script>
    // Hàm Parse ngày siêu cấp cứu cánh: Lọc sạch mọi rác bằng Regex để lấy đúng Timestamp
    function parseDateStr(dateStr) {
        if (!dateStr) return 0;
        const matches = String(dateStr).match(/\d+/g);
        if (matches && matches.length >= 3) {
            let year = matches[0].length === 4 ? matches[0] : matches[2];
            let month = matches[1];
            let day = matches[0].length === 4 ? matches[2] : matches[0];
            return new Date(Number(year), Number(month) - 1, Number(day)).getTime();
        }
        return 0;
    }

    // Hàm chuẩn hóa chuỗi X-axis cho đẹp và đồng nhất (DD/MM/YYYY)
    function formatDateLabel(dateStr) {
        if (!dateStr) return 'N/A';
        const matches = String(dateStr).match(/\d+/g);
        if (matches && matches.length >= 3) {
            let year = matches[0].length === 4 ? matches[0] : matches[2];
            let month = matches[1];
            let day = matches[0].length === 4 ? matches[2] : matches[0];
            return `${day.padStart(2, '0')}/${month.padStart(2, '0')}/${year}`;
        }
        return String(dateStr).trim();
    }

    // Đóng Popup khi ấn X hoặc click ra bên ngoài
    document.getElementById('closeModal').onclick = function() {
        document.getElementById('chartModal').style.display = 'none';
    };
    window.onclick = function(event) {
        if (event.target == document.getElementById('chartModal')) {
            document.getElementById('chartModal').style.display = 'none';
        }
    };

    document.getElementById('kpiSearchForm').addEventListener('submit', async function(e) {
        e.preventDefault(); 
        
        const network = document.getElementById('networkSelect').value;
        const cellName = document.getElementById('cellInput').value.trim();
        const statusMsg = document.getElementById('statusMessage');
        const chartsContainer = document.getElementById('chartsContainer');

        if (!cellName) return;

        statusMsg.style.color = 'blue';
        statusMsg.textContent = 'Đang tải dữ liệu...';
        chartsContainer.innerHTML = '';

        try {
            // Đảm bảo Chart.js đã được tải
            if (typeof Chart === 'undefined') {
                statusMsg.style.color = 'orange';
                statusMsg.textContent = 'Đang khởi tạo thư viện biểu đồ, vui lòng chờ giây lát...';
                await new Promise(r => setTimeout(r, 1500)); 
                if (typeof Chart === 'undefined') {
                    throw new Error("Không thể tải thư viện Chart.js. Vui lòng kiểm tra kết nối internet.");
                }
            }

            const response = await fetch(`/api/kpi-data?network=${network}&cellName=${encodeURIComponent(cellName)}`);
            const data = await response.json();

            if (data.error) {
                statusMsg.style.color = 'red';
                statusMsg.textContent = data.error;
                return;
            }

            if (data.length === 0) {
                statusMsg.style.color = 'red';
                statusMsg.textContent = `Không tìm thấy dữ liệu KPI nào cho Cell: "${cellName}" trong mạng ${network.toUpperCase()}.`;
                return;
            }

            statusMsg.style.color = 'green';
            statusMsg.textContent = `Tìm thấy ${data.length} bản ghi dữ liệu cho Cell: ${cellName}.`;

            // THUẬT TOÁN SẮP XẾP CHÍNH XÁC TĂNG DẦN: (a - b) Tuần tự từ cũ đến mới dựa trên Timestamp đã bóc tách
            data.sort((a, b) => parseDateStr(a.Thoi_gian) - parseDateStr(b.Thoi_gian));

            // Map nhãn trục X (Đã được chuẩn hóa DD/MM/YYYY)
            const labels = data.map(row => formatDateLabel(row.Thoi_gian));

            let chartConfigs = [];
            if (network === '3g') {
                chartConfigs = [
                    { key: 'PSTRAFFIC', title: 'PS TRAFFIC', color: '#3498db' },
                    { key: 'PSCONGES', title: 'PS CONGES', color: '#e74c3c' },
                    { key: 'TRAFFIC', title: 'TRAFFIC', color: '#2ecc71' },
                    { key: 'CSCONGES', title: 'CS CONGES', color: '#f1c40f' }
                ];
            } else if (network === '4g') {
                chartConfigs = [
                    { key: 'Total_Data_Traffic_Volume_GB', title: 'TRAFFIC (GB)', color: '#3498db' },
                    { key: 'User_DL_Avg_Throughput_kbps', title: 'USER DL AVG THPUT (kbps)', color: '#9b59b6' },
                    { key: 'RB_Util_Rate_DL', title: 'RES BLK DL (%)', color: '#e67e22' },
                    { key: 'CQI_4G', title: 'CQI 4G', color: '#34495e' } 
                ];
            } else if (network === '5g') {
                chartConfigs = [
                    { key: 'Total_Data_Traffic_Volume_GB', title: 'TRAFFIC (GB)', color: '#3498db' },
                    { key: 'Cell_DL_Avg_Throughput', title: 'CELL DL AVG THROUGHPUT', color: '#1abc9c' },
                    { key: 'CQI_5G', title: 'CQI 5G', color: '#e74c3c' }
                ];
            }

            chartConfigs.forEach((cfg) => {
                // Trích xuất các chỉ số theo đúng trục thời gian
                const dataPoints = data.map(row => parseFloat(row[cfg.key]) || 0);

                const chartWrapper = document.createElement('div');
                chartWrapper.className = 'card';
                chartWrapper.style.padding = '15px';
                chartWrapper.style.cursor = 'pointer';
                chartWrapper.style.transition = 'transform 0.2s, box-shadow 0.2s';
                chartWrapper.title = "Click để phóng to biểu đồ này";
                
                // Hiệu ứng Hover khi trỏ chuột
                chartWrapper.onmouseover = function() {
                    this.style.transform = 'scale(1.02)';
                    this.style.boxShadow = '0 8px 16px rgba(0,0,0,0.15)';
                };
                chartWrapper.onmouseout = function() {
                    this.style.transform = 'scale(1)';
                    this.style.boxShadow = '0 4px 6px rgba(0,0,0,0.05)'; // Box shadow chuẩn của Card
                };

                const chartTitle = document.createElement('h3');
                chartTitle.textContent = cfg.title;
                chartTitle.style.textAlign = 'center';
                chartTitle.style.marginBottom = '10px';
                chartTitle.style.color = '#333';
                
                const canvas = document.createElement('canvas');

                chartWrapper.appendChild(chartTitle);
                chartWrapper.appendChild(canvas);
                chartsContainer.appendChild(chartWrapper);

                // Khởi tạo Chart dạng nhỏ
                new Chart(canvas, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: cfg.title,
                            data: dataPoints,
                            borderColor: cfg.color,
                            backgroundColor: cfg.color + '33',
                            borderWidth: 2,
                            fill: true,
                            tension: 0.3,
                            pointBackgroundColor: cfg.color,
                            pointRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true } }
                    }
                });

                // LOGIC PHÓNG TO POPUP KHI CLICK VÀO BIỂU ĐỒ NÀY
                chartWrapper.onclick = function() {
                    document.getElementById('chartModal').style.display = 'block';
                    document.getElementById('modalTitle').textContent = cfg.title + " (" + cellName + ")";
                    
                    // Xóa instance cũ của Popup Chart nếu có để không bị đè dữ liệu
                    if (window.modalChartInstance) {
                        window.modalChartInstance.destroy();
                    }
                    
                    const ctx = document.getElementById('modalCanvas').getContext('2d');
                    window.modalChartInstance = new Chart(ctx, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: cfg.title,
                                data: dataPoints,
                                borderColor: cfg.color,
                                backgroundColor: cfg.color + '33',
                                borderWidth: 3,
                                fill: true,
                                tension: 0.3,
                                pointBackgroundColor: cfg.color,
                                pointRadius: 6,
                                pointHoverRadius: 9
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false, // Phóng to thả ga full container
                            plugins: { 
                                legend: { display: false },
                                tooltip: {
                                    mode: 'index',
                                    intersect: false,
                                    titleFont: { size: 14 },
                                    bodyFont: { size: 14 },
                                    padding: 10
                                }
                            },
                            scales: { 
                                y: { beginAtZero: true, ticks: { font: { size: 14 } } },
                                x: { ticks: { font: { size: 13 } } }
                            }
                        }
                    });
                };
            });

        } catch (error) {
            console.error(error);
            statusMsg.style.color = 'red';
            statusMsg.textContent = 'Lỗi hệ thống khi vẽ biểu đồ: ' + error.message;
        }
    });
</script>
</body>
</html>
