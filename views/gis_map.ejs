    function extractCoreName(name) {
        if (!name) return '';
        return String(name).toUpperCase().replace(/^(3G|4G|5G)[-\s_]?/i, '').replace(/[-\s_]?(THA|TH)$/i, '').substring(0, 6);
    }

    function getHeatmapColor(ratio) {
        if (ratio >= 0.8) return { fill: '#e74c3c', border: '#c0392b' }; 
        if (ratio >= 0.6) return { fill: '#e67e22', border: '#d35400' }; 
        if (ratio >= 0.4) return { fill: '#f1c40f', border: '#f39c12' }; 
        if (ratio >= 0.2) return { fill: '#2ecc71', border: '#27ae60' }; 
        return { fill: '#3498db', border: '#2980b9' }; 
    }

    function createTASegment(lat, lng, azimuth, innerRadius, outerRadius, beamwidth, ratio, cellCode, taIndex, ueCount) {
        const points = [];
        const startAngle = azimuth - beamwidth / 2;
        const endAngle = azimuth + beamwidth / 2;

        for (let i = startAngle; i <= endAngle; i += 15) points.push(getDestination(lat, lng, i, outerRadius));
        points.push(getDestination(lat, lng, endAngle, outerRadius));

        if (innerRadius > 0) {
            for (let i = endAngle; i >= startAngle; i -= 15) points.push(getDestination(lat, lng, i, innerRadius));
            points.push(getDestination(lat, lng, startAngle, innerRadius));
        } else {
            points.push([lat, lng]);
        }

        const colors = getHeatmapColor(ratio);
        let polygon = L.polygon(points, { color: colors.border, weight: 0.5, fillColor: colors.fill, fillOpacity: 0.75 });
        polygon.originalStyle = { color: colors.border, weight: 0.5, fillColor: colors.fill, fillOpacity: 0.75 };

        polygon.bindPopup(`
            <div style="font-family:Arial; min-width:200px;">
                <h4 style="margin:0 0 5px 0; color:${colors.fill}; border-bottom:2px solid ${colors.fill}; padding-bottom:5px; font-size:14px;">📍 Mật Độ Timing Advance</h4>
                <div style="font-size:12px; color:var(--text-main); line-height:1.6;">
                    <b>Cell:</b> <span style="color:#2980b9; font-weight:bold;">${cellCode}</span><br>
                    <b>Chỉ số TA Index:</b> <b>${taIndex}</b><br>
                    <b>Bán kính vùng:</b> ${innerRadius.toFixed(0)}m - ${outerRadius.toFixed(0)}m<br>
                    <div style="background:var(--bg-body); padding:6px; margin-top:6px; border-radius:4px; text-align:center;">
                        <span style="display:block; font-size:11px; color:var(--text-muted);">Số lượng người dùng (UE)</span>
                        <span style="color:${colors.fill}; font-size:18px; font-weight:bold;">${ueCount}</span>
                    </div>
                </div>
            </div>
        `);
        return polygon;
    }

