<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    
    .map-header { background: white; padding: 15px 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); z-index: 10; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;}
    .map-header h1 { margin: 0; font-size: 20px; color: #2c3e50; font-weight: bold; white-space: nowrap;}
    
    .map-controls { display: flex; gap: 15px; align-items: center; flex-wrap: wrap;}
    .map-controls select { padding: 9px 15px; border-radius: 4px; border: 1px solid #bdc3c7; outline: none; font-weight: bold; color: #2c3e50; cursor: pointer; }
    
    .search-box { display: flex; align-items: center; border: 2px solid #3498db; border-radius: 6px; overflow: hidden; background: white;}
    .search-box input { border: none; padding: 9px 15px; width: 250px; outline: none; font-size: 14px; }
    .search-box button { border: none; background: #3498db; color: white; padding: 9px 15px; cursor: pointer; font-weight: bold; transition: 0.2s; }
    .search-box button:hover { background: #2980b9; }

    .map-wrapper { position: relative; flex: 1; display: flex; flex-direction: column; height: 100%; width: 100%; }
    #map { flex: 1; height: 100%; width: 100%; z-index: 1; background: #e5e3df; }
    
    #mapLoading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(255,255,255,0.9); padding: 20px 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); z-index: 1000; display: none; text-align: center; font-weight: bold; color: #2980b9; }
    @keyframes spin { 100% { transform: rotate(360deg); } }

    .rf-popup-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .rf-popup-table th, .rf-popup-table td { padding: 6px; border: 1px solid #ecf0f1; text-align: left; }
    .rf-popup-table th { background: #f8f9fa; color: #34495e; width: 45%; font-weight: bold; }
    .rf-popup-table tr:hover { background: #f4f6f8; }
    .rf-popup-container { max-height: 280px; overflow-y: auto; overflow-x: hidden; border: 1px solid #bdc3c7; border-radius: 4px; margin-top: 10px;}
    .rf-popup-container::-webkit-scrollbar { width: 6px; }
    .rf-popup-container::-webkit-scrollbar-track { background: #f1f1f1; }
    .rf-popup-container::-webkit-scrollbar-thumb { background: #bdc3c7; border-radius: 3px; }

    .custom-leaflet-btn a { font-size: 18px !important; line-height: 30px !important; text-align: center; text-decoration: none; color: #333; display: block; width: 30px; height: 30px; }
    .custom-leaflet-btn a:hover { background-color: #f4f4f4; color: #2980b9; }

    .info.legend { background: white; padding: 12px 18px; border-radius: 8px; box-shadow: 0 3px 10px rgba(0,0,0,0.3); font-size: 12px; line-height: 20px; color: #333; min-width: 200px; }
    .info.legend h4 { margin: 0 0 12px 0; color: #2c3e50; border-bottom: 2px solid #3498db; padding-bottom: 5px; font-size: 14px; font-weight: bold;}

    .slider-control { background: white; padding: 12px 15px; border-radius: 6px; box-shadow: 0 1px 5px rgba(0,0,0,0.4); width: 220px; }
    .slider-control input[type=range] { -webkit-appearance: none; width: 100%; margin: 8px 0; background: transparent; }
    .slider-control input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 6px; cursor: pointer; background: #bdc3c7; border-radius: 3px; }
    .slider-control input[type=range]::-webkit-slider-thumb { height: 16px; width: 16px; border-radius: 50%; background: #3498db; cursor: pointer; -webkit-appearance: none; margin-top: -5px; }

    /* Custom CSS cho Tool Azimuth */
    .azi-tool-container { position: relative; }
    .azi-sub-menu {
        display: none; position: absolute; left: 36px; top: 0; background: white; border-radius: 6px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.2); width: 220px; z-index: 1000; flex-direction: column; border: 1px solid #bdc3c7; overflow: hidden;
    }
    .azi-sub-menu.show { display: flex; }
    .azi-menu-item { padding: 12px 15px; border-bottom: 1px solid #ecf0f1; cursor: pointer; font-size: 13px; font-weight: bold; color: #2c3e50; transition: 0.2s;}
    .azi-menu-item:hover { background: #f4f6f8; color: #2980b9; }
    .azi-menu-item:last-child { border-bottom: none; }
    
    .azi-end-icon { background: #e74c3c; border: 2px solid #fff; border-radius: 50%; box-shadow: 0 0 5px rgba(0,0,0,0.5); }
    .azi-permanent-label { background: rgba(255,255,255,0.9); border: 2px solid #8e44ad; border-radius: 6px; font-size: 11px; padding: 4px 8px; font-weight: bold; white-space: nowrap; box-shadow: 0 2px 5px rgba(0,0,0,0.2);}
    .leaflet-tooltip.azi-permanent-label::before { border-right-color: #8e44ad; }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        
        <div class="map-header">
            <h1>Bản Đồ Vùng Phủ Sóng (GIS Map)</h1>
            <div class="map-controls">
                <input type="file" id="itsLogInput" accept=".txt,.csv" style="display: none;" onchange="processItsLog(event)">
                <button onclick="document.getElementById('itsLogInput').click()" class="btn-primary" style="background: #e67e22; color: white; border: none; padding: 9px 15px; border-radius: 4px; cursor: pointer; font-weight: bold;">
                    📥 Import Log ITS
                </button>

                <div class="search-box">
                    <input type="text" id="mapSearchInput" placeholder="Nhập Cell Code, Site Code..." onkeypress="if(event.key === 'Enter') searchMap()">
                    <button onclick="searchMap()">🔍 Tìm kiếm</button>
                </div>

                <label style="font-weight: bold; color: #7f8c8d; margin-left: 10px;">Lớp mạng:</label>
                <select id="networkSelect" onchange="loadMapData()">
                    <option value="4g" selected>Mạng 4G LTE</option>
                    <option value="3g">Mạng 3G WCDMA</option>
                    <option value="5g">Mạng 5G NR</option>
                </select>
                <button onclick="loadMapData()" class="btn-primary" style="background: #27ae60; color: white; border: none; padding: 9px 15px; border-radius: 4px; cursor: pointer; font-weight: bold;">
                    🔄 Tải Lại
                </button>
            </div>
        </div>
        
        <div class="map-wrapper" id="mapWrapper">
            <div id="mapLoading"><span style="display: inline-block; animation: spin 1s linear infinite; margin-right: 10px;">⏳</span> Đang xử lý dữ liệu...</div>
            <div id="map"></div>
        </div>

    </main>
</div>

<script>
    let globalPolygons = []; 
    let defaultBounds = [];  
    let globalLogLines = []; 
    let azimuthOrigins = {}; 
    let latestOriginId = null; // Lưu ID của điểm gốc mới nhất để nút Add Direction trên menu hoạt động
    
    let map = L.map('map').setView([19.806692, 105.776153], 10); 
    let layerGroup = L.layerGroup().addTo(map);
    let itsLogLayer = L.layerGroup().addTo(map); 
    let azimuthLayer = L.layerGroup().addTo(map); 
    let legendControl = null; 

    const googleStreets = L.tileLayer('http://mt0.google.com/vt/lyrs=m&hl=vi&x={x}&y={y}&z={z}', {
        attribution: 'Map data &copy; Google', maxZoom: 20
    });
    const googleHybrid = L.tileLayer('http://mt0.google.com/vt/lyrs=y&hl=vi&x={x}&y={y}&z={z}', {
        attribution: 'Map data &copy; Google', maxZoom: 20
    });

    googleStreets.addTo(map); 
    L.control.layers({
        "🌍 Google Map (Cơ bản)": googleStreets,
        "🛰️ Google Map (Vệ tinh)": googleHybrid
    }).addTo(map);

    // --- NÚT FULL SCREEN ---
    L.Control.FullScreen = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function(map) {
            let container = L.DomUtil.create('div', 'leaflet-bar leaflet-control custom-leaflet-btn');
            container.innerHTML = '<a href="#" title="Toàn màn hình">⛶</a>';
            container.onclick = function(e) {
                e.preventDefault();
                let mapElement = document.getElementById('mapWrapper');
                if (!document.fullscreenElement) { mapElement.requestFullscreen().catch(err => console.log(err)); } 
                else { document.exitFullscreen(); }
            }
            return container;
        }
    });
    map.addControl(new L.Control.FullScreen());

    // --- NÚT GPS ---
    let userMarker = null;
    L.Control.GPS = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function(map) {
            let container = L.DomUtil.create('div', 'leaflet-bar leaflet-control custom-leaflet-btn');
            container.innerHTML = '<a href="#" title="Vị trí của tôi">📍</a>';
            container.onclick = function(e) { e.preventDefault(); map.locate({setView: true, maxZoom: 15}); }
            return container;
        }
    });
    map.addControl(new L.Control.GPS());

    // --- NÚT AZIMUTH TOOL (MENU DROPDOWN) ---
    L.Control.AzimuthTool = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function(map) {
            let container = L.DomUtil.create('div', 'leaflet-bar leaflet-control custom-leaflet-btn azi-tool-container');
            container.innerHTML = `
                <a href="#" title="Công cụ vẽ tia Azimuth" onclick="toggleAziMenu(event)">🧭</a>
                <div id="aziSubMenu" class="azi-sub-menu">
                    <div class="azi-menu-item" onclick="createAzimuthOrigin('gps')">📍 Lấy điểm gốc trùng GPS</div>
                    <div class="azi-menu-item" onclick="createAzimuthOrigin('center')">🎯 Lấy gốc giữa màn hình</div>
                    <div class="azi-menu-item" style="color: #27ae60;" onclick="addDirectionToLatest()">➕ Add Direction</div>
                </div>
            `;
            // Ngăn chặn sự kiện click lọt xuống bản đồ
            L.DomEvent.disableClickPropagation(container);
            return container;
        }
    });
    map.addControl(new L.Control.AzimuthTool());

    // Đóng/Mở menu Azimuth
    window.toggleAziMenu = function(e) {
        e.preventDefault();
        let menu = document.getElementById('aziSubMenu');
        menu.classList.toggle('show');
    };
    // Đóng menu khi click ra ngoài bản đồ
    map.on('click', function() {
        let menu = document.getElementById('aziSubMenu');
        if(menu && menu.classList.contains('show')) menu.classList.remove('show');
    });

    // --- SLIDER ĐIỀU CHỈNH ---
    L.Control.Sliders = L.Control.extend({
        options: { position: 'bottomleft' },
        onAdd: function (map) {
            let div = L.DomUtil.create('div', 'info legend leaflet-control slider-control');
            div.innerHTML = `
                <div style="margin-bottom: 12px;">
                    <label style="font-size: 13px; font-weight: bold; color: #2c3e50;">Kích thước Điểm Đo ITS: <span id="markerSizeVal" style="color:#e67e22">3.5</span></label><br>
                    <input type="range" id="markerSizeSlider" min="1" max="10" step="0.5" value="3.5">
                </div>
                <div>
                    <label style="font-size: 13px; font-weight: bold; color: #2c3e50;">Bán kính Cánh Quạt Cell: <span id="sectorSizeVal" style="color:#2980b9">100%</span></label><br>
                    <input type="range" id="sectorSizeSlider" min="10" max="300" step="10" value="100">
                </div>
            `;
            L.DomEvent.disableClickPropagation(div);
            L.DomEvent.disableScrollPropagation(div);
            return div;
        }
    });
    map.addControl(new L.Control.Sliders());

    document.getElementById('markerSizeSlider').addEventListener('input', function(e) {
        let size = parseFloat(e.target.value);
        document.getElementById('markerSizeVal').innerText = size;
        itsLogLayer.eachLayer(function(layer) {
            if (layer instanceof L.CircleMarker) layer.setRadius(size);
        });
    });

    document.getElementById('sectorSizeSlider').addEventListener('input', function(e) {
        let scale = parseFloat(e.target.value) / 100;
        document.getElementById('sectorSizeVal').innerText = e.target.value + '%';
        
        globalPolygons.forEach(item => {
            let newPoints = calculateSectorPoints(item.lat, item.lng, item.azimuth, item.baseRadius, scale);
            item.polygon.setLatLngs(newPoints);
        });

        globalLogLines.forEach(item => {
            let newArcCenter = getDestination(item.cellObj.lat, item.cellObj.lng, item.cellObj.azimuth, item.cellObj.baseRadius * scale);
            item.line.setLatLngs([[item.startLat, item.startLng], newArcCenter]);
        });
    });

    map.on('locationfound', function(e) {
        if (userMarker) map.removeLayer(userMarker);
        userMarker = L.circleMarker(e.latlng, { radius: 8, fillColor: "#2980b9", color: "#fff", weight: 2, opacity: 1, fillOpacity: 0.8 }).addTo(map).bindPopup("📍 Bạn đang ở đây!").openPopup();
    });

    document.addEventListener('fullscreenchange', () => { setTimeout(() => map.invalidateSize(), 200); });
    setTimeout(() => { map.invalidateSize(); }, 500);


    // ====================================================
    // CÔNG CỤ AZIMUTH ĐỘNG (INTERACTIVE AZIMUTH TOOL)
    // ====================================================
    
    function getBearing(startLat, startLng, destLat, destLng) {
        startLat = startLat * Math.PI / 180;
        startLng = startLng * Math.PI / 180;
        destLat = destLat * Math.PI / 180;
        destLng = destLng * Math.PI / 180;

        let y = Math.sin(destLng - startLng) * Math.cos(destLat);
        let x = Math.cos(startLat) * Math.sin(destLat) - Math.sin(startLat) * Math.cos(destLat) * Math.cos(destLng - startLng);
        let brng = Math.atan2(y, x);
        brng = brng * 180 / Math.PI;
        return (brng + 360) % 360;
    }

    // Khởi tạo điểm Gốc từ Menu
    window.createAzimuthOrigin = function(type) {
        document.getElementById('aziSubMenu').classList.remove('show'); // Đóng menu
        
        let center;
        if (type === 'gps') {
            if (userMarker) {
                center = userMarker.getLatLng();
            } else {
                alert("Chưa có tín hiệu GPS! Hãy bấm biểu tượng Định Vị 📍 trước để lấy GPS.");
                return;
            }
        } else {
            center = map.getCenter();
        }

        let marker = L.marker(center, {draggable: true}).addTo(azimuthLayer);
        let id = marker._leaflet_id;
        latestOriginId = id; // Lưu ID để dùng cho nút Add Direction chung

        azimuthOrigins[id] = { marker: marker, lines: [], name: "Trạm Gốc " + id };

        function updatePopup() {
            let pos = marker.getLatLng();
            let html = `
                <div style="min-width: 220px; font-family: Arial;">
                    <h4 style="margin-top:0; color:#2980b9; border-bottom:1px solid #ddd; padding-bottom:5px;">📍 Cấu Hình Điểm Gốc</h4>
                    <div style="margin-bottom: 8px;">
                        <label style="font-size:12px; font-weight:bold;">Tên gợi nhớ:</label>
                        <input type="text" id="origName_${id}" value="${azimuthOrigins[id].name}" style="width:100%; padding:5px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box;">
                    </div>
                    <div style="margin-bottom: 8px;">
                        <label style="font-size:12px; font-weight:bold;">Vĩ độ (Lat):</label>
                        <input type="number" step="0.000001" id="origLat_${id}" value="${pos.lat.toFixed(6)}" style="width:100%; padding:5px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box;">
                    </div>
                    <div style="margin-bottom: 12px;">
                        <label style="font-size:12px; font-weight:bold;">Kinh độ (Lng):</label>
                        <input type="number" step="0.000001" id="origLng_${id}" value="${pos.lng.toFixed(6)}" style="width:100%; padding:5px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box;">
                    </div>
                    <button onclick="updateOrigin(${id})" style="background:#2980b9; color:#fff; border:none; padding:8px; width:100%; border-radius:4px; font-weight:bold; cursor:pointer; margin-bottom:8px;">💾 Áp dụng Tọa độ</button>
                    <button onclick="addDirection(${id})" style="background:#27ae60; color:#fff; border:none; padding:8px; width:100%; border-radius:4px; font-weight:bold; cursor:pointer;">➕ Add Direction</button>
                </div>
            `;
            marker.bindPopup(html);
        }
        
        updatePopup();
        marker.on('dragend', function() {
            updatePopup();
            redrawLines(id); 
        });
        marker.openPopup();
    };

    // Hàm gọi Add Direction từ Sub Menu
    window.addDirectionToLatest = function() {
        document.getElementById('aziSubMenu').classList.remove('show');
        if (latestOriginId && azimuthOrigins[latestOriginId]) {
            addDirection(latestOriginId);
        } else {
            alert("Vui lòng tạo một Điểm Gốc (Trùng GPS hoặc Giữa bản đồ) trước khi Add Direction!");
        }
    };

    // Hàm cập nhật chữ hiển thị trực tiếp trên map
    function updatePermanentLabel(marker, name, az) {
        marker.setTooltipContent(`
            <div style="text-align:center; line-height:1.2;">
                <b style="color:#8e44ad; font-size:12px;">${name}</b><br>
                <span style="color:#e74c3c; font-weight:bold;">${az.toFixed(1)}°</span>
            </div>
        `);
    }

    // Thêm Tia hướng phát (Direction)
    window.addDirection = function(originId) {
        let originObj = azimuthOrigins[originId];
        let origPos = originObj.marker.getLatLng();

        let destCoords = getDestination(origPos.lat, origPos.lng, 0, 100);
        let endLatLng = L.latLng(destCoords[0], destCoords[1]);

        let endIcon = L.divIcon({className: 'azi-end-icon', iconSize: [12, 12], iconAnchor: [6, 6]});
        let endMarker = L.marker(endLatLng, {draggable: true, icon: endIcon}).addTo(azimuthLayer);
        
        let line = L.polyline([origPos, endLatLng], {color: '#8e44ad', weight: 2.5, opacity: 0.8}).addTo(azimuthLayer);

        let lineObj = { endMarker: endMarker, line: line, name: "Sector mới", azimuth: 0, distance: 100 };
        originObj.lines.push(lineObj);

        let endId = endMarker._leaflet_id;

        // HIỂN THỊ NHÃN PERMANENT (LUÔN LUÔN HIỆN)
        endMarker.bindTooltip("", {permanent: true, direction: "right", className: "azi-permanent-label", offset: [10, 0]}).openTooltip();
        updatePermanentLabel(endMarker, lineObj.name, lineObj.azimuth);

        function updateEndPopup() {
            let html = `
                <div style="min-width: 200px; font-family: Arial;">
                    <h4 style="margin-top:0; color:#8e44ad; border-bottom:1px solid #ddd; padding-bottom:5px;">🎯 Cấu Hình Tia</h4>
                    <div style="margin-bottom: 8px;">
                        <label style="font-size:12px; font-weight:bold;">Tên Sector:</label>
                        <input type="text" id="endName_${endId}" value="${lineObj.name}" style="width:100%; padding:5px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box;">
                    </div>
                    <div style="margin-bottom: 8px;">
                        <label style="font-size:12px; font-weight:bold;">Góc Azimuth (°):</label>
                        <input type="number" id="endAz_${endId}" value="${lineObj.azimuth.toFixed(1)}" style="width:100%; padding:5px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box;">
                    </div>
                    <div style="margin-bottom: 12px;">
                        <label style="font-size:12px; font-weight:bold;">Khoảng cách (m):</label>
                        <input type="number" id="endDist_${endId}" value="${lineObj.distance.toFixed(1)}" style="width:100%; padding:5px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box;">
                    </div>
                    <button onclick="updateEndMarker(${originId}, ${endId})" style="background:#8e44ad; color:#fff; border:none; padding:8px; width:100%; border-radius:4px; font-weight:bold; cursor:pointer;">Lưu Thông Số</button>
                </div>
            `;
            endMarker.bindPopup(html);
        }
        updateEndPopup();

        // Hiển thị Realtime khi kéo thả
        endMarker.on('drag', function(e) {
            let currentPos = e.target.getLatLng();
            let op = originObj.marker.getLatLng();
            line.setLatLngs([op, currentPos]);

            let dist = map.distance(op, currentPos);
            let az = getBearing(op.lat, op.lng, currentPos.lat, currentPos.lng);

            lineObj.distance = dist;
            lineObj.azimuth = az;

            // Cập nhật nhãn permanent liên tục khi kéo
            updatePermanentLabel(endMarker, lineObj.name, az);
        });

        endMarker.on('dragend', function() {
            updateEndPopup();
        });
    };

    // Hàm cập nhật điểm gốc
    window.updateOrigin = function(id) {
        let name = document.getElementById('origName_'+id).value;
        let lat = parseFloat(document.getElementById('origLat_'+id).value);
        let lng = parseFloat(document.getElementById('origLng_'+id).value);
        
        if(isNaN(lat) || isNaN(lng)) return alert("Tọa độ không hợp lệ!");

        let obj = azimuthOrigins[id];
        obj.name = name;
        let newLatLng = L.latLng(lat, lng);
        obj.marker.setLatLng(newLatLng);
        
        map.setView(newLatLng, 17); 
        redrawLines(id);
    };

    // Vẽ lại các tia khi điểm gốc bị di chuyển
    window.redrawLines = function(originId) {
        let obj = azimuthOrigins[originId];
        let origPos = obj.marker.getLatLng();
        
        obj.lines.forEach(lObj => {
            let newCoords = getDestination(origPos.lat, origPos.lng, lObj.azimuth, lObj.distance);
            let newLatLng = L.latLng(newCoords[0], newCoords[1]);
            
            lObj.endMarker.setLatLng(newLatLng);
            lObj.line.setLatLngs([origPos, newLatLng]);
            updatePermanentLabel(lObj.endMarker, lObj.name, lObj.azimuth);

            let currentHtml = lObj.endMarker.getPopup().getContent();
            lObj.endMarker.setPopupContent(currentHtml);
        });
        obj.marker.closePopup(); 
    };

    // Hàm cập nhật tia từ dữ liệu người dùng nhập
    window.updateEndMarker = function(originId, endId) {
        let obj = azimuthOrigins[originId];
        let lObj = obj.lines.find(l => l.endMarker._leaflet_id === endId);
        
        lObj.name = document.getElementById('endName_'+endId).value;
        lObj.azimuth = parseFloat(document.getElementById('endAz_'+endId).value);
        lObj.distance = parseFloat(document.getElementById('endDist_'+endId).value);

        let origPos = obj.marker.getLatLng();
        let newCoords = getDestination(origPos.lat, origPos.lng, lObj.azimuth, lObj.distance);
        let newLatLng = L.latLng(newCoords[0], newCoords[1]);

        lObj.endMarker.setLatLng(newLatLng);
        lObj.line.setLatLngs([origPos, newLatLng]);
        
        updatePermanentLabel(lObj.endMarker, lObj.name, lObj.azimuth);
        lObj.endMarker.closePopup();
    };


    // ====================================================
    // THUẬT TOÁN TÍNH TOÁN LƯỢNG GIÁC: VẼ CÁNH QUẠT (CELL)
    // ====================================================
    function getDestination(lat, lng, azimuth, distanceMeters) {
        const R = 6378137; 
        const brng = azimuth * Math.PI / 180;
        const lat1 = lat * Math.PI / 180;
        const lon1 = lng * Math.PI / 180;
        const lat2 = Math.asin(Math.sin(lat1) * Math.cos(distanceMeters/R) + Math.cos(lat1) * Math.sin(distanceMeters/R) * Math.cos(brng));
        const lon2 = lon1 + Math.atan2(Math.sin(brng) * Math.sin(distanceMeters/R) * Math.cos(lat1), Math.cos(distanceMeters/R) - Math.sin(lat1) * Math.sin(lat2));
        return [lat2 * 180 / Math.PI, lon2 * 180 / Math.PI];
    }

    function calculateSectorPoints(lat, lng, azimuth, baseRadius, scale) {
        let radius = baseRadius * scale;
        const beamwidth = 65; 
        const center = [lat, lng];
        const points = [center];
        const startAngle = azimuth - beamwidth / 2;
        const endAngle = azimuth + beamwidth / 2;

        for (let i = startAngle; i <= endAngle; i += 5) points.push(getDestination(lat, lng, i, radius));
        points.push(getDestination(lat, lng, endAngle, radius));
        points.push(center);
        return points;
    }

    function createSector(lat, lng, azimuth, cellName, networkType, rfData, baseRadius, scale) {
        let color = '#e74c3c'; 
        if (networkType === '3g') color = '#f1c40f'; 
        if (networkType === '5g') color = '#3498db'; 

        const points = calculateSectorPoints(lat, lng, azimuth, baseRadius, scale);
        
        const polygon = L.polygon(points, { color: color, weight: 1.5, fillColor: color, fillOpacity: 0.55 });

        let tableHtml = `<div class="rf-popup-container"><table class="rf-popup-table">`;
        if (Array.isArray(rfData)) {
            rfData.forEach(item => tableHtml += `<tr><th>${item.key}</th><td>${item.value}</td></tr>`);
        }
        tableHtml += `</table></div>`;

        polygon.bindPopup(`
            <div style="font-family: Arial; min-width: 320px;">
                <h4 style="margin: 0 0 5px 0; color: ${color}; border-bottom: 2px solid ${color}; padding-bottom: 5px;">📡 Cell: ${cellName}</h4>
                <div style="font-size: 12px; color: #7f8c8d;"><strong>Tọa độ:</strong> ${lat.toFixed(5)}, ${lng.toFixed(5)} &nbsp;|&nbsp; <strong>Góc phát:</strong> ${azimuth}°</div>
                ${tableHtml}
            </div>
        `, { maxWidth: 500 });
        
        return polygon;
    }

    async function loadMapData() {
        const network = document.getElementById('networkSelect').value;
        const loading = document.getElementById('mapLoading');
        
        loading.style.display = 'block';
        layerGroup.clearLayers();
        itsLogLayer.clearLayers(); 
        azimuthLayer.clearLayers(); 
        azimuthOrigins = {};
        latestOriginId = null;
        if (legendControl) map.removeControl(legendControl); 
        
        globalPolygons = []; 
        globalLogLines = []; 
        defaultBounds = [];
        document.getElementById('mapSearchInput').value = ''; 

        let scale = parseFloat(document.getElementById('sectorSizeSlider').value) / 100;

        try {
            const response = await fetch(`/api/gis-data?network=${network}`);
            const data = await response.json();

            if (data.length === 0) {
                loading.style.display = 'none';
                return alert('Không có dữ liệu tọa độ trạm cho mạng này!');
            }

            data.forEach(item => {
                if(item.lat && item.lng) {
                    let baseRadius = 250; 
                    if (network === '3g') baseRadius = 300; 
                    if (network === '5g') baseRadius = 150; 

                    const sector = createSector(item.lat, item.lng, item.azimuth, item.cell, network, item.rfData, baseRadius, scale);
                    sector.addTo(layerGroup);
                    defaultBounds.push([item.lat, item.lng]);
                    
                    globalPolygons.push({
                        cellStr: String(item.cell).toLowerCase(), siteStr: String(item.site).toLowerCase(),
                        polygon: sector, lat: item.lat, lng: item.lng, azimuth: item.azimuth, 
                        baseRadius: baseRadius, baseColor: sector.options.color,
                        rawData: item 
                    });
                }
            });

            if (defaultBounds.length > 0) map.fitBounds(defaultBounds);
            loading.style.display = 'none';

        } catch (error) {
            console.error(error);
            loading.style.display = 'none';
            alert('Lỗi truy xuất dữ liệu từ máy chủ!');
        }
    }

    function searchMap() {
        let keyword = document.getElementById('mapSearchInput').value.trim().toLowerCase();
        if (!keyword) {
            globalPolygons.forEach(item => {
                item.polygon.setStyle({ weight: 1.5, fillOpacity: 0.55, color: item.baseColor, fillColor: item.baseColor });
            });
            if (defaultBounds.length > 0) map.fitBounds(defaultBounds);
            return;
        }

        let matchedBounds = [];
        let matchCount = 0;

        globalPolygons.forEach(item => {
            let isMatch = item.cellStr.includes(keyword) || item.siteStr.includes(keyword);
            if (isMatch) {
                item.polygon.setStyle({ weight: 3, fillOpacity: 0.9, color: '#000000', fillColor: item.baseColor });
                item.polygon.bringToFront(); 
                matchedBounds.push([item.lat, item.lng]);
                if(matchCount === 0) item.polygon.openPopup();
                matchCount++;
            } else {
                item.polygon.setStyle({ weight: 0.5, fillOpacity: 0.15, color: item.baseColor, fillColor: item.baseColor });
            }
        });

        if (matchedBounds.length > 0) {
            if (matchedBounds.length === 1) map.setView(matchedBounds[0], 16);
            else map.fitBounds(matchedBounds, { padding: [50, 50], maxZoom: 16 });
        } else {
            alert(`Không tìm thấy Cell hoặc Site nào chứa từ khóa "${keyword}".`);
        }
    }

    // ====================================================
    // MODULE: ĐỌC VÀ VẼ LOG FILE ĐO KIỂM (ITS)
    // ====================================================
    
    function getColor4G(level) {
        if (level >= -80) return '#27ae60'; 
        if (level >= -90) return '#2980b9'; 
        if (level >= -100) return '#f1c40f'; 
        if (level >= -110) return '#e67e22'; 
        return '#c0392b'; 
    }

    function getColor3G(level) {
        if (level >= -75) return '#27ae60'; 
        if (level >= -85) return '#2980b9'; 
        if (level >= -95) return '#f1c40f'; 
        if (level >= -105) return '#e67e22'; 
        return '#c0392b'; 
    }

    function addLegend(is3G, is4G) {
        if (legendControl) map.removeControl(legendControl);
        
        legendControl = L.control({position: 'bottomright'});
        legendControl.onAdd = function (map) {
            let div = L.DomUtil.create('div', 'info legend');
            let labels = [];
            
            if (is4G) {
                div.innerHTML = '<h4>Mức thu RSRP 4G (dBm)</h4>';
                const ranges = [ 
                    {min: '', max: '-80', color: '#27ae60', desc: 'Rất tốt'}, 
                    {min: '-80', max: '-90', color: '#2980b9', desc: 'Tốt'}, 
                    {min: '-90', max: '-100', color: '#f1c40f', desc: 'Trung bình'}, 
                    {min: '-100', max: '-110', color: '#e67e22', desc: 'Yếu'}, 
                    {min: '-110', max: '', color: '#c0392b', desc: 'Rất yếu'} 
                ];
                ranges.forEach(r => {
                    let text = r.min === '' ? `>= ${r.max}` : (r.max === '' ? `< ${r.min}` : `${r.min} đến ${r.max}`);
                    labels.push(`
                        <div style="display: flex; align-items: center; margin-bottom: 6px;">
                            <i style="background:${r.color}; width: 16px; height: 16px; border-radius: 50%; border: 1px solid #7f8c8d; margin-right: 8px;"></i> 
                            <b style="width: 65px;">${text}</b> 
                            <span style="color:#7f8c8d; font-style:italic;">(${r.desc})</span>
                        </div>
                    `);
                });
            } else if (is3G) {
                div.innerHTML = '<h4>Mức thu RSCP 3G (dBm)</h4>';
                const ranges = [ 
                    {min: '', max: '-75', color: '#27ae60', desc: 'Rất tốt'}, 
                    {min: '-75', max: '-85', color: '#2980b9', desc: 'Tốt'}, 
                    {min: '-85', max: '-95', color: '#f1c40f', desc: 'Trung bình'}, 
                    {min: '-95', max: '-105', color: '#e67e22', desc: 'Yếu'}, 
                    {min: '-105', max: '', color: '#c0392b', desc: 'Rất yếu'} 
                ];
                ranges.forEach(r => {
                    let text = r.min === '' ? `>= ${r.max}` : (r.max === '' ? `< ${r.min}` : `${r.min} đến ${r.max}`);
                    labels.push(`
                        <div style="display: flex; align-items: center; margin-bottom: 6px;">
                            <i style="background:${r.color}; width: 16px; height: 16px; border-radius: 50%; border: 1px solid #7f8c8d; margin-right: 8px;"></i> 
                            <b style="width: 65px;">${text}</b> 
                            <span style="color:#7f8c8d; font-style:italic;">(${r.desc})</span>
                        </div>
                    `);
                });
            } else {
                return div; 
            }

            div.innerHTML += labels.join('');
            return div;
        };
        legendControl.addTo(map);
    }

    function processItsLog(event) {
        const file = event.target.files[0];
        if (!file) return;

        itsLogLayer.clearLayers();
        globalLogLines = []; 
        document.getElementById('mapLoading').style.display = 'block';

        const reader = new FileReader();
        reader.onload = function(e) {
            const text = e.target.result;
            const lines = text.split(/\r?\n/);
            
            if (lines.length < 2) {
                alert("File log không hợp lệ hoặc trống!");
                document.getElementById('mapLoading').style.display = 'none';
                return;
            }

            const headers = lines[0].split('|').map(h => h.trim().toLowerCase());
            const idxLat = headers.indexOf('latitude');
            const idxLng = headers.indexOf('longitude');
            const idxNode = headers.indexOf('node');
            const idxCellID = headers.indexOf('cellid');
            const idxLAC = headers.indexOf('lac');
            const idxTech = headers.indexOf('networktech');
            const idxLevel = headers.indexOf('level');

            if (idxLat < 0 || idxLng < 0 || idxLevel < 0) {
                alert("File log thiếu cột chuẩn (Latitude, Longitude, Level).");
                document.getElementById('mapLoading').style.display = 'none';
                return;
            }

            let is3G = false, is4G = false;
            let logBounds = [];
            
            let markerSize = parseFloat(document.getElementById('markerSizeSlider').value) || 3.5;
            let scale = parseFloat(document.getElementById('sectorSizeSlider').value) / 100;

            for (let i = 1; i < lines.length; i++) {
                const cols = lines[i].split('|');
                if (cols.length < headers.length) continue;

                const lat = parseFloat(cols[idxLat]);
                const lng = parseFloat(cols[idxLng]);
                if (isNaN(lat) || isNaN(lng)) continue;

                const tech = cols[idxTech] ? cols[idxTech].toUpperCase() : '';
                const level = parseFloat(cols[idxLevel]);
                const node = cols[idxNode] ? cols[idxNode].trim() : '';
                const cellId = cols[idxCellID] ? cols[idxCellID].trim() : '';
                const lac = cols[idxLAC] ? cols[idxLAC].trim() : '';

                let color = '#95a5a6'; 
                let servingCellObj = null;

                if (tech.includes('3G')) {
                    is3G = true;
                    color = getColor3G(level);
                    servingCellObj = globalPolygons.find(p => p.rawData.lac === lac && p.rawData.ci === cellId);
                } else if (tech.includes('4G')) {
                    is4G = true;
                    color = getColor4G(level);
                    servingCellObj = globalPolygons.find(p => p.rawData.enodeb === node && p.rawData.lcrid === cellId);
                }

                const marker = L.circleMarker([lat, lng], {
                    radius: markerSize, fillColor: color, color: '#34495e', weight: 0.5, fillOpacity: 1
                });
                marker.bindPopup(`<b>Công nghệ:</b> ${tech}<br><b>Signal Level:</b> ${level} dBm<br><b>Serving Cell ID:</b> ${cellId}<br><b>Node/LAC:</b> ${node || lac}`);
                marker.addTo(itsLogLayer);

                if (servingCellObj) {
                    let arcCenter = getDestination(servingCellObj.lat, servingCellObj.lng, servingCellObj.azimuth, servingCellObj.baseRadius * scale);
                    
                    const line = L.polyline([[lat, lng], arcCenter], {
                        color: color, weight: 1.5, opacity: 0.8, dashArray: '4, 4'
                    });
                    line.addTo(itsLogLayer);

                    globalLogLines.push({
                        line: line,
                        startLat: lat,
                        startLng: lng,
                        cellObj: servingCellObj
                    });
                }
                
                logBounds.push([lat, lng]);
            }

            if (is4G) addLegend(false, true);
            else if (is3G) addLegend(true, false);

            if (logBounds.length > 0) map.fitBounds(logBounds);
            document.getElementById('mapLoading').style.display = 'none';
            event.target.value = ''; 
        };
        
        reader.readAsText(file);
    }

    window.onload = loadMapData;
</script>
