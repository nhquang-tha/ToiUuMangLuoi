    async function renderTAMap(scale = 1) {
        const loading = document.getElementById('mapLoading');
        document.getElementById('loadingText').innerText = "Đang xử lý thuật toán mô phỏng TA...";
        loading.style.display = 'block';

        try {
            if (taDataCache.length === 0) {
                document.getElementById('loadingText').innerText = "Đang tải dữ liệu TA từ máy chủ...";
                const res = await fetch('/api/ta-data');
                taDataCache = await res.json();
            }

            document.getElementById('loadingText').innerText = "Đang vẽ bản đồ nhiệt đa sắc...";
            
            const taLookupMap = {};
            taDataCache.forEach(t => {
                let rawTaCell = String(t.Cell_Code || t.cell_code || t.CELL_CODE || t['Cell Code'] || t['Cell_Code'] || '').trim();
                let core = extractCoreName(rawTaCell);
                if (core) taLookupMap[core] = t;
                taLookupMap[rawTaCell.toLowerCase()] = t;
            });

            layerGroup.clearLayers(); 
            taLayer.clearLayers();

            const taBaseDistances = [0, 200, 500, 900, 1400, 2000, 2800, 3800, 5000, 6500, 8500, 11000, 15000];

            globalPolygons.forEach(cellItem => {
                let taRecord = taLookupMap[cellItem.fastCoreCode] || taLookupMap[cellItem.cellStr];

                if (taRecord) {
                    let ues = [];
                    for(let i = 0; i <= 11; i++) {
                        let val = taRecord['Index' + i] !== undefined ? taRecord['Index' + i] : taRecord['index' + i];
                        ues.push(parseInt(val) || 0);
                    }
                    let maxUE = Math.max(...ues);
                    if (maxUE > 0) {
                        for(let i = 0; i <= 11; i++) {
                            let ueCount = ues[i];
                            if (ueCount > 0) {
                                let ratio = ueCount / maxUE; 
                                let baseBw = 65; let bw = baseBw * (0.2 + 0.8 * ratio); 
                                let innerR = taBaseDistances[i] * scale; let outerR = taBaseDistances[i+1] * scale;
                                let segment = createTASegment(cellItem.lat, cellItem.lng, cellItem.azimuth, innerR, outerR, bw, ratio, cellItem.displayCellName, i, ueCount);
                                segment.addTo(taLayer);
                                cellItem.taSegments = cellItem.taSegments || [];
                                cellItem.taSegments.push(segment);
                            }
                        }
                    }
                } else {
                    let fallback = createSector(cellItem.lat, cellItem.lng, cellItem.azimuth, cellItem.displayCellName, '4g', cellItem.rawData.rfData, 250, scale);
                    let styleObj = {fillColor: '#bdc3c7', color: '#95a5a6', fillOpacity: 0.3, weight: 1.5};
                    fallback.setStyle(styleObj); fallback.originalStyle = styleObj;
                    fallback.addTo(taLayer); cellItem.taSegments = [fallback];
                }
            });

            addTALegend();
            loading.style.display = 'none';
        } catch (e) {
            console.error(e); showToast('Lỗi truy xuất hệ thống khi tải dữ liệu TA!', true);
            loading.style.display = 'none';
        }
    }

