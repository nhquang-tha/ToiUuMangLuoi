    async function loadMapData() {
        const network = document.getElementById('networkSelect').value;
        const loading = document.getElementById('mapLoading');
        document.getElementById('loadingText').innerText = "Đang tải dữ liệu mạng lưới...";
        
        isTAMode = false;
        document.getElementById('btnTAMode').innerHTML = '📶 Mô phỏng TA';
        document.getElementById('btnTAMode').style.background = '#9b59b6';

        loading.style.display = 'block';
        layerGroup.clearLayers();
        itsLogLayer.clearLayers(); 
        azimuthLayer.clearLayers(); 
        taLayer.clearLayers();
        azimuthOrigins = {};
        latestOriginId = null;
        
        globalPolygons = []; 
        globalLogLines = []; 
        defaultBounds = [];
        document.getElementById('mapSearchInput').value = ''; 

        let scale = parseFloat(document.getElementById('sectorSizeSlider').value) / 100;

        try {
            const response = await fetch(`/api/gis-data?network=${network}`);
            const data = await response.json();

            if (data.length === 0) {
                loading.style.display = 'none';
                showToast('Không có dữ liệu tọa độ trạm RF cho mạng này!', true);
                return;
            }

            document.getElementById('loadingText').innerText = "Đang xử lý hình học đa giác...";

            setTimeout(() => {
                data.forEach(item => {
                    if(item.lat && item.lng) {
                        let baseRadius = 250; 
                        if (network === '3g') baseRadius = 300; 
                        if (network === '5g') baseRadius = 150; 

                        let rfCellName = ''; let rfCellCode = '';
                        if (item.rfData) {
                            let nameItem = item.rfData.find(x => x.key.toLowerCase() === 'cell_name' || x.key.toLowerCase() === 'site_name');
                            if (nameItem) rfCellName = nameItem.value;
                            let codeItem = item.rfData.find(x => x.key.toLowerCase() === 'cell_code');
                            if (codeItem) rfCellCode = codeItem.value;
                        }
                        
                        let cellStr = String(item.cell).toLowerCase();
                        let displayCellName = item.cell || rfCellName || "Unknown";
                        let fastCoreCode = extractCoreName(rfCellCode || item.cell);

                        const sector = createSector(item.lat, item.lng, item.azimuth, item.cell, network, item.rfData, baseRadius, scale);
                        sector.addTo(layerGroup);
                        defaultBounds.push([item.lat, item.lng]);
                        
                        globalPolygons.push({
                            cellStr: cellStr, siteStr: String(item.site).toLowerCase(),
                            polygon: sector, lat: item.lat, lng: item.lng, azimuth: item.azimuth, 
                            baseRadius: baseRadius, baseColor: sector.options.color,
                            rawData: item,
                            displayCellName: displayCellName,
                            fastCoreCode: fastCoreCode 
                        });
                    }
                });

                if (defaultBounds.length > 0) map.fitBounds(defaultBounds);
                if (legendControl) map.removeControl(legendControl); 
                loading.style.display = 'none';

            }, 50);

        } catch (error) {
            console.error(error);
            loading.style.display = 'none';
            showToast('Lỗi truy xuất dữ liệu từ máy chủ!', true);
        }
    }

    function searchMap() {
        let keyword = document.getElementById('mapSearchInput').value.trim().toLowerCase();
        
        if (!keyword) {
            globalPolygons.forEach(item => {
                if (isTAMode && item.taSegments) {
                    item.taSegments.forEach(seg => {
                        if (!taLayer.hasLayer(seg)) taLayer.addLayer(seg);
                        if (seg.originalStyle) seg.setStyle(seg.originalStyle);
                    });
                } else {
                    if (!layerGroup.hasLayer(item.polygon)) layerGroup.addLayer(item.polygon);
                    item.polygon.setStyle({ weight: 1, fillOpacity: 0.65, color: item.baseColor, fillColor: item.baseColor });
                }
            });
            globalCshtData.forEach(item => {
                item.marker.setStyle({ radius: 5, color: '#ffffff', weight: 2, fillColor: '#34495e', fillOpacity: 1 });
            });
            if (defaultBounds.length > 0) map.fitBounds(defaultBounds);
            return;
        }

        let matchedBounds = [];
        let matchCount = 0;

        globalPolygons.forEach(item => {
            let isMatch = item.cellStr.includes(keyword) || item.siteStr.includes(keyword);
            
            if (isMatch) {
                if (isTAMode && item.taSegments) {
                    item.taSegments.forEach(seg => {
                        if (!taLayer.hasLayer(seg)) taLayer.addLayer(seg);
                        seg.setStyle({ weight: 3, color: '#000000' });
                        seg.bringToFront();
                    });
                } else {
                    if (!layerGroup.hasLayer(item.polygon)) layerGroup.addLayer(item.polygon);
                    item.polygon.setStyle({ weight: 3, fillOpacity: 0.9, color: '#000000', fillColor: item.baseColor });
                    item.polygon.bringToFront(); 
                }
                
                matchedBounds.push([item.lat, item.lng]);
                if(matchCount === 0 && !isTAMode) {
                    let point = map.latLngToContainerPoint([item.lat, item.lng]);
                    item.polygon.openPopup(map.containerPointToLatLng(point));
                }
                matchCount++;
            } else {
                if (isTAMode && item.taSegments) {
                    item.taSegments.forEach(seg => { if (taLayer.hasLayer(seg)) taLayer.removeLayer(seg); });
                } else {
                    if (!layerGroup.hasLayer(item.polygon)) layerGroup.addLayer(item.polygon);
                    item.polygon.setStyle({ weight: 0.5, fillOpacity: 0.15, color: item.baseColor, fillColor: item.baseColor });
                }
            }
        });

        globalCshtData.forEach(item => {
            let isMatch = item.Ten_CSHT.includes(keyword) || item.Ma_CSHT.includes(keyword);
            if (isMatch) {
                item.marker.setStyle({ radius: 9, color: '#e74c3c', weight: 3, fillColor: '#f1c40f', fillOpacity: 1 });
                item.marker.bringToFront();
                matchedBounds.push([item.lat, item.lng]);
                if (matchCount === 0) item.marker.openPopup();
                matchCount++;
            } else {
                item.marker.setStyle({ radius: 4, color: '#34495e', weight: 1.5, fillColor: '#ecf0f1', fillOpacity: 0.6 });
            }
        });

        if (matchedBounds.length > 0) {
            if (matchedBounds.length === 1) map.setView(matchedBounds[0], 16);
            else map.fitBounds(matchedBounds, { padding: [50, 50], maxZoom: 16 });
        } else {
            showToast(`Không tìm thấy Cell/Site hoặc CSHT nào chứa từ khóa "${keyword}".`, true);
        }
    }

    function getColor4G(level) {
        if (level >= -80) return '#27ae60'; if (level >= -90) return '#2980b9'; 
        if (level >= -100) return '#f1c40f'; if (level >= -110) return '#e67e22'; return '#c0392b'; 
    }
    function getColor3G(level) {
        if (level >= -75) return '#27ae60'; if (level >= -85) return '#2980b9'; 
        if (level >= -95) return '#f1c40f'; if (level >= -105) return '#e67e22'; return '#c0392b'; 
    }
    function addLegend(is3G, is4G) {
        if (legendControl) map.removeControl(legendControl);
        legendControl = L.control({position: 'bottomright'});
        legendControl.onAdd = function (map) {
            let div = L.DomUtil.create('div', 'info legend'); let labels = [];
            let title = is4G ? 'Mức thu (RSRP)' : 'Mức thu (RSCP)';
            div.innerHTML = `<h4 style="margin: 0 0 10px 0; color: var(--text-main); font-size: 13px; font-weight: bold; border-bottom: 2px solid var(--primary); padding-bottom: 5px;">${title}</h4>`;
            
            const ranges4G = [ 
                { text: 'RSRP >= -80', color: '#27ae60' }, 
                { text: '-90 <= RSRP < -80', color: '#2980b9' }, 
                { text: '-100 <= RSRP < -90', color: '#f1c40f' }, 
                { text: '-110 <= RSRP < -100', color: '#e67e22' }, 
                { text: 'RSRP < -110', color: '#c0392b' } 
            ];
            const ranges3G = [ 
                { text: 'RSCP >= -75', color: '#27ae60' }, 
                { text: '-85 <= RSCP < -75', color: '#2980b9' }, 
                { text: '-95 <= RSCP < -85', color: '#f1c40f' }, 
                { text: '-105 <= RSCP < -95', color: '#e67e22' }, 
                { text: 'RSCP < -105', color: '#c0392b' } 
            ];
            
            const ranges = is4G ? ranges4G : ranges3G;

            ranges.forEach(r => {
                labels.push(`<div style="display: flex; align-items: center; margin-bottom: 5px;"><i style="background:${r.color}; width: 14px; height: 14px; border-radius: 3px; margin-right: 8px;"></i> <span style="font-size: 12px; font-weight: bold; color: var(--text-main);">${r.text}</span></div>`);
            });
            div.innerHTML += labels.join(''); return div;
        };
        legendControl.addTo(map);
    }

    async function processItsLog(event) {
        const files = event.target.files;
        if (!files || files.length === 0) return;

        itsLogLayer.clearLayers(); 
        globalLogLines = []; 
        document.getElementById('loadingText').innerText = "Đang vẽ dữ liệu đường đo Drive Test...";
        document.getElementById('mapLoading').style.display = 'block';

        let is3G = false, is4G = false; 
        let allLogBounds = [];
        let markerSize = parseFloat(document.getElementById('markerSizeSlider').value) || 3.5;
        let scale = parseFloat(document.getElementById('sectorSizeSlider').value) / 100;

        const readFile = (file) => {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const text = e.target.result; 
                    const lines = text.split(/\r?\n/);
                    if (lines.length < 2) { resolve(); return; } 

                    const headers = lines[0].split('|').map(h => h.trim().toLowerCase());
                    const idxLat = headers.indexOf('latitude'); const idxLng = headers.indexOf('longitude');
                    const idxNode = headers.indexOf('node'); const idxCellID = headers.indexOf('cellid');
                    const idxLAC = headers.indexOf('lac'); const idxTech = headers.indexOf('networktech'); const idxLevel = headers.indexOf('level');

                    if (idxLat < 0 || idxLng < 0 || idxLevel < 0) { resolve(); return; } 

                    for (let i = 1; i < lines.length; i++) {
                        const cols = lines[i].split('|'); if (cols.length < headers.length) continue;
                        const lat = parseFloat(cols[idxLat]); const lng = parseFloat(cols[idxLng]);
                        if (isNaN(lat) || isNaN(lng)) continue;

                        const tech = cols[idxTech] ? cols[idxTech].toUpperCase() : ''; const level = parseFloat(cols[idxLevel]);
                        const node = cols[idxNode] ? cols[idxNode].trim() : ''; const cellId = cols[idxCellID] ? cols[idxCellID].trim() : '';
                        const lac = cols[idxLAC] ? cols[idxLAC].trim() : '';

                        let color = '#95a5a6'; let servingCellObj = null;
                        if (tech.includes('3G')) { is3G = true; color = getColor3G(level); servingCellObj = globalPolygons.find(p => p.rawData.lac === lac && p.rawData.ci === cellId); } 
                        else if (tech.includes('4G')) { is4G = true; color = getColor4G(level); servingCellObj = globalPolygons.find(p => p.rawData.enodeb === node && p.rawData.lcrid === cellId); }

                        const marker = L.circleMarker([lat, lng], { radius: markerSize, fillColor: color, color: '#34495e', weight: 0.5, fillOpacity: 1 });
                        marker.bindPopup(`<b>Tech:</b> ${tech}<br><b>Level:</b> ${level} dBm<br><b>Serving Cell:</b> ${cellId}<br><b>Node/LAC:</b> ${node || lac}`);
                        marker.addTo(itsLogLayer);

                        if (servingCellObj) {
                            let arcCenter = getDestination(servingCellObj.lat, servingCellObj.lng, servingCellObj.azimuth, servingCellObj.baseRadius * scale);
                            const line = L.polyline([[lat, lng], arcCenter], { color: color, weight: 1.5, opacity: 0.8, dashArray: '4, 4' });
                            line.addTo(itsLogLayer);
                            globalLogLines.push({ line: line, startLat: lat, startLng: lng, cellObj: servingCellObj });
                        }
                        allLogBounds.push([lat, lng]);
                    }
                    resolve(); 
                };
                reader.readAsText(file);
            });
        };

        const readPromises = [];
        for (let i = 0; i < files.length; i++) readPromises.push(readFile(files[i]));
        
        await Promise.all(readPromises);

        if (is4G) addLegend(false, true); else if (is3G) addLegend(true, false);
        if (allLogBounds.length > 0) map.fitBounds(allLogBounds);
        
        document.getElementById('mapLoading').style.display = 'none'; 
        event.target.value = ''; 
    }

    window.onload = loadAllMapData;
</script>
</body>
</html>
