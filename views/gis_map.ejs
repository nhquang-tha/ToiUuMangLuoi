<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: var(--bg-body); }
    .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    
    .map-header { background: var(--bg-surface); padding: 10px 20px; box-shadow: var(--shadow-card); z-index: 10; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; border-bottom: 1px solid var(--border-color);}
    .map-header h1 { margin: 0; font-size: 18px; color: var(--text-main); font-weight: bold; white-space: nowrap;}
    
    .map-controls { display: flex; gap: 10px; align-items: center; flex-wrap: wrap;}
    .map-controls select { padding: 6px 12px; height: 34px; border-radius: 6px; border: 1.5px solid var(--border-color); outline: none; font-weight: bold; color: var(--text-main); background: var(--bg-body); cursor: pointer; font-size: 13px; }
    
    .search-box { display: flex; align-items: center; border: 1.5px solid var(--border-color); border-radius: 6px; overflow: hidden; background: var(--bg-body); height: 34px;}
    .search-box input { border: none; padding: 6px 12px; width: 220px; outline: none; font-size: 13px; height: 100%; box-sizing: border-box; background: transparent; color: var(--text-main); }
    .search-box button { border: none; background: var(--primary); color: white; padding: 0 15px; cursor: pointer; font-weight: bold; transition: 0.2s; font-size: 13px; height: 100%; }
    .search-box button:hover { filter: brightness(1.1); }

    .map-wrapper { position: relative; flex: 1; display: flex; flex-direction: column; height: 100%; width: 100%; }
    #map { flex: 1; height: 100%; width: 100%; z-index: 1; background: var(--bg-body); }
    
    #mapLoading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--bg-surface); padding: 20px 40px; border-radius: 12px; box-shadow: var(--shadow-card); z-index: 1000; display: none; text-align: center; font-weight: bold; color: var(--primary); font-size: 15px; border: 2px solid var(--primary);}
    @keyframes spin { 100% { transform: rotate(360deg); } }

    .rf-popup-table { width: 100%; border-collapse: collapse; font-size: 11px; }
    .rf-popup-table th, .rf-popup-table td { padding: 5px; border: 1px solid var(--border-color); text-align: left; }
    .rf-popup-table th { background: var(--bg-body); color: var(--text-muted); width: 45%; font-weight: bold; text-transform: uppercase;}
    .rf-popup-table tr:hover { background: var(--bg-body); }
    .rf-popup-container { max-height: 250px; overflow-y: auto; overflow-x: hidden; border: 1px solid var(--border-color); border-radius: 6px; margin-top: 10px;}
    .rf-popup-container::-webkit-scrollbar { width: 4px; }
    .rf-popup-container::-webkit-scrollbar-track { background: var(--bg-body); }
    .rf-popup-container::-webkit-scrollbar-thumb { background: var(--border-color); border-radius: 2px; }

    .custom-leaflet-btn a { font-size: 16px !important; display: flex !important; justify-content: center; align-items: center; text-decoration: none; color: var(--text-main); width: 32px; height: 32px; background: var(--bg-surface); border-radius: 6px;}
    .custom-leaflet-btn a:hover { background-color: var(--bg-body); color: var(--primary); }

    .info.legend { background: var(--bg-surface); padding: 12px 16px; border-radius: 8px; box-shadow: var(--shadow-card); color: var(--text-main); min-width: 180px; border: 1px solid var(--border-color); }

    .slider-control { background: var(--bg-surface); padding: 12px 16px; border-radius: 8px; box-shadow: var(--shadow-card); width: 220px; border: 1px solid var(--border-color); color: var(--text-main); }
    .slider-control input[type=range] { -webkit-appearance: none; width: 100%; margin: 8px 0; background: transparent; }
    .slider-control input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 5px; cursor: pointer; background: var(--border-color); border-radius: 2.5px; }
    .slider-control input[type=range]::-webkit-slider-thumb { height: 14px; width: 14px; border-radius: 50%; background: var(--primary); cursor: pointer; -webkit-appearance: none; margin-top: -4.5px; }

    .azi-tool-container { position: relative; }
    .azi-sub-menu {
        display: none; position: absolute; left: 38px; top: 0; background: var(--bg-surface); border-radius: 8px; 
        box-shadow: var(--shadow-card); width: 220px; z-index: 1000; flex-direction: column; border: 1px solid var(--border-color); overflow: hidden;
    }
    .azi-sub-menu.show { display: flex; }
    .azi-menu-item { padding: 10px 15px; border-bottom: 1px solid var(--border-color); cursor: pointer; font-size: 13px; font-weight: bold; color: var(--text-main); transition: 0.2s;}
    .azi-menu-item:hover { background: var(--bg-body); color: var(--primary); }
    .azi-menu-item:last-child { border-bottom: none; }
    
    .azi-end-icon { background: #e74c3c; border: 2px solid #fff; border-radius: 50%; box-shadow: 0 0 5px rgba(0,0,0,0.5); }
    .azi-permanent-label { background: var(--bg-surface); border: 2px solid #8e44ad; border-radius: 4px; font-size: 11px; padding: 2px 6px; font-weight: bold; white-space: nowrap; box-shadow: var(--shadow-card); color: var(--text-main);}
    .leaflet-tooltip.azi-permanent-label::before { border-right-color: #8e44ad; }

    .csht-tooltip {
        background: transparent; border: none; box-shadow: none;
        color: var(--text-main); font-weight: 800; font-size: 12px;
        text-shadow: 1px 1px 0 var(--bg-surface), -1px -1px 0 var(--bg-surface), 1px -1px 0 var(--bg-surface), -1px 1px 0 var(--bg-surface), 0 2px 4px rgba(0,0,0,0.5);
    }
    .leaflet-tooltip.csht-tooltip::before { display: none; }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        
        <div class="map-header">
            <h1>Bản Đồ Vùng Phủ Sóng (GIS Map)</h1>
            <div class="map-controls">
                
                <button id="btnTAMode" onclick="toggleTAMode()" style="background: #9b59b6; color: white; border: none; padding: 0 15px; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.3s; font-size: 13px; height: 34px; display: inline-flex; align-items: center;">
                    📶 Mô Phỏng TA
                </button>

                <input type="file" id="itsLogInput" accept=".txt,.csv" multiple style="display: none;" onchange="processItsLog(event)">
                <button onclick="document.getElementById('itsLogInput').click()" style="background: #e67e22; color: white; border: none; padding: 0 15px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 13px; height: 34px; display: inline-flex; align-items: center;">
                    📥 Import Log ITS
                </button>

                <div class="search-box">
                    <input type="text" id="mapSearchInput" placeholder="Nhập Cell/Site hoặc CSHT..." onkeypress="if(event.key === 'Enter') searchMap()">
                    <button onclick="searchMap()">🔍 Tìm kiếm</button>
                </div>

                <select id="networkSelect" onchange="loadMapData()">
                    <option value="4g" selected>Mạng 4G LTE</option>
                    <option value="3g">Mạng 3G WCDMA</option>
                    <option value="5g">Mạng 5G NR</option>
                </select>
                <button onclick="loadAllMapData()" style="background: var(--success); color: white; border: none; padding: 0 15px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 13px; height: 34px; display: inline-flex; align-items: center;">
                    🔄 Tải Lại
                </button>
            </div>
        </div>
        
        <div class="map-wrapper" id="mapWrapper">
            <div id="mapLoading">
                <span style="display: inline-block; animation: spin 1s linear infinite; margin-right: 8px; font-size: 20px;">⚙️</span> <span id="loadingText">Đang xử lý dữ liệu...</span>
            </div>
            <div id="map"></div>
        </div>

    </main>
</div>

<script>
    let globalPolygons = []; 
    let globalCshtData = []; 
    let defaultBounds = [];  
    let globalLogLines = []; 
    let azimuthOrigins = {}; 
    let latestOriginId = null; 
    
    let isTAMode = false;
    let taDataCache = []; 

    // Hệ thống Toast thông báo thay thế hoàn toàn alert()
    function showToast(message, isError = false) {
        let toast = document.getElementById('mapToast');
        if (!toast) {
            toast = document.createElement('div');
            toast.id = 'mapToast';
            toast.style.cssText = 'position:fixed; bottom:20px; right:20px; background:rgba(0,0,0,0.85); color:#fff; padding:12px 20px; border-radius:8px; font-size:13px; z-index:9999; box-shadow:0 4px 15px rgba(0,0,0,0.3); transition:opacity 0.3s;';
            document.body.appendChild(toast);
        }
        toast.style.background = isError ? '#e74c3c' : '#27ae60';
        toast.innerText = message;
        toast.style.opacity = '1';
        setTimeout(() => { toast.style.opacity = '0'; }, 3500);
    }

    let map = L.map('map', { preferCanvas: true }).setView([19.806692, 105.776153], 10); 
    
    map.createPane('cshtPane');
    map.getPane('cshtPane').style.zIndex = 450; 
    const cshtRenderer = L.svg({ pane: 'cshtPane' });
    
    let layerGroup = L.layerGroup().addTo(map);   
    let cshtLayer = L.layerGroup().addTo(map);    
    let itsLogLayer = L.layerGroup().addTo(map);  
    let azimuthLayer = L.layerGroup().addTo(map); 
    let taLayer = L.layerGroup().addTo(map); 
    let legendControl = null; 

    const googleStreets = L.tileLayer('http://mt0.google.com/vt/lyrs=m&hl=vi&x={x}&y={y}&z={z}', {
        attribution: 'Map data &copy; Google', maxZoom: 20
    });
    const googleHybrid = L.tileLayer('http://mt0.google.com/vt/lyrs=y&hl=vi&x={x}&y={y}&z={z}', {
        attribution: 'Map data &copy; Google', maxZoom: 20
    });

    googleStreets.addTo(map); 
    L.control.layers({
        "🌍 Google Map (Cơ bản)": googleStreets,
        "🛰️ Google Map (Vệ tinh)": googleHybrid
    }).addTo(map);

    L.Control.FullScreen = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function(map) {
            let container = L.DomUtil.create('div', 'leaflet-bar leaflet-control custom-leaflet-btn');
            container.innerHTML = `<a href="#" title="Toàn màn hình">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"></polyline><polyline points="9 21 3 21 3 15"></polyline><line x1="21" y1="3" x2="14" y2="10"></line><line x1="3" y1="21" x2="10" y2="14"></line></svg>
            </a>`;
            container.onclick = function(e) {
                e.preventDefault();
                let mapElement = document.getElementById('mapWrapper');
                if (!document.fullscreenElement) { mapElement.requestFullscreen().catch(err => console.log(err)); } 
                else { document.exitFullscreen(); }
            }
            return container;
        }
    });
    map.addControl(new L.Control.FullScreen());

    let userMarker = null;
    L.Control.GPS = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function(map) {
            let container = L.DomUtil.create('div', 'leaflet-bar leaflet-control custom-leaflet-btn');
            container.innerHTML = `<a href="#" title="Vị trí của tôi">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="6"></circle>
                    <line x1="12" y1="2" x2="12" y2="5"></line>
                    <line x1="12" y1="19" x2="12" y2="22"></line>
                    <line x1="2" y1="12" x2="5" y2="12"></line>
                    <line x1="19" y1="12" x2="22" y2="12"></line>
                </svg>
            </a>`;
            container.onclick = function(e) { e.preventDefault(); map.locate({setView: true, maxZoom: 15}); }
            return container;
        }
    });
    map.addControl(new L.Control.GPS());

    L.Control.AzimuthTool = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function(map) {
            let container = L.DomUtil.create('div', 'leaflet-bar leaflet-control custom-leaflet-btn azi-tool-container');
            container.innerHTML = `
                <a href="#" title="Công cụ vẽ tia Azimuth" onclick="toggleAziMenu(event)">🧭</a>
                <div id="aziSubMenu" class="azi-sub-menu">
                    <div class="azi-menu-item" onclick="createAzimuthOrigin('gps')">📍 Lấy điểm gốc trùng GPS</div>
                    <div class="azi-menu-item" onclick="createAzimuthOrigin('center')">🎯 Lấy gốc giữa màn hình</div>
                    <div class="azi-menu-item" style="color: #27ae60;" onclick="addDirectionToLatest()">➕ Add Direction</div>
                    <div class="azi-menu-item" style="color: #c0392b; border-top: 1px solid var(--border-color);" onclick="clearAzimuthTool()">🗑️ Clear Azimuth</div>
                </div>
            `;
            L.DomEvent.disableClickPropagation(container);
            return container;
        }
    });
    map.addControl(new L.Control.AzimuthTool());

    window.toggleAziMenu = function(e) { e.preventDefault(); document.getElementById('aziSubMenu').classList.toggle('show'); };
    map.on('click', function() { let menu = document.getElementById('aziSubMenu'); if(menu && menu.classList.contains('show')) menu.classList.remove('show'); });

    window.clearAzimuthTool = function() {
        document.getElementById('aziSubMenu').classList.remove('show'); 
        azimuthLayer.clearLayers();
        azimuthOrigins = {};
        latestOriginId = null;
    };

    L.Control.Sliders = L.Control.extend({
        options: { position: 'bottomleft' },
        onAdd: function (map) {
            let div = L.DomUtil.create('div', 'slider-control');
            div.innerHTML = `
                <div style="margin-bottom: 8px;">
                    <label style="font-size: 11px; font-weight: bold;">Kích thước Điểm đo ITS: <span id="markerSizeVal" style="color:#e67e22">3.5</span></label>
                    <input type="range" id="markerSizeSlider" min="1" max="10" step="0.5" value="3.5">
                </div>
                <div>
                    <label style="font-size: 11px; font-weight: bold;">Bán kính Bản đồ (Scale): <span id="sectorSizeVal" style="color:#2980b9">10%</span></label>
                    <input type="range" id="sectorSizeSlider" min="10" max="300" step="10" value="10">
                </div>
            `;
            L.DomEvent.disableClickPropagation(div);
            L.DomEvent.disableScrollPropagation(div);
            return div;
        }
    });
    map.addControl(new L.Control.Sliders());

    document.getElementById('markerSizeSlider').addEventListener('input', function(e) {
        let size = parseFloat(e.target.value);
        document.getElementById('markerSizeVal').innerText = size;
        itsLogLayer.eachLayer(function(layer) {
            if (layer instanceof L.CircleMarker) layer.setRadius(size);
        });
    });

    document.getElementById('sectorSizeSlider').addEventListener('input', function(e) {
        let scale = parseFloat(e.target.value) / 100;
        document.getElementById('sectorSizeVal').innerText = e.target.value + '%';
        
        if (isTAMode) {
            renderTAMap(scale);
        } else {
            globalPolygons.forEach(item => {
                let newPoints = calculateSectorPoints(item.lat, item.lng, item.azimuth, item.baseRadius, scale);
                item.polygon.setLatLngs(newPoints);
            });
            globalLogLines.forEach(item => {
                let newArcCenter = getDestination(item.cellObj.lat, item.cellObj.lng, item.cellObj.azimuth, item.cellObj.baseRadius * scale);
                item.line.setLatLngs([[item.startLat, item.startLng], newArcCenter]);
            });
        }
    });

    map.on('locationfound', function(e) {
        if (userMarker) map.removeLayer(userMarker);
        userMarker = L.circleMarker(e.latlng, { radius: 7, fillColor: "#3498db", color: "#fff", weight: 2, opacity: 1, fillOpacity: 0.9 }).addTo(map).bindPopup("📍 Bạn đang ở đây!").openPopup();
    });

    document.addEventListener('fullscreenchange', () => { setTimeout(() => map.invalidateSize(), 200); });
    setTimeout(() => { map.invalidateSize(); }, 500);

    function getBearing(startLat, startLng, destLat, destLng) {
        startLat = startLat * Math.PI / 180; startLng = startLng * Math.PI / 180;
        destLat = destLat * Math.PI / 180; destLng = destLng * Math.PI / 180;
        let y = Math.sin(destLng - startLng) * Math.cos(destLat);
        let x = Math.cos(startLat) * Math.sin(destLat) - Math.sin(startLat) * Math.cos(destLat) * Math.cos(destLng - startLng);
        let brng = Math.atan2(y, x) * 180 / Math.PI;
        return (brng + 360) % 360;
    }

    window.createAzimuthOrigin = function(type) {
        document.getElementById('aziSubMenu').classList.remove('show'); 
        let center = type === 'gps' ? (userMarker ? userMarker.getLatLng() : null) : map.getCenter();
        if (!center && type === 'gps') { showToast("Chưa có tín hiệu GPS!", true); return; }
        let marker = L.marker(center, {draggable: true}).addTo(azimuthLayer);
        let id = marker._leaflet_id; latestOriginId = id; 
        azimuthOrigins[id] = { marker: marker, lines: [], name: "Trạm Gốc " + id };
        function updatePopup() {
            let pos = marker.getLatLng();
            let html = `<div style="min-width: 200px; font-family: Arial;">
                    <h4 style="margin-top:0; color:#2980b9; border-bottom:1px solid #ddd; padding-bottom:5px;">📍 Cấu Hình Gốc</h4>
                    <div style="margin-bottom: 6px;"><label style="font-size:11px; font-weight:bold;">Tên:</label><input type="text" id="origName_${id}" value="${azimuthOrigins[id].name}" style="width:100%; padding:4px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box; font-size:12px;"></div>
                    <div style="margin-bottom: 6px;"><label style="font-size:11px; font-weight:bold;">Vĩ độ (Lat):</label><input type="number" step="0.000001" id="origLat_${id}" value="${pos.lat.toFixed(6)}" style="width:100%; padding:4px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box; font-size:12px;"></div>
                    <div style="margin-bottom: 10px;"><label style="font-size:11px; font-weight:bold;">Kinh độ (Lng):</label><input type="number" step="0.000001" id="origLng_${id}" value="${pos.lng.toFixed(6)}" style="width:100%; padding:4px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box; font-size:12px;"></div>
                    <button onclick="updateOrigin(${id})" style="background:#2980b9; color:#fff; border:none; padding:6px; width:100%; border-radius:3px; font-weight:bold; cursor:pointer; margin-bottom:6px; font-size:12px;">💾 Lưu Tọa độ</button>
                    <button onclick="addDirection(${id})" style="background:#27ae60; color:#fff; border:none; padding:6px; width:100%; border-radius:3px; font-weight:bold; cursor:pointer; font-size:12px;">➕ Add Direction</button>
                </div>`;
            marker.bindPopup(html);
        }
        updatePopup(); marker.on('dragend', function() { updatePopup(); redrawLines(id); }); marker.openPopup();
    };

    window.addDirectionToLatest = function() {
        document.getElementById('aziSubMenu').classList.remove('show');
        if (latestOriginId && azimuthOrigins[latestOriginId]) addDirection(latestOriginId); else showToast("Vui lòng tạo một Điểm Gốc trước!", true);
    };

    function updatePermanentLabel(marker, name, az) {
        marker.setTooltipContent(`<div style="text-align:center; line-height:1.2;"><b style="color:#8e44ad; font-size:11px;">${name}</b><br><span style="color:#e74c3c; font-weight:bold; font-size:11px;">${az.toFixed(1)}°</span></div>`);
    }

    window.addDirection = function(originId) {
        let originObj = azimuthOrigins[originId]; let origPos = originObj.marker.getLatLng(); let destCoords = getDestination(origPos.lat, origPos.lng, 0, 500); 
        let endLatLng = L.latLng(destCoords[0], destCoords[1]); let endIcon = L.divIcon({className: 'azi-end-icon', iconSize: [12, 12], iconAnchor: [6, 6]});
        let endMarker = L.marker(endLatLng, {draggable: true, icon: endIcon}).addTo(azimuthLayer); let line = L.polyline([origPos, endLatLng], {color: '#8e44ad', weight: 2, opacity: 0.8}).addTo(azimuthLayer);
        let lineObj = { endMarker: endMarker, line: line, name: "Sector", azimuth: 0, distance: 500 }; originObj.lines.push(lineObj); let endId = endMarker._leaflet_id;
        endMarker.bindTooltip("", {permanent: true, direction: "right", className: "azi-permanent-label", offset: [10, 0]}).openTooltip(); updatePermanentLabel(endMarker, lineObj.name, lineObj.azimuth);
        function updateEndPopup() {
            let html = `<div style="min-width: 180px; font-family: Arial;">
                    <h4 style="margin-top:0; color:#8e44ad; border-bottom:1px solid #ddd; padding-bottom:5px;">🎯 Cấu Hình Tia</h4>
                    <div style="margin-bottom: 6px;"><label style="font-size:11px; font-weight:bold;">Tên:</label><input type="text" id="endName_${endId}" value="${lineObj.name}" style="width:100%; padding:4px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box; font-size:12px;"></div>
                    <div style="margin-bottom: 6px;"><label style="font-size:11px; font-weight:bold;">Góc Azimuth (°):</label><input type="number" id="endAz_${endId}" value="${lineObj.azimuth.toFixed(1)}" style="width:100%; padding:4px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box; font-size:12px;"></div>
                    <div style="margin-bottom: 10px;"><label style="font-size:11px; font-weight:bold;">Độ dài (m):</label><input type="number" id="endDist_${endId}" value="${lineObj.distance.toFixed(1)}" style="width:100%; padding:4px; border:1px solid #ccc; border-radius:3px; box-sizing: border-box; font-size:12px;"></div>
                    <button onclick="updateEndMarker(${originId}, ${endId})" style="background:#8e44ad; color:#fff; border:none; padding:6px; width:100%; border-radius:3px; font-weight:bold; cursor:pointer; font-size:12px;">💾 Lưu Thông Số</button>
                </div>`;
            endMarker.bindPopup(html);
        }
        updateEndPopup();
        endMarker.on('drag', function(e) {
            let currentPos = e.target.getLatLng(); let op = originObj.marker.getLatLng(); line.setLatLngs([op, currentPos]);
            let dist = map.distance(op, currentPos); let az = getBearing(op.lat, op.lng, currentPos.lat, currentPos.lng);
            lineObj.distance = dist; lineObj.azimuth = az; updatePermanentLabel(endMarker, lineObj.name, az);
        });
        endMarker.on('dragend', function() { updateEndPopup(); });
    };

    window.updateOrigin = function(id) {
        let name = document.getElementById('origName_'+id).value; let lat = parseFloat(document.getElementById('origLat_'+id).value); let lng = parseFloat(document.getElementById('origLng_'+id).value);
        if(isNaN(lat) || isNaN(lng)) { showToast("Tọa độ không hợp lệ!", true); return; }
        let obj = azimuthOrigins[id]; obj.name = name; let newLatLng = L.latLng(lat, lng);
        obj.marker.setLatLng(newLatLng); map.setView(newLatLng, 17); redrawLines(id);
    };

    window.redrawLines = function(originId) {
        let obj = azimuthOrigins[originId]; let origPos = obj.marker.getLatLng();
        obj.lines.forEach(lObj => {
            let newCoords = getDestination(origPos.lat, origPos.lng, lObj.azimuth, lObj.distance); let newLatLng = L.latLng(newCoords[0], newCoords[1]);
            lObj.endMarker.setLatLng(newLatLng); lObj.line.setLatLngs([origPos, newLatLng]); updatePermanentLabel(lObj.endMarker, lObj.name, lObj.azimuth);
            lObj.endMarker.setPopupContent(lObj.endMarker.getPopup().getContent());
        });
        obj.marker.closePopup(); 
    };

    window.updateEndMarker = function(originId, endId) {
        let obj = azimuthOrigins[originId]; let lObj = obj.lines.find(l => l.endMarker._leaflet_id === endId);
        lObj.name = document.getElementById('endName_'+endId).value; lObj.azimuth = parseFloat(document.getElementById('endAz_'+endId).value); lObj.distance = parseFloat(document.getElementById('endDist_'+endId).value);
        let origPos = obj.marker.getLatLng(); let newCoords = getDestination(origPos.lat, origPos.lng, lObj.azimuth, lObj.distance); let newLatLng = L.latLng(newCoords[0], newCoords[1]);
        lObj.endMarker.setLatLng(newLatLng); lObj.line.setLatLngs([origPos, newLatLng]); updatePermanentLabel(lObj.endMarker, lObj.name, lObj.azimuth); lObj.endMarker.closePopup();
    };

    function getDestination(lat, lng, azimuth, distanceMeters) {
        const R = 6378137; 
        const brng = azimuth * Math.PI / 180;
        const lat1 = lat * Math.PI / 180;
        const lon1 = lng * Math.PI / 180;
        const lat2 = Math.asin(Math.sin(lat1) * Math.cos(distanceMeters/R) + Math.cos(lat1) * Math.sin(distanceMeters/R) * Math.cos(brng));
        const lon2 = lon1 + Math.atan2(Math.sin(brng) * Math.sin(distanceMeters/R) * Math.cos(lat1), Math.cos(distanceMeters/R) - Math.sin(lat1) * Math.sin(lat2));
        return [lat2 * 180 / Math.PI, lon2 * 180 / Math.PI];
    }

    function calculateSectorPoints(lat, lng, azimuth, baseRadius, scale) {
        let radius = baseRadius * scale;
        const beamwidth = 65; 
        const center = [lat, lng];
        const points = [center];
        const startAngle = azimuth - beamwidth / 2;
        const endAngle = azimuth + beamwidth / 2;

        for (let i = startAngle; i <= endAngle; i += 15) {
            points.push(getDestination(lat, lng, i, radius));
        }
        points.push(getDestination(lat, lng, endAngle, radius));
        points.push(center);
        return points;
    }

    function createSector(lat, lng, azimuth, cellName, networkType, rfData, baseRadius, scale) {
        let color = '#e74c3c'; 
        if (networkType === '3g') color = '#f1c40f'; 
        if (networkType === '5g') color = '#3498db'; 

        const points = calculateSectorPoints(lat, lng, azimuth, baseRadius, scale);
        const polygon = L.polygon(points, { color: color, weight: 1, fillColor: color, fillOpacity: 0.65 });

        polygon.originalStyle = { color: color, weight: 1, fillColor: color, fillOpacity: 0.65 };

        let tableHtml = `<div class="rf-popup-container"><table class="rf-popup-table">`;
        if (Array.isArray(rfData)) {
            rfData.forEach(item => tableHtml += `<tr><th>${item.key}</th><td>${item.value}</td></tr>`);
        }
        tableHtml += `</table></div>`;

        polygon.bindPopup(`
            <div style="font-family: Arial; min-width: 250px;">
                <h4 style="margin: 0 0 5px 0; color: ${color}; border-bottom: 2px solid ${color}; padding-bottom: 5px; font-size:14px;">📡 Cell: ${cellName}</h4>
                <div style="font-size: 11px; color: var(--text-muted);"><strong>Tọa độ:</strong> ${lat.toFixed(5)}, ${lng.toFixed(5)} &nbsp;|&nbsp; <strong>Góc phát:</strong> ${azimuth}°</div>
                ${tableHtml}
            </div>
        `, { maxWidth: 400 });
        
        return polygon;
    }

