    async function toggleTAMode() {
        const network = document.getElementById('networkSelect').value;
        const btn = document.getElementById('btnTAMode');

        if (network !== '4g') {
            alert('Tính năng phân tích TA hiện tại chỉ hỗ trợ mô phỏng trên mạng 4G!');
            return;
        }

        isTAMode = !isTAMode;

        if (isTAMode) {
            btn.innerHTML = '🎯 Tắt Mô phỏng TA';
            btn.style.background = '#8e44ad';
            
            let scale = parseFloat(document.getElementById('sectorSizeSlider').value) / 100;
            await renderTAMap(scale);
        } else {
            btn.innerHTML = '📶 Mô phỏng TA';
            btn.style.background = '#9b59b6';
            
            loadMapData();
        }
    }

    async function renderTAMap(scale = 1) {
        const loading = document.getElementById('mapLoading');
        loading.style.display = 'block';

        try {
            if (taDataCache.length === 0) {
                const res = await fetch('/api/ta-data');
                taDataCache = await res.json();
            }

            layerGroup.clearLayers(); 
            taLayer.clearLayers();

            const taBaseDistances = [0, 200, 500, 900, 1400, 2000, 2800, 3800, 5000, 6500, 8500, 11000, 15000];

            globalPolygons.forEach(cellItem => {
                
                let rfCellName = '';
                let rfCellCode = '';
                if (cellItem.rawData && cellItem.rawData.rfData) {
                    let nameItem = cellItem.rawData.rfData.find(x => x.key.toLowerCase() === 'cell_name' || x.key.toLowerCase() === 'site_name');
                    if (nameItem) rfCellName = nameItem.value;
                    
                    let codeItem = cellItem.rawData.rfData.find(x => x.key.toLowerCase() === 'cell_code');
                    if (codeItem) rfCellCode = codeItem.value;
                }

                let coreRfName = extractCoreName(rfCellName);
                let coreRfCode = extractCoreName(rfCellCode);
                let coreStr = extractCoreName(cellItem.cellStr);

                const taRecord = taDataCache.find(t => {
                    let rawTaCell = String(t.Cell_Code || t.cell_code || t.CELL_CODE || t.Cell_code || t['Cell Code'] || t['Cell_Code'] || '').trim();
                    let rawRfCellCode = String(rfCellCode).trim();
                    
                    if (rawTaCell && rawRfCellCode && rawTaCell.toLowerCase() === rawRfCellCode.toLowerCase()) return true;

                    let coreTaCell = extractCoreName(rawTaCell);
                    if (!coreTaCell) return false;

                    if (coreTaCell === coreRfName || coreTaCell === coreRfCode || coreTaCell === coreStr) return true;
                    if (coreRfName.length > 4 && coreTaCell.includes(coreRfName)) return true;
                    if (coreRfCode.length > 4 && coreTaCell.includes(coreRfCode)) return true;

                    return false;
                });

                if (taRecord) {
                    let ues = [];
                    for(let i = 0; i <= 11; i++) {
                        let keyUpperCase = 'Index' + i;
                        let keyLowerCase = 'index' + i;
                        let val = taRecord[keyUpperCase] !== undefined ? taRecord[keyUpperCase] : taRecord[keyLowerCase];
                        ues.push(parseInt(val) || 0);
                    }
                    
                    let maxUE = Math.max(...ues);
                    
                    if (maxUE > 0) {
                        for(let i = 0; i <= 11; i++) {
                            let ueCount = ues[i];
                            if (ueCount > 0) {
                                let ratio = ueCount / maxUE; 
                                let baseBw = 65;
                                let bw = baseBw * (0.2 + 0.8 * ratio); 
                                let innerR = taBaseDistances[i] * scale;
                                let outerR = taBaseDistances[i+1] * scale;
                                
                                let cellDisplayName = cellItem.rawData.cell || rfCellName || "Unknown";
                                let segment = createTASegment(cellItem.lat, cellItem.lng, cellItem.azimuth, innerR, outerR, bw, ratio, cellDisplayName, i, ueCount);
                                segment.addTo(taLayer);
                                
                                cellItem.taSegments = cellItem.taSegments || [];
                                cellItem.taSegments.push(segment);
                            }
                        }
                    }
                } else {
                    let fallback = createSector(cellItem.lat, cellItem.lng, cellItem.azimuth, cellItem.rawData.cell, '4g', cellItem.rawData.rfData, 250, scale);
                    let styleObj = {fillColor: '#bdc3c7', color: '#95a5a6', fillOpacity: 0.3, weight: 1.5};
                    fallback.setStyle(styleObj);
                    fallback.originalStyle = styleObj;
                    fallback.addTo(taLayer);
                    cellItem.taSegments = [fallback];
                }
            });

            addTALegend();
            loading.style.display = 'none';

        } catch (e) {
            console.error(e);
            alert('Lỗi truy xuất hệ thống khi tải dữ liệu TA!');
            loading.style.display = 'none';
        }
    }


    // ====================================================
    // KHỞI TẠO BẢN ĐỒ CƠ BẢN
    // ====================================================
    async function loadMapData() {
        const network = document.getElementById('networkSelect').value;
        const loading = document.getElementById('mapLoading');
        
        isTAMode = false;
        document.getElementById('btnTAMode').innerHTML = '📶 Mô phỏng TA';
        document.getElementById('btnTAMode').style.background = '#9b59b6';

        loading.style.display = 'block';
        layerGroup.clearLayers();
        itsLogLayer.clearLayers(); 
        azimuthLayer.clearLayers(); 
        taLayer.clearLayers();
        azimuthOrigins = {};
        latestOriginId = null;
        
        globalPolygons = []; 
        globalLogLines = []; 
        defaultBounds = [];
        document.getElementById('mapSearchInput').value = ''; 

        let scale = parseFloat(document.getElementById('sectorSizeSlider').value) / 100;

        try {
            const response = await fetch(`/api/gis-data?network=${network}`);
            const data = await response.json();

            if (data.length === 0) {
                loading.style.display = 'none';
                return alert('Không có dữ liệu tọa độ trạm cho mạng này!');
            }

            data.forEach(item => {
                if(item.lat && item.lng) {
                    let baseRadius = 250; 
                    if (network === '3g') baseRadius = 300; 
                    if (network === '5g') baseRadius = 150; 

                    const sector = createSector(item.lat, item.lng, item.azimuth, item.cell, network, item.rfData, baseRadius, scale);
                    sector.addTo(layerGroup);
                    defaultBounds.push([item.lat, item.lng]);
                    
                    globalPolygons.push({
                        cellStr: String(item.cell).toLowerCase(), siteStr: String(item.site).toLowerCase(),
                        polygon: sector, lat: item.lat, lng: item.lng, azimuth: item.azimuth, 
                        baseRadius: baseRadius, baseColor: sector.options.color,
                        rawData: item 
                    });
                }
            });

            if (defaultBounds.length > 0) map.fitBounds(defaultBounds);
            if (legendControl) map.removeControl(legendControl); 
            loading.style.display = 'none';

        } catch (error) {
            console.error(error);
            loading.style.display = 'none';
            alert('Lỗi truy xuất dữ liệu từ máy chủ!');
        }
    }

    // ====================================================
    // TÌM KIẾM ĐỒNG BỘ: ẨN CÁC TRẠM KHÁC KHI TÌM KIẾM TA
    // ====================================================
    function searchMap() {
        let keyword = document.getElementById('mapSearchInput').value.trim().toLowerCase();
        
        if (!keyword) {
            globalPolygons.forEach(item => {
                if (isTAMode && item.taSegments) {
                    item.taSegments.forEach(seg => {
                        if (!taLayer.hasLayer(seg)) taLayer.addLayer(seg);
                        if (seg.originalStyle) seg.setStyle(seg.originalStyle);
                    });
                } else {
                    if (!layerGroup.hasLayer(item.polygon)) layerGroup.addLayer(item.polygon);
                    item.polygon.setStyle({ weight: 1, fillOpacity: 0.65, color: item.baseColor, fillColor: item.baseColor });
                }
            });
            if (defaultBounds.length > 0) map.fitBounds(defaultBounds);
            return;
        }

        let matchedBounds = [];
        let matchCount = 0;

        globalPolygons.forEach(item => {
            let isMatch = item.cellStr.includes(keyword) || item.siteStr.includes(keyword);
            
            if (isMatch) {
                if (isTAMode && item.taSegments) {
                    item.taSegments.forEach(seg => {
                        if (!taLayer.hasLayer(seg)) taLayer.addLayer(seg);
                        seg.setStyle({ weight: 3, color: '#000000' });
                        seg.bringToFront();
                    });
                } else {
                    if (!layerGroup.hasLayer(item.polygon)) layerGroup.addLayer(item.polygon);
                    item.polygon.setStyle({ weight: 3, fillOpacity: 0.9, color: '#000000', fillColor: item.baseColor });
                    item.polygon.bringToFront(); 
                }
                
                matchedBounds.push([item.lat, item.lng]);
                if(matchCount === 0 && !isTAMode) item.polygon.openPopup();
                matchCount++;
            } else {
                if (isTAMode && item.taSegments) {
                    // XÓA HOÀN TOÀN CÁC CELL KHÔNG KHỚP KHỎI BẢN ĐỒ TA
                    item.taSegments.forEach(seg => {
                        if (taLayer.hasLayer(seg)) taLayer.removeLayer(seg);
                    });
                } else {
                    // LÀM MỜ CELL KHÔNG KHỚP Ở BẢN ĐỒ THƯỜNG
                    if (!layerGroup.hasLayer(item.polygon)) layerGroup.addLayer(item.polygon);
                    item.polygon.setStyle({ weight: 0.5, fillOpacity: 0.15, color: item.baseColor, fillColor: item.baseColor });
                }
            }
        });

        if (matchedBounds.length > 0) {
            if (matchedBounds.length === 1) map.setView(matchedBounds[0], 16);
            else map.fitBounds(matchedBounds, { padding: [50, 50], maxZoom: 16 });
        } else {
            alert(`Không tìm thấy Cell hoặc Site nào chứa từ khóa "${keyword}".`);
        }
    }

    // ====================================================
    // MODULE: ĐỌC VÀ VẼ LOG FILE ĐO KIỂM (ITS)
    // ====================================================
    
    function getColor4G(level) {
        if (level >= -80) return '#27ae60'; 
        if (level >= -90) return '#2980b9'; 
        if (level >= -100) return '#f1c40f'; 
        if (level >= -110) return '#e67e22'; 
        return '#c0392b'; 
    }

    function getColor3G(level) {
        if (level >= -75) return '#27ae60'; 
        if (level >= -85) return '#2980b9'; 
        if (level >= -95) return '#f1c40f'; 
        if (level >= -105) return '#e67e22'; 
        return '#c0392b'; 
    }

    function addLegend(is3G, is4G) {
        if (legendControl) map.removeControl(legendControl);
        
        legendControl = L.control({position: 'bottomright'});
        legendControl.onAdd = function (map) {
            let div = L.DomUtil.create('div', 'info legend');
            let labels = [];
            
            let title = is4G ? 'Mức thu RSRP 4G (dBm)' : 'Mức thu RSCP 3G (dBm)';
            div.innerHTML = `<h4 style="margin: 0 0 10px 0; color: #2c3e50; font-size: 13px; font-weight: bold; border-bottom: 2px solid #3498db; padding-bottom: 5px;">${title}</h4>`;
            
            const ranges = [ 
                {min: '', max: is4G ? '-80' : '-75', color: '#27ae60', desc: 'Rất tốt'}, 
                {min: is4G ? '-80' : '-75', max: is4G ? '-90' : '-85', color: '#2980b9', desc: 'Tốt'}, 
                {min: is4G ? '-90' : '-85', max: is4G ? '-100' : '-95', color: '#f1c40f', desc: 'Trung bình'}, 
                {min: is4G ? '-100' : '-95', max: is4G ? '-110' : '-105', color: '#e67e22', desc: 'Yếu'}, 
                {min: is4G ? '-110' : '-105', max: '', color: '#c0392b', desc: 'Rất yếu'} 
            ];
            ranges.forEach(r => {
                let text = r.min === '' ? `>= ${r.max}` : (r.max === '' ? `< ${r.min}` : `${r.min} đến ${r.max}`);
                labels.push(`
                    <div style="display: flex; align-items: center; margin-bottom: 5px;">
                        <i style="background:${r.color}; width: 14px; height: 14px; border-radius: 3px; margin-right: 8px;"></i> 
                        <span style="width: 70px; font-size: 11px; font-weight: bold;">${text}</span> 
                        <span style="color:#7f8c8d; font-size: 11px; font-style:italic;">(${r.desc})</span>
                    </div>
                `);
            });
            div.innerHTML += labels.join('');
            return div;
        };
        legendControl.addTo(map);
    }

    function processItsLog(event) {
        const file = event.target.files[0];
        if (!file) return;

        itsLogLayer.clearLayers();
        globalLogLines = []; 
        document.getElementById('mapLoading').style.display = 'block';

        const reader = new FileReader();
        reader.onload = function(e) {
            const text = e.target.result;
            const lines = text.split(/\r?\n/);
            
            if (lines.length < 2) {
                alert("File log không hợp lệ hoặc trống!");
                document.getElementById('mapLoading').style.display = 'none';
                return;
            }

            const headers = lines[0].split('|').map(h => h.trim().toLowerCase());
            const idxLat = headers.indexOf('latitude');
            const idxLng = headers.indexOf('longitude');
            const idxNode = headers.indexOf('node');
            const idxCellID = headers.indexOf('cellid');
            const idxLAC = headers.indexOf('lac');
            const idxTech = headers.indexOf('networktech');
            const idxLevel = headers.indexOf('level');

            if (idxLat < 0 || idxLng < 0 || idxLevel < 0) {
                alert("File log thiếu cột chuẩn (Latitude, Longitude, Level).");
                document.getElementById('mapLoading').style.display = 'none';
                return;
            }

            let is3G = false, is4G = false;
            let logBounds = [];
            
            let markerSize = parseFloat(document.getElementById('markerSizeSlider').value) || 3.5;
            let scale = parseFloat(document.getElementById('sectorSizeSlider').value) / 100;

            for (let i = 1; i < lines.length; i++) {
                const cols = lines[i].split('|');
                if (cols.length < headers.length) continue;

                const lat = parseFloat(cols[idxLat]);
                const lng = parseFloat(cols[idxLng]);
                if (isNaN(lat) || isNaN(lng)) continue;

                const tech = cols[idxTech] ? cols[idxTech].toUpperCase() : '';
                const level = parseFloat(cols[idxLevel]);
                const node = cols[idxNode] ? cols[idxNode].trim() : '';
                const cellId = cols[idxCellID] ? cols[idxCellID].trim() : '';
                const lac = cols[idxLAC] ? cols[idxLAC].trim() : '';

                let color = '#95a5a6'; 
                let servingCellObj = null;

                if (tech.includes('3G')) {
                    is3G = true;
                    color = getColor3G(level);
                    servingCellObj = globalPolygons.find(p => p.rawData.lac === lac && p.rawData.ci === cellId);
                } else if (tech.includes('4G')) {
                    is4G = true;
                    color = getColor4G(level);
                    servingCellObj = globalPolygons.find(p => p.rawData.enodeb === node && p.rawData.lcrid === cellId);
                }

                const marker = L.circleMarker([lat, lng], {
                    radius: markerSize, fillColor: color, color: '#34495e', weight: 0.5, fillOpacity: 1
                });
                marker.bindPopup(`<b>Công nghệ:</b> ${tech}<br><b>Signal Level:</b> ${level} dBm<br><b>Serving Cell ID:</b> ${cellId}<br><b>Node/LAC:</b> ${node || lac}`);
                marker.addTo(itsLogLayer);

                if (servingCellObj) {
                    let arcCenter = getDestination(servingCellObj.lat, servingCellObj.lng, servingCellObj.azimuth, servingCellObj.baseRadius * scale);
                    
                    const line = L.polyline([[lat, lng], arcCenter], {
                        color: color, weight: 1.5, opacity: 0.8, dashArray: '4, 4'
                    });
                    line.addTo(itsLogLayer);

                    globalLogLines.push({
                        line: line,
                        startLat: lat,
                        startLng: lng,
                        cellObj: servingCellObj
                    });
                }
                
                logBounds.push([lat, lng]);
            }

            if (is4G) addLegend(false, true);
            else if (is3G) addLegend(true, false);

            if (logBounds.length > 0) map.fitBounds(logBounds);
            document.getElementById('mapLoading').style.display = 'none';
            event.target.value = ''; 
        };
        
        reader.readAsText(file);
    }

    window.onload = loadMapData;
</script>
</body>
</html>
