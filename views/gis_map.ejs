<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>

<!-- Load thư viện Bản đồ Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    
    .map-header { background: white; padding: 15px 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); z-index: 10; display: flex; justify-content: space-between; align-items: center; }
    .map-header h1 { margin: 0; font-size: 20px; color: #2c3e50; font-weight: bold; }
    
    .map-controls { display: flex; gap: 15px; align-items: center; }
    .map-controls select { padding: 8px 15px; border-radius: 4px; border: 1px solid #bdc3c7; outline: none; font-weight: bold; color: #2c3e50; }
    
    #map { flex: 1; width: 100%; z-index: 1; }
    
    /* Loading overlay */
    #mapLoading { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(255,255,255,0.9); padding: 20px 40px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); z-index: 1000; display: none; text-align: center; font-weight: bold; color: #2980b9; }
    @keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        
        <!-- Thanh điều khiển công cụ Bản đồ -->
        <div class="map-header">
            <h1>Bản Đồ Vùng Phủ Sóng (GIS Map)</h1>
            <div class="map-controls">
                <label style="font-weight: bold; color: #7f8c8d;">Hiển thị mạng:</label>
                <select id="networkSelect" onchange="loadMapData()">
                    <option value="4g" selected>Mạng 4G LTE</option>
                    <option value="3g">Mạng 3G WCDMA</option>
                    <option value="5g">Mạng 5G NR</option>
                </select>
                <button onclick="loadMapData()" class="btn-primary" style="background: #2980b9; color: white; border: none; padding: 8px 20px; border-radius: 4px; cursor: pointer; font-weight: bold;">
                    🔄 Vẽ Lên Bản Đồ
                </button>
            </div>
        </div>
        
        <div style="position: relative; flex: 1;">
            <div id="mapLoading"><span style="display: inline-block; animation: spin 1s linear infinite; margin-right: 10px;">⏳</span> Đang vẽ tọa độ lên bản đồ...</div>
            <div id="map"></div>
        </div>

    </main>
</div>

<script>
    // Khởi tạo bản đồ mặc định tại Việt Nam
    let map = L.map('map').setView([19.806692, 105.776153], 10); 
    let layerGroup = L.layerGroup().addTo(map);

    // Lớp Bản đồ 1: Google Đường phố (Dễ nhìn đường)
    const streetMap = L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap'
    });
    
    // Lớp Bản đồ 2: Vệ tinh (Esri World Imagery)
    const satelliteMap = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        attribution: 'Tiles &copy; Esri'
    });

    streetMap.addTo(map); // Hiển thị đường phố mặc định
    
    // Bộ điều khiển cho phép đổi nền bản đồ ở góc trên bên phải
    L.control.layers({
        "Bản đồ Đường phố": streetMap,
        "Bản đồ Vệ tinh": satelliteMap
    }).addTo(map);

    // ====================================================
    // THUẬT TOÁN TÍNH TOÁN LƯỢNG GIÁC: VẼ CÁNH QUẠT VÙNG PHỦ
    // ====================================================
    function getDestination(lat, lng, azimuth, distanceMeters) {
        const R = 6378137; // Bán kính trái đất tính bằng mét
        const brng = azimuth * Math.PI / 180;
        const lat1 = lat * Math.PI / 180;
        const lon1 = lng * Math.PI / 180;

        const lat2 = Math.asin(Math.sin(lat1) * Math.cos(distanceMeters/R) + Math.cos(lat1) * Math.sin(distanceMeters/R) * Math.cos(brng));
        const lon2 = lon1 + Math.atan2(Math.sin(brng) * Math.sin(distanceMeters/R) * Math.cos(lat1), Math.cos(distanceMeters/R) - Math.sin(lat1) * Math.sin(lat2));

        return [lat2 * 180 / Math.PI, lon2 * 180 / Math.PI];
    }

    function createSector(lat, lng, azimuth, cellName, networkType) {
        const radius = 250; // Bán kính quạt (250 mét)
        const beamwidth = 65; // Góc mở cánh quạt Anten (Độ)
        
        // Đổi màu tùy theo mạng
        let color = '#3498db'; // 4G Xanh dương
        if (networkType === '3g') color = '#e67e22'; // 3G Cam
        if (networkType === '5g') color = '#2ecc71'; // 5G Xanh lá

        const center = [lat, lng];
        const points = [center];
        const startAngle = azimuth - beamwidth / 2;
        const endAngle = azimuth + beamwidth / 2;

        // Vẽ các đỉnh của rìa cánh quạt
        for (let i = startAngle; i <= endAngle; i += 5) { 
            points.push(getDestination(lat, lng, i, radius));
        }
        points.push(getDestination(lat, lng, endAngle, radius));
        points.push(center);
        
        // Khởi tạo Polygon
        const polygon = L.polygon(points, {
            color: color,
            weight: 1,
            fillColor: color,
            fillOpacity: 0.5
        });

        // Click vào hình quạt sẽ hiện thông tin
        polygon.bindPopup(`
            <div style="font-family: Arial;">
                <b style="color: ${color};">Cell: ${cellName}</b><br>
                <b>Góc phát (Azimuth):</b> ${azimuth}°
            </div>
        `);
        return polygon;
    }

    // ====================================================
    // HÀM TẢI DỮ LIỆU TỪ MÁY CHỦ
    // ====================================================
    async function loadMapData() {
        const network = document.getElementById('networkSelect').value;
        const loading = document.getElementById('mapLoading');
        
        loading.style.display = 'block';
        layerGroup.clearLayers();

        try {
            const response = await fetch(`/api/gis-data?network=${network}`);
            const data = await response.json();

            if (data.length === 0) {
                loading.style.display = 'none';
                alert('Không có dữ liệu trạm (Tọa độ/Azimuth) cho mạng này trong Database!');
                return;
            }

            let bounds = [];

            // Vẽ hàng loạt hình quạt lên bản đồ
            data.forEach(item => {
                if(item.lat && item.lng) {
                    const sector = createSector(item.lat, item.lng, item.azimuth, item.cell, network);
                    sector.addTo(layerGroup);
                    bounds.push([item.lat, item.lng]);
                }
            });

            // Tự động căn giữa và Zoom bao quát tất cả các trạm
            if (bounds.length > 0) {
                map.fitBounds(bounds);
            }

            loading.style.display = 'none';

        } catch (error) {
            console.error(error);
            loading.style.display = 'none';
            alert('Lỗi truy xuất dữ liệu từ máy chủ!');
        }
    }

    // Tự động load dữ liệu 4G khi vừa mở trang
    window.onload = loadMapData;
</script>
</body>
</html>
