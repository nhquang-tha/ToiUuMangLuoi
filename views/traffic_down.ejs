<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; border-top: 4px solid #8e44ad;}
    
    .tab-header { display: flex; border-bottom: 2px solid #ecf0f1; margin-bottom: 20px; flex-wrap: wrap;}
    .tab-btn { background: transparent; border: none; padding: 12px 25px; cursor: pointer; font-size: 14px; font-weight: bold; color: #7f8c8d; transition: 0.3s; position: relative; }
    .tab-btn:hover { color: #2c3e50; }
    .tab-btn.active { color: #8e44ad; border-bottom: 3px solid #8e44ad; }
    
    /* CSS THANH CUỘN CHO BẢNG DÀI (SCROLLBAR) */
    .table-wrapper { 
        width: 100%; 
        max-height: 500px; 
        overflow-y: auto;  
        overflow-x: auto; 
        background: #fff; 
        border-radius: 8px; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
        display: none; 
        animation: fadeIn 0.5s ease;
        border: 1px solid #ecf0f1;
    }
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; white-space: nowrap; }
    .data-table th, .data-table td { padding: 12px 15px; border-bottom: 1px solid #ecf0f1; text-align: left; }
    .data-table th { 
        position: sticky; 
        top: 0; 
        z-index: 10; 
        background-color: #f8f9fa; 
        color: #2c3e50; 
        font-weight: bold; 
        box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.1);
    }
    .data-table tbody tr:hover { background-color: #f9f0fc; }
    
    .trend-flat { color: #95a5a6; font-size: 11px;}
    .bad-cell { color: #c0392b; font-weight: bold; }
    .ratio-badge { background: #fbeeeeb0; color: #e74c3c; padding: 4px 10px; border-radius: 12px; border: 1px solid #fad2d2; font-size: 12px; font-weight: bold;}
    
    /* Huy hiệu mạng 3G/4G/5G */
    .net-badge-3g { background: #e3f2fd; color: #2980b9; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; border: 1px solid #bce0fd;}
    .net-badge-4g { background: #f4ecf8; color: #8e44ad; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; border: 1px solid #e1cbed;}
    .net-badge-5g { background: #e8f8f5; color: #16a085; padding: 3px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; border: 1px solid #bce8e0;}

    .header-zero { border-bottom: 2px solid #e74c3c; padding: 15px; font-weight: bold; color: #c0392b; font-size: 16px; background: #fdf2f2; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; left: 0; z-index: 11; }
    
    .btn-kpi { background: #3498db; color: white; padding: 5px 10px; border-radius: 4px; text-decoration: none; font-size: 11px; font-weight: bold; display: inline-block; transition: 0.2s; border: 1px solid #2980b9; }
    .btn-kpi:hover { background: #2980b9; transform: scale(1.05); box-shadow: 0 2px 5px rgba(0,0,0,0.2); }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>📉 Cảnh Báo Sụt Giảm Lưu Lượng (Traffic Down)</h1>
        </header>
        
        <div class="content-body">
            
            <div class="filter-card">
                <div style="flex: 1; min-width: 250px;">
                    <p style="margin: 0 0 5px 0; color: #7f8c8d; font-size: 14px;">Thuật toán tự động nhận diện dữ liệu mới nhất (3G, 4G & 5G) để phân tích đối soát.</p>
                    <div id="dateInfo" style="font-weight: bold; color: #8e44ad; font-size: 16px;">
                        Ngày phân tích: <span style="color:#2c3e50;">[Chưa lấy dữ liệu]</span>
                    </div>
                </div>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <button onclick="fetchTrafficDown()" class="btn-primary" style="background: #8e44ad; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 45px; font-size: 14px; transition: 0.2s;">
                        🔍 Bắt Đầu Phân Tích
                    </button>
                    <button onclick="exportToExcel()" id="btnExport" class="btn-success" style="background: #27ae60; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 45px; font-size: 14px; display: none;">
                        📥 Xuất Excel (Tất Cả)
                    </button>
                </div>
            </div>

            <!-- HƯỚNG DẪN / THÔNG BÁO TIÊU CHÍ LỌC -->
            <div id="initMsg" style="background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 20px; font-size: 14px; color: #34495e;">
                <strong>💡 Các tiêu chí Lọc Traffic:</strong><br>
                <span style="color: #e74c3c">1. Cell Không Lưu Lượng (Lọc 3G/4G/5G):</span> Trạm phải <b>CÓ MẶT</b> trong file KPI mới nhất. Traffic = 0 GB VÀ Traffic TB mốc thời gian trước đó > 0 GB.<br>
                <span style="color: #f39c12">2. Cell Suy Giảm (Lọc 4G/5G):</span> Traffic hôm nay < 70% Tuần trước (cùng thứ) <strong>VÀ</strong> Tuần trước > 5 GB <strong>VÀ</strong> 3 ngày mới nhất đều suy giảm so với cùng kỳ tuần trước.<br>
                <span style="color: #8e44ad">3. POI Suy Giảm (Tách 4G/5G riêng):</span> Traffic POI hôm nay < 70% Tuần trước <strong>VÀ</strong> 3 ngày mới nhất đều suy giảm so với cùng kỳ tuần trước.
            </div>

            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #8e44ad; font-size: 16px; font-weight: bold; background: white; border-radius: 8px; margin-bottom: 15px;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang đối soát lưu lượng mạng lưới với tuần trước...
            </div>
            
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px;"></div>

            <div class="tab-header" id="tabsMenu" style="display: none;">
                <button class="tab-btn active" onclick="openTab(event, 'zeroTableContainer')">1. Cell Không Lưu Lượng</button>
                <button class="tab-btn" onclick="openTab(event, 'droppedTableContainer')">2. Cell Suy Giảm (>30%)</button>
                <button class="tab-btn" onclick="openTab(event, 'poiTableContainer')">3. Điểm POI Suy Giảm</button>
            </div>

            <!-- TAB 1: ZERO TRAFFIC -->
            <div class="table-wrapper" id="zeroTableContainer">
                <div class="header-zero">
                    <div>
                        🚨 Cảnh Báo: Các Trạm Mất Kênh Lưu Lượng (<span id="zeroCount">0</span> Cell)
                    </div>
                    <div>
                        <select id="zeroTypeFilter" onchange="renderZeroTable()" style="padding: 6px 12px; border-radius: 4px; border: 1px solid #e74c3c; color: #c0392b; font-weight: bold; outline: none; cursor: pointer; font-size: 13px;">
                            <option value="1">Mất lưu lượng 1 Ngày (Mới nhất)</option>
                            <option value="3">Mất lưu lượng 3 Ngày liên tiếp</option>
                            <option value="7">Mất lưu lượng 7 Ngày liên tiếp</option>
                        </select>
                    </div>
                </div>
                <table class="data-table" id="zeroTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tên Cell</th>
                            <th>Mạng</th>
                            <th>Traffic T0 (GB) <br><small style="color:#e74c3c">Hôm nay</small></th>
                            <th>Traffic Mốc Lịch Sử (GB) <br><small style="color:#27ae60">Trung bình kỳ trước</small></th>
                            <th style="text-align: center;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="zeroBody">
                    </tbody>
                </table>
            </div>

            <!-- TAB 2: DROPPED TRAFFIC CELLS -->
            <div class="table-wrapper" id="droppedTableContainer" style="display: none;">
                <div style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #e67e22; position: sticky; top: 0; background: #fef5e7; z-index: 11; border-bottom: 2px solid #e67e22;">
                    ⚠️ Cell Suy Giảm Lưu Lượng Đột Biến: <span id="droppedCount">0</span> Cell
                </div>
                <table class="data-table" id="droppedTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tên Cell</th>
                            <th>Mạng</th>
                            <th>Traffic T0 (GB) <br><small style="color:#e74c3c">Hôm nay</small></th>
                            <th>Traffic T7 (GB) <br><small style="color:#27ae60">Cùng kỳ tuần trước</small></th>
                            <th>Tỷ Lệ Giữ Lại</th>
                            <th style="text-align: center;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="droppedBody">
                    </tbody>
                </table>
            </div>

            <!-- TAB 3: POI TRAFFIC DROPPED -->
            <div class="table-wrapper" id="poiTableContainer" style="display: none;">
                <div style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #8e44ad; position: sticky; top: 0; background: #f4ecf8; z-index: 11; border-bottom: 2px solid #8e44ad;">
                    📍 POI Bị Suy Giảm Lượng User/Traffic: <span id="poiCount">0</span> POI
                </div>
                <table class="data-table" id="poiTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tên Khu Vực POI</th>
                            <th>Mạng</th>
                            <th>Traffic T0 (GB) <br><small style="color:#e74c3c">Hôm nay</small></th>
                            <th>Traffic T7 (GB) <br><small style="color:#27ae60">Cùng kỳ tuần trước</small></th>
                            <th>Tỷ Lệ Giữ Lại</th>
                            <th style="text-align: center;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="poiBody">
                    </tbody>
                </table>
            </div>

        </div>
    </main>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const xlsxScript = document.createElement('script');
        xlsxScript.src = atob('aHR0cHM6Ly91bnBrZy5jb20veGxzeC9kaXN0L3hsc3guZnVsbC5taW4uanM=');
        document.head.appendChild(xlsxScript);
    });

    // Biến lưu Cache dữ liệu Không lưu lượng
    window.trafficDataCache = {
        zero1d: [],
        zero3d: [],
        zero7d: []
    };

    function openTab(evt, tabName) {
        let i, tabcontent, tablinks;
        tabcontent = document.getElementsByClassName("table-wrapper");
        for (i = 0; i < tabcontent.length; i++) { tabcontent[i].style.display = "none"; }
        tablinks = document.getElementsByClassName("tab-btn");
        for (i = 0; i < tablinks.length; i++) { tablinks[i].classList.remove("active"); }
        document.getElementById(tabName).style.display = "block";
        evt.currentTarget.classList.add("active");
    }

    async function fetchTrafficDown() {
        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('loadingMsg').style.display = 'block';
        document.getElementById('errorMsg').style.display = 'none';
        document.getElementById('tabsMenu').style.display = 'none';
        document.getElementById('zeroTableContainer').style.display = 'none';
        document.getElementById('droppedTableContainer').style.display = 'none';
        document.getElementById('poiTableContainer').style.display = 'none';
        document.getElementById('btnExport').style.display = 'none';

        document.getElementById('zeroBody').innerHTML = '';
        document.getElementById('droppedBody').innerHTML = '';
        document.getElementById('poiBody').innerHTML = '';

        try {
            const response = await fetch('/api/traffic-down-data');
            const data = await response.json();
            
            document.getElementById('loadingMsg').style.display = 'none';

            if (data.error) {
                document.getElementById('errorMsg').innerText = data.error;
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            document.getElementById('dateInfo').innerHTML = `Ngày phân tích: <span style="color:#2c3e50;">${data.latestDate}</span> <i>(So với: ${data.lastWeekDate})</i>`;
            
            // LƯU CACHE DỮ LIỆU ZERO
            window.trafficDataCache.zero1d = data.zero_1d || [];
            window.trafficDataCache.zero3d = data.zero_3d || [];
            window.trafficDataCache.zero7d = data.zero_7d || [];

            // XỬ LÝ RENDER BẢNG ZERO ĐẦU TIÊN THEO SELECT
            renderZeroTable();

            // XỬ LÝ TAB DROPPED CELLS
            let droppedCells = data.droppedTrafficCells || [];
            document.getElementById('droppedCount').innerText = droppedCells.length;
            const droppedBody = document.getElementById('droppedBody');
            droppedCells.forEach((row, index) => {
                let badge = row.network === '5g' ? '<span class="net-badge-5g">5G</span>' : '<span class="net-badge-4g">4G</span>';
                
                droppedBody.insertAdjacentHTML('beforeend', `
                    <tr>
                        <td>${index + 1}</td>
                        <td style="font-weight: bold; color: #8e44ad;">${row.Cell_name}</td>
                        <td>${badge}</td>
                        <td style="color: #e74c3c; font-weight:bold;">${row.t0}</td>
                        <td style="color: #27ae60;">${row.t7}</td>
                        <td><span class="ratio-badge">${row.ratio}%</span></td>
                        <td style="text-align: center;">
                            <a href="/kpi-analytics?network=${row.network}&cell=${encodeURIComponent(row.Cell_name)}" target="_blank" class="btn-kpi">📊 Xem KPI</a>
                        </td>
                    </tr>
                `);
            });

            // XỬ LÝ TAB DROPPED POI
            let droppedPOIs = data.droppedTrafficPOIs || [];
            document.getElementById('poiCount').innerText = droppedPOIs.length;
            const poiBody = document.getElementById('poiBody');
            droppedPOIs.forEach((row, index) => {
                let badge = row.network === '5g' ? '<span class="net-badge-5g">5G</span>' : '<span class="net-badge-4g">4G</span>';
                
                poiBody.insertAdjacentHTML('beforeend', `
                    <tr>
                        <td>${index + 1}</td>
                        <td style="font-weight: bold; color: #d35400;">${row.POI}</td>
                        <td>${badge}</td>
                        <td style="color: #e74c3c; font-weight:bold;">${row.t0}</td>
                        <td style="color: #27ae60;">${row.t7}</td>
                        <td><span class="ratio-badge">${row.ratio}%</span></td>
                        <td style="text-align: center;">
                            <a href="/poi-report?poi=${encodeURIComponent(row.POI)}" target="_blank" class="btn-kpi" style="background:#9b59b6; border-color:#8e44ad;">📍 Xem Báo cáo POI</a>
                        </td>
                    </tr>
                `);
            });

            document.getElementById('tabsMenu').style.display = 'flex';
            document.getElementById('zeroTableContainer').style.display = 'block';
            document.getElementById('btnExport').style.display = 'block';

        } catch (error) {
            console.error(error);
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = 'Lỗi kết nối đến máy chủ CSDL. Có thể dữ liệu chưa được nạp đầy đủ.';
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    // HÀM RENDER RIÊNG CHO BẢNG ZERO KHI ĐỔI SELECT
    function renderZeroTable() {
        const type = document.getElementById('zeroTypeFilter').value;
        const zeroBody = document.getElementById('zeroBody');
        zeroBody.innerHTML = ''; 
        
        let dataSource = [];
        if (type === "1") dataSource = window.trafficDataCache.zero1d;
        else if (type === "3") dataSource = window.trafficDataCache.zero3d;
        else if (type === "7") dataSource = window.trafficDataCache.zero7d;

        document.getElementById('zeroCount').innerText = dataSource.length;
        
        if (dataSource.length > 0) {
            dataSource.forEach((row, index) => {
                let badge = '';
                if (row.network === '5g') badge = '<span class="net-badge-5g">5G</span>';
                else if (row.network === '4g') badge = '<span class="net-badge-4g">4G</span>';
                else badge = '<span class="net-badge-3g">3G</span>';
                
                zeroBody.insertAdjacentHTML('beforeend', `
                    <tr>
                        <td>${index + 1}</td>
                        <td style="font-weight: bold; color: #c0392b;">${row.Cell_name}</td>
                        <td>${badge}</td>
                        <td style="color: #e74c3c; font-weight:bold;">${row.t0}</td>
                        <td style="color: #27ae60;">${row.avgPast}</td>
                        <td style="text-align: center;">
                            <a href="/kpi-analytics?network=${row.network}&cell=${encodeURIComponent(row.Cell_name)}" target="_blank" class="btn-kpi">📊 Xem KPI</a>
                        </td>
                    </tr>
                `);
            });
        } else {
            zeroBody.innerHTML = `<tr><td colspan="6" style="text-align:center; padding:30px; color:#27ae60; font-weight:bold;">🎉 Không có trạm nào mất lưu lượng trong chu kỳ này!</td></tr>`;
        }
    }

    function exportToExcel() {
        if (typeof XLSX === 'undefined') {
            alert('Thư viện Excel chưa tải xong, vui lòng đợi...');
            return;
        }

        let wb = XLSX.utils.book_new();

        const createSheetFromTable = (tableId, sheetName) => {
            let table = document.getElementById(tableId);
            if (!table) return;
            let clone = table.cloneNode(true);
            // Xóa cột thao tác
            for (let i = 0; i < clone.rows.length; i++) {
                if(clone.rows[i].cells.length > 0) clone.rows[i].deleteCell(-1); 
            }
            let ws = XLSX.utils.table_to_sheet(clone);
            XLSX.utils.book_append_sheet(wb, ws, sheetName);
        };

        // Ép render tạm thời tất cả dữ liệu zero để xuất (bảo đảm xuất đủ 1d, 3d, 7d)
        const origSelect = document.getElementById('zeroTypeFilter').value;
        
        document.getElementById('zeroTypeFilter').value = "1"; renderZeroTable();
        createSheetFromTable('zeroTable', "Mat_Luu_Luong_1_Ngay");
        
        document.getElementById('zeroTypeFilter').value = "3"; renderZeroTable();
        createSheetFromTable('zeroTable', "Mat_Luu_Luong_3_Ngay");
        
        document.getElementById('zeroTypeFilter').value = "7"; renderZeroTable();
        createSheetFromTable('zeroTable', "Mat_Luu_Luong_7_Ngay");
        
        document.getElementById('zeroTypeFilter').value = origSelect; renderZeroTable(); // Trả lại gốc

        createSheetFromTable('droppedTable', "Cell_Suy_Giam");
        createSheetFromTable('poiTable', "POI_Suy_Giam");

        let dateStr = document.getElementById('dateInfo').innerText.match(/\d{2}\/\d{2}\/\d{4}/);
        let fileName = `Bao_Cao_Sut_Giam_Luu_Luong_${dateStr ? dateStr[0].replace(/\//g, '_') : 'MoiNhat'}.xlsx`;
        XLSX.writeFile(wb, fileName);
    }
</script>
</body>
</html>
