<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap; border-top: 4px solid #e74c3c;}
    
    .table-wrapper { width: 100%; overflow-x: auto; background: #fff; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); display: none; animation: fadeIn 0.5s ease;}
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; white-space: nowrap; }
    .data-table th, .data-table td { padding: 12px 15px; border-bottom: 1px solid #ecf0f1; text-align: left; }
    .data-table th { background-color: #f8f9fa; color: #2c3e50; font-weight: bold; position: sticky; top: 0; z-index: 10;}
    .data-table tbody tr:hover { background-color: #fdf2f2; }
    
    .bad-cell { color: #c0392b; font-weight: bold; }
    .violation-badge { background: #fbeeeeb0; color: #e74c3c; padding: 4px 8px; border-radius: 4px; border: 1px solid #fad2d2; font-size: 11px;}

    .btn-kpi { background: #3498db; color: white; padding: 5px 10px; border-radius: 4px; text-decoration: none; font-size: 11px; font-weight: bold; display: inline-block; transition: 0.2s; border: 1px solid #2980b9; }
    .btn-kpi:hover { background: #2980b9; transform: scale(1.05); box-shadow: 0 2px 5px rgba(0,0,0,0.2); }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>Cảnh Báo Chất Lượng: Worst Cells 4G</h1>
        </header>
        
        <div class="content-body">
            
            <div class="filter-card">
                <div style="flex: 1; min-width: 250px;">
                    <label style="display:block; margin-bottom:8px; font-weight:bold; color:#2c3e50;">Khoảng thời gian (Tính từ ngày mới nhất):</label>
                    <select id="daysSelect" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; cursor: pointer; font-size: 14px; border-left: 4px solid #e74c3c;">
                        <option value="1" selected>Lỗi trong 1 Ngày</option>
                        <option value="3">Lỗi liên tiếp 3 Ngày</option>
                        <option value="7">Lỗi liên tiếp 7 Ngày (Tuần)</option>
                        <option value="15">Lỗi liên tiếp 15 Ngày (Nửa tháng)</option>
                        <option value="30">Lỗi liên tiếp 30 Ngày (Tháng)</option>
                    </select>
                </div>
                <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                    <button onclick="fetchWorstCells()" class="btn-primary" style="background: #e74c3c; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 45px; font-size: 14px; transition: 0.2s;">
                        🔍 Bắt Đầu Lọc Worst Cell
                    </button>
                    <button onclick="exportToExcel()" id="btnExport" class="btn-success" style="background: #27ae60; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 45px; font-size: 14px; display: none;">
                        📥 Xuất File Excel
                    </button>
                </div>
            </div>

            <div id="initMsg" style="background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 20px; font-size: 14px; color: #34495e;">
                <strong>💡 Tiêu chí Worst Cell (Áp dụng 1 trong 4):</strong><br>
                1. User DL Avg Thput < 7000 kbps<br>
                2. Res Block DL > 20%<br>
                3. CQI 4G < 93%<br>
                4. Drop Rate (Service Drop All) > 0.3%
            </div>

            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #e67e22; font-size: 16px; font-weight: bold; background: white; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 15px;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang rà soát và lọc dữ liệu hàng nghìn Cell...
            </div>
            
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px;"></div>

            <div class="table-wrapper" id="tableContainer">
                <div style="padding: 15px; border-bottom: 1px solid #eee; font-weight: bold; color: #c0392b;">
                    Tổng số Cell vi phạm: <span id="totalCount">0</span> Cell.
                    <span style="font-size: 12px; font-weight: normal; color: #7f8c8d; margin-left: 10px;">(Dữ liệu chi tiết hiển thị của ngày mới nhất)</span>
                </div>
                <table class="data-table" id="worstTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Tên Cell 4G</th>
                            <th>Ngày Cập Nhật</th>
                            <th>Throughput (Kbps) <br><small style="color:#e74c3c">&lt;7000</small></th>
                            <th>PRB DL (%) <br><small style="color:#e74c3c">&gt;20%</small></th>
                            <th>CQI 4G (%) <br><small style="color:#e74c3c">&lt;93%</small></th>
                            <th>Drop Rate (%) <br><small style="color:#e74c3c">&gt;0.3%</small></th>
                            <th>Nguyên Nhân Lỗi</th>
                            <th style="text-align: center;">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                    </tbody>
                </table>
            </div>

        </div>
    </main>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const xlsxScript = document.createElement('script');
        xlsxScript.src = atob('aHR0cHM6Ly91bnBrZy5jb20veGxzeC9kaXN0L3hsc3guZnVsbC5taW4uanM=');
        document.head.appendChild(xlsxScript);
    });

    async function fetchWorstCells() {
        const days = document.getElementById('daysSelect').value;
        
        document.getElementById('initMsg').style.display = 'none';
        document.getElementById('loadingMsg').style.display = 'block';
        document.getElementById('errorMsg').style.display = 'none';
        document.getElementById('tableContainer').style.display = 'none';
        document.getElementById('btnExport').style.display = 'none';
        document.getElementById('tableBody').innerHTML = '';

        try {
            const response = await fetch(`/api/worst-cells-data?days=${days}`);
            if (!response.ok) throw new Error('Lỗi máy chủ');
            const data = await response.json();
            
            document.getElementById('loadingMsg').style.display = 'none';

            if (data.length === 0) {
                document.getElementById('errorMsg').innerText = `Tuyệt vời! Không có Cell nào bị lỗi liên tục trong ${days} ngày.`;
                document.getElementById('errorMsg').className = 'alert alert-success';
                document.getElementById('errorMsg').style.color = '#27ae60';
                document.getElementById('errorMsg').style.backgroundColor = '#e8f8f5';
                document.getElementById('errorMsg').style.borderColor = '#bce8e0';
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            document.getElementById('totalCount').innerText = data.length;
            const tbody = document.getElementById('tableBody');
            
            data.forEach((row, index) => {
                const tr = document.createElement('tr');
                
                const thputStyle = (parseFloat(row.User_DL_Avg_Throughput_Kbps) < 7000) ? 'bad-cell' : '';
                const prbStyle = (parseFloat(row.RB_Util_Rate_DL) > 20) ? 'bad-cell' : '';
                const cqiStyle = (parseFloat(row.CQI_4G) < 93) ? 'bad-cell' : '';
                const dropStyle = (parseFloat(row.Service_Drop_all) > 0.3) ? 'bad-cell' : '';

                tr.innerHTML = `
                    <td>${index + 1}</td>
                    <td style="font-weight: bold; color: #2980b9;">${row.Cell_name}</td>
                    <td>${row.Latest_Date}</td>
                    <td class="${thputStyle}">${row.User_DL_Avg_Throughput_Kbps}</td>
                    <td class="${prbStyle}">${row.RB_Util_Rate_DL}</td>
                    <td class="${cqiStyle}">${row.CQI_4G}</td>
                    <td class="${dropStyle}">${row.Service_Drop_all}</td>
                    <td><span class="violation-badge">${row.Violations}</span></td>
                    <td style="text-align:center;">
                        <a href="/kpi-analytics?network=4g&cell=${encodeURIComponent(row.Cell_name)}" target="_blank" class="btn-kpi">📊 Xem KPI</a>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            document.getElementById('tableContainer').style.display = 'block';
            document.getElementById('btnExport').style.display = 'block';

        } catch (error) {
            console.error(error);
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = 'Lỗi truy xuất dữ liệu từ Database.';
            document.getElementById('errorMsg').style.display = 'block';
        }
    }

    function exportToExcel() {
        if (typeof XLSX === 'undefined') {
            alert('Thư viện Excel chưa tải xong, vui lòng đợi...');
            return;
        }
        let table = document.getElementById('worstTable').cloneNode(true);
        // Xóa cột thao tác khi xuất file Excel
        for (let i = 0; i < table.rows.length; i++) {
            table.rows[i].deleteCell(-1); 
        }
        let wb = XLSX.utils.table_to_book(table, {sheet: "Worst_Cells"});
        let days = document.getElementById('daysSelect').value;
        let fileName = `Bao_Cao_Worst_Cells_Lien_Tiep_${days}_Ngay.xlsx`;
        XLSX.writeFile(wb, fileName);
    }
</script>
</body>
</html>
