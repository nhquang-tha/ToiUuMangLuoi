<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; position: relative; }
    
    .filter-card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; border-top: 4px solid #27ae60;}
    
    .step-badge { background: #27ae60; color: white; padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: bold; margin-bottom: 10px; display: inline-block;}
    .step-desc { font-size: 14px; color: #7f8c8d; margin-bottom: 15px;}

    .group-card { background: white; border-radius: 10px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); margin-bottom: 25px; overflow: hidden; border: 1px solid #ecf0f1; display: none; animation: fadeIn 0.5s;}
    .group-header { padding: 15px 20px; font-weight: bold; color: white; font-size: 16px; display: flex; justify-content: space-between; align-items: center;}
    .group-header.g1 { background: #34495e; } 
    .group-header.g2 { background: #e67e22; } 
    .group-header.g3 { background: #c0392b; } 
    
    .action-box { padding: 15px 20px; background: #fdfdfd; border-bottom: 1px solid #ecf0f1; display: flex; align-items: center; gap: 15px;}
    .action-box strong { color: #2c3e50; }
    
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; }
    .data-table th, .data-table td { padding: 12px 15px; border-bottom: 1px solid #ecf0f1; text-align: left; }
    .data-table th { background-color: #f8f9fa; color: #2c3e50; }
    .data-table tbody tr:hover { background-color: #f4f6f8; }

    .metric-bad { color: #e74c3c; font-weight: bold; }
    .metric-ok { color: #27ae60; font-weight: bold; }

    .btn-kpi { background: #3498db; color: white; padding: 6px 12px; border-radius: 4px; text-decoration: none; font-size: 12px; font-weight: bold; transition: 0.2s; border: 1px solid #2980b9; display: inline-block;}
    .btn-kpi:hover { background: #2980b9; transform: scale(1.05); }

    .summary-box { background: #e8f8f5; border: 1px solid #27ae60; padding: 15px; border-radius: 8px; margin-bottom: 20px; display: none;}
    .summary-box span { font-weight: bold; color: #27ae60; font-size: 18px;}

    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>🛠️ Tối Ưu Hóa Mạng Lưới (Quy trình 5 Bước Khép Kín)</h1>
        </header>
        
        <div class="content-body">
            
            <!-- VÙNG FILTER -->
            <div class="filter-card">
                <div class="step-badge">BƯỚC 1 & 2: ĐỊNH VỊ VÀ SÀNG LỌC</div>
                <div class="step-desc">
                    Lựa chọn Tuần đánh giá để hệ thống quét các <b>"Vùng Trũng"</b> (Cell vi phạm điểm QoE/QoS < 3 sao). Sau đó tự động đối soát loại bỏ danh sách <b>Blacklist</b> (Trạm IBS/DAS cũ, Biên giới/Hải đảo bất khả kháng).
                </div>
                
                <div style="display: flex; gap: 20px; align-items: flex-end; flex-wrap: wrap;">
                    <div style="flex: 1; min-width: 250px;">
                        <label style="display:block; margin-bottom:8px; font-weight:bold; color:#2c3e50;">1. Chọn Tuần Phân Tích (Từ DB):</label>
                        <select id="weekSelect" style="width: 100%; padding: 12px; border: 1px solid #bdc3c7; border-radius: 6px; outline: none; cursor: pointer; font-size: 14px;">
                            <% if (typeof weeks !== 'undefined' && weeks.length > 0) { %>
                                <% weeks.forEach(w => { %>
                                    <option value="<%= w %>"><%= w %></option>
                                <% }) %>
                            <% } else { %>
                                <option value="">Chưa có dữ liệu QoE/QoS</option>
                            <% } %>
                        </select>
                    </div>
                    <div style="flex: 1; min-width: 250px; padding: 12px; background: #f8f9fa; border-radius: 6px; border: 1px solid #ecf0f1;">
                        <label style="display:flex; align-items: center; cursor: pointer; font-weight: bold; color: #34495e;">
                            <input type="checkbox" id="blacklistCheck" checked style="width: 18px; height: 18px; margin-right: 10px;">
                            2. Kích hoạt loại bỏ Blacklist
                        </label>
                    </div>
                    <button onclick="runOptimization()" class="btn-primary" style="background: #27ae60; color: white; border: none; padding: 12px 30px; border-radius: 6px; font-weight: bold; cursor: pointer; height: 46px; font-size: 14px; transition: 0.2s;">
                        ⚙️ Khởi Chạy Phân Tích
                    </button>
                </div>
            </div>

            <!-- THÔNG BÁO -->
            <div id="loadingMsg" style="display: none; text-align: center; padding: 30px; color: #27ae60; font-size: 16px; font-weight: bold; background: white; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); margin-bottom: 15px;">
                <span style="display: inline-block; animation: spin 1s linear infinite;">⏳</span> Đang thực hiện BƯỚC 3: Ánh xạ KPI 7 ngày để chẩn đoán bệnh...
            </div>
            
            <div id="errorMsg" style="display: none; text-align: center; padding: 20px; color: #e74c3c; font-weight: bold; background: #fdf2f2; border: 1px solid #fad2d2; border-radius: 8px; margin-bottom: 15px;"></div>

            <div id="summaryBox" class="summary-box">
                Tóm tắt quy trình: Hệ thống đã quét được tổng cộng <span id="sumTotal">0</span> trạm rơi vào "Vùng trũng". 
                Đã loại trừ <span id="sumBlack">0</span> trạm thuộc diện Blacklist. 
                Hiện còn lại <span id="sumValid">0</span> trạm ưu tiên cao cần được giải phẫu bệnh lý.
            </div>

            <!-- NHÓM 1 -->
            <div class="group-card" id="group1">
                <div class="group-header g1">
                    <div>BƯỚC 3: Căn Bệnh Nhóm 1 - Tắc nghẽn Truyền dẫn / Lỗi Core</div>
                    <div style="font-size: 14px; font-weight: normal;">Số lượng: <b id="g1Count">0</b> Cell</div>
                </div>
                <div class="action-box">
                    <span class="step-badge" style="background:#34495e; margin:0;">BƯỚC 4: KÊ ĐƠN</span>
                    <div><strong>Điều phối xử lý:</strong> Yêu cầu NOC / Truyền dẫn kiểm tra băng thông luồng cáp quang từ trạm về Core, đo Ping, kiểm tra lỗi cổng SFP, hoặc cấu hình lại định tuyến (Routing).</div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Tên Cell</th><th>Lỗi Ghi Nhận</th>
                            <th>Thput DL (Mbps)<br><small style="color:#e74c3c">< 15 Mbps</small></th>
                            <th>Latency (ms)<br><small style="color:#e74c3c">> 100 ms</small></th>
                            <th>PRB DL (%)</th>
                            <th>CQI (%)</th>
                            <th>BƯỚC 5: CLOSED-LOOP</th>
                        </tr>
                    </thead>
                    <tbody id="g1Body"></tbody>
                </table>
            </div>

            <!-- NHÓM 2 -->
            <div class="group-card" id="group2">
                <div class="group-header g2">
                    <div>BƯỚC 3: Căn Bệnh Nhóm 2 - Tắc nghẽn Vô tuyến mãn tính</div>
                    <div style="font-size: 14px; font-weight: normal;">Số lượng: <b id="g2Count">0</b> Cell</div>
                </div>
                <div class="action-box">
                    <span class="step-badge" style="background:#e67e22; margin:0;">BƯỚC 4: KÊ ĐƠN</span>
                    <div><strong>Điều phối xử lý:</strong> (Mềm) Bật Load Balancing, hạ góc ngẩng (Downtilt) ăng-ten để thu hẹp vùng phủ. (Cứng) Bật Carrier Aggregation, mở rộng License BBU, quy hoạch trạm mới.</div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Tên Cell</th><th>Lỗi Ghi Nhận</th>
                            <th>PRB DL (%)<br><small style="color:#e74c3c">> 65%</small></th>
                            <th>Thput DL (Mbps)</th>
                            <th>CQI (%)</th>
                            <th>Drop Rate (%)</th>
                            <th>BƯỚC 5: CLOSED-LOOP</th>
                        </tr>
                    </thead>
                    <tbody id="g2Body"></tbody>
                </table>
            </div>

            <!-- NHÓM 3 -->
            <div class="group-card" id="group3">
                <div class="group-header g3">
                    <div>BƯỚC 3: Căn Bệnh Nhóm 3 - Nhiễu / Vùng phủ kém / Lỗi Phần cứng</div>
                    <div style="font-size: 14px; font-weight: normal;">Số lượng: <b id="g3Count">0</b> Cell</div>
                </div>
                <div class="action-box">
                    <span class="step-badge" style="background:#c0392b; margin:0;">BƯỚC 4: KÊ ĐƠN</span>
                    <div><strong>Điều phối xử lý:</strong> Kỹ sư RNO kiểm tra Neighbor, chỉnh Azimuth/Tilt cơ dập nhiễu. Đội Đài trạm đo kiểm VSWR, kiểm tra dây nhảy, module phát sóng (RRU).</div>
                </div>
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Tên Cell</th><th>Lỗi Ghi Nhận</th>
                            <th>CQI (%)<br><small style="color:#e74c3c">< 90%</small></th>
                            <th>ERAB Setup SR<br><small style="color:#e74c3c">< 98.5%</small></th>
                            <th>Drop Rate (%)<br><small style="color:#e74c3c">> 1%</small></th>
                            <th>PRB DL (%)</th>
                            <th>BƯỚC 5: CLOSED-LOOP</th>
                        </tr>
                    </thead>
                    <tbody id="g3Body"></tbody>
                </table>
            </div>

        </div>
    </main>
</div>

<script>
    async function runOptimization() {
        const week = document.getElementById('weekSelect').value;
        const filterBL = document.getElementById('blacklistCheck').checked;

        if (!week) {
            alert("Vui lòng import dữ liệu QoE/QoS trước khi thực hiện Phân tích!"); return;
        }

        document.getElementById('loadingMsg').style.display = 'block';
        document.getElementById('errorMsg').style.display = 'none';
        document.getElementById('summaryBox').style.display = 'none';
        document.getElementById('group1').style.display = 'none';
        document.getElementById('group2').style.display = 'none';
        document.getElementById('group3').style.display = 'none';

        try {
            const response = await fetch(`/api/optimizing-data?week=${encodeURIComponent(week)}&filterBlacklist=${filterBL}`);
            const result = await response.json();

            document.getElementById('loadingMsg').style.display = 'none';

            if (result.error) {
                document.getElementById('errorMsg').innerText = result.error;
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            if (result.message) {
                document.getElementById('errorMsg').innerText = result.message;
                document.getElementById('errorMsg').className = 'alert alert-success';
                document.getElementById('errorMsg').style.color = '#27ae60';
                document.getElementById('errorMsg').style.backgroundColor = '#e8f8f5';
                document.getElementById('errorMsg').style.display = 'block';
                return;
            }

            document.getElementById('sumTotal').innerText = result.stats.totalBad;
            document.getElementById('sumBlack').innerText = result.stats.blacklisted;
            document.getElementById('sumValid').innerText = result.stats.analyzed;
            document.getElementById('summaryBox').style.display = 'block';

            const renderRow = (r, type) => {
                let m = r.metrics;
                let btn = `<a href="/kpi-analytics?network=4g&cell=${encodeURIComponent(r.Cell_Name)}" target="_blank" class="btn-kpi">🔎 Kiểm tra phục hồi</a>`;
                
                if(type === 1) return `<tr><td><b>${r.Cell_Name}</b></td><td>${r.Type}</td><td class="metric-bad">${m.thput}</td><td class="metric-bad">${m.latency}</td><td class="metric-ok">${m.prb}</td><td class="metric-ok">${m.cqi}</td><td style="text-align:center;">${btn}</td></tr>`;
                if(type === 2) return `<tr><td><b>${r.Cell_Name}</b></td><td>${r.Type}</td><td class="metric-bad">${m.prb}</td><td class="metric-bad">${m.thput}</td><td>${m.cqi}</td><td>${m.drop_rate}</td><td style="text-align:center;">${btn}</td></tr>`;
                if(type === 3) return `<tr><td><b>${r.Cell_Name}</b></td><td>${r.Type}</td><td class="${m.cqi < 90 ? 'metric-bad' : ''}">${m.cqi}</td><td class="${m.erab < 98.5 ? 'metric-bad' : ''}">${m.erab}</td><td class="${m.drop_rate > 1 ? 'metric-bad' : ''}">${m.drop_rate}</td><td>${m.prb}</td><td style="text-align:center;">${btn}</td></tr>`;
            };

            const data = result.data;
            
            if (data.group1.length > 0) {
                document.getElementById('g1Count').innerText = data.group1.length;
                document.getElementById('g1Body').innerHTML = data.group1.map(r => renderRow(r, 1)).join('');
                document.getElementById('group1').style.display = 'block';
            }

            if (data.group2.length > 0) {
                document.getElementById('g2Count').innerText = data.group2.length;
                document.getElementById('g2Body').innerHTML = data.group2.map(r => renderRow(r, 2)).join('');
                document.getElementById('group2').style.display = 'block';
            }

            if (data.group3.length > 0) {
                document.getElementById('g3Count').innerText = data.group3.length;
                document.getElementById('g3Body').innerHTML = data.group3.map(r => renderRow(r, 3)).join('');
                document.getElementById('group3').style.display = 'block';
            }

        } catch (error) {
            document.getElementById('loadingMsg').style.display = 'none';
            document.getElementById('errorMsg').innerText = 'Lỗi kết nối đến máy chủ CSDL.';
            document.getElementById('errorMsg').style.display = 'block';
        }
    }
</script>
</body>
</html>
