<%- include('partials/head') %>
<%
    let activeUser = locals.currentUser || locals.user || (typeof currentUser !== 'undefined' ? currentUser : null);
    let rawRole = activeUser && activeUser.role ? activeUser.role : '';
    let normalizedRole = rawRole ? String(rawRole).trim().toLowerCase() : '';
    let sidebarUser = activeUser ? Object.assign({}, activeUser, { role: normalizedRole }) : null;
    
    // Tab đang active sau khi submit (Mặc định 3g900)
    let currentTab = locals.activeTab || '3g900';
%>
<style>
    .layout { display: flex; height: 100vh; overflow: hidden; background-color: #f4f6f8; }
    .main-content { flex: 1; overflow-y: auto; padding: 20px; }
    .card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-bottom: 25px; border-top: 4px solid #3498db; }
    
    /* Hệ thống Tab */
    .tab-header { display: flex; border-bottom: 2px solid #ecf0f1; margin-bottom: 20px; }
    .tab-btn { background: transparent; border: none; padding: 12px 25px; cursor: pointer; font-size: 15px; font-weight: bold; color: #7f8c8d; transition: 0.3s; }
    .tab-btn:hover { color: #3498db; background: #fdfdfd; }
    .tab-btn.active { color: #2980b9; border-bottom: 3px solid #3498db; }
    
    .tab-content { display: none; animation: fadeIn 0.4s; }
    .tab-content.active { display: block; }

    /* Bảng nhập liệu */
    .table-responsive { width: 100%; overflow-x: auto; margin-bottom: 15px; border: 1px solid #ecf0f1; border-radius: 8px;}
    .data-table { width: 100%; border-collapse: collapse; font-size: 13px; white-space: nowrap; }
    .data-table th, .data-table td { padding: 10px; border-bottom: 1px solid #ecf0f1; text-align: center; }
    .data-table th { background-color: #f8f9fa; color: #2c3e50; font-weight: bold; }
    .data-table input { width: 100%; min-width: 60px; padding: 6px; border: 1px solid #bdc3c7; border-radius: 4px; outline: none; text-align: center; font-weight: bold; color: #34495e;}
    .data-table input[type="text"] { text-align: left; min-width: 100px;}
    
    .btn-success { background: #27ae60; color: white; border: none; padding: 8px 15px; border-radius: 4px; font-weight: bold; cursor: pointer; }
    .btn-success:hover { background: #219653; }
    .btn-danger { background: #e74c3c; color: white; border: none; padding: 5px 10px; border-radius: 4px; font-weight: bold; cursor: pointer; }
    .btn-primary { background: #3498db; color: white; border: none; padding: 12px 25px; border-radius: 6px; font-weight: bold; cursor: pointer; font-size: 15px; width: 100%; transition: 0.2s;}
    .btn-primary:hover { background: #2980b9; }

    textarea { width: 100%; padding: 15px; border: 1px solid #bdc3c7; border-radius: 8px; font-family: monospace; font-size: 14px; background: #fdfdfd; color: #2c3e50; outline: none; resize: vertical; box-sizing: border-box;}

    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

<div class="layout">
    <%- include('partials/sidebar', { currentUser: sidebarUser }) %>
    <main class="main-content">
        <header class="topbar">
            <h1>Thư Viện Scrip (Generate Tool)</h1>
        </header>
        
        <div class="content-body">
            <div class="card">
                <!-- CÁC TAB CÔNG NGHỆ -->
                <div class="tab-header">
                    <button class="tab-btn <%= currentTab === '3g900' ? 'active' : '' %>" onclick="openTab(event, 'tab3g900')">Mạng 3G (900MHz)</button>
                    <button class="tab-btn <%= currentTab === '4g' ? 'active' : '' %>" onclick="openTab(event, 'tab4g')">Mạng 4G (LTE)</button>
                    <button class="tab-btn <%= currentTab === '3g2100' ? 'active' : '' %>" onclick="openTab(event, 'tab3g2100')">Mạng 3G (2100MHz)</button>
                </div>

                <!-- KHU VỰC NHẬP LIỆU -->
                <div id="tab3g900" class="tab-content <%= currentTab === '3g900' ? 'active' : '' %>">
                    <%- include('partials/scrip_form', { tech: '3g900', defaultSRN: 70, defaultSlot: 2, rx: 2, tx: 1 }) %>
                </div>

                <div id="tab4g" class="tab-content <%= currentTab === '4g' ? 'active' : '' %>">
                    <%- include('partials/scrip_form', { tech: '4g', defaultSRN: 60, defaultSlot: 3, rx: 4, tx: 4 }) %>
                </div>

                <div id="tab3g2100" class="tab-content <%= currentTab === '3g2100' ? 'active' : '' %>">
                    <%- include('partials/scrip_form', { tech: '3g2100', defaultSRN: 80, defaultSlot: 3, rx: 2, tx: 1 }) %>
                </div>

                <!-- KẾT QUẢ RENDER -->
                <% if (locals.script_result) { %>
                    <div style="margin-top: 30px; border-top: 2px dashed #ecf0f1; padding-top: 20px;">
                        <h4 style="color: #2c3e50; margin-top: 0;">🚀 Kết Quả Command Line (O&M):</h4>
                        <textarea rows="15" readonly><%= script_result %></textarea>
                    </div>
                <% } %>
            </div>
        </div>
    </main>
</div>

<script>
    function openTab(evt, tabName) {
        var i, tabcontent, tablinks;
        tabcontent = document.getElementsByClassName("tab-content");
        for (i = 0; i < tabcontent.length; i++) {
            tabcontent[i].style.display = "none";
            tabcontent[i].className = tabcontent[i].className.replace(" active", "");
        }
        tablinks = document.getElementsByClassName("tab-btn");
        for (i = 0; i < tablinks.length; i++) {
            tablinks[i].className = tablinks[i].className.replace(" active", "");
        }
        document.getElementById(tabName).style.display = "block";
        document.getElementById(tabName).className += " active";
        evt.currentTarget.className += " active";
    }

    // Hàm thêm Dòng (Dịch chuẩn từ Python sang JS của bạn)
    function addRow(tech) {
        var table = document.getElementById("rruTable_" + tech).getElementsByTagName('tbody')[0];
        var newRow = table.insertRow(table.rows.length);
        var idx = table.rows.length;
        
        var defaultSRN, defaultSlot;
        if (tech == '3g900') { defaultSRN = 70 + idx - 1; defaultSlot = 2; }
        else if (tech == '3g2100') { defaultSRN = 80 + idx - 1; defaultSlot = 3; }
        else { defaultSRN = 60 + idx - 1; defaultSlot = 3; }

        var rxNum = tech == '4g' ? 4 : 2;
        var txNum = tech == '4g' ? 4 : 1;

        newRow.innerHTML = `
            <td><input type="text" name="rn[]" value="RRU${idx}"></td>
            <td><input type="number" name="srn[]" value="${defaultSRN}"></td>
            <td><input type="number" name="hsn[]" value="${defaultSlot}"></td>
            <td><input type="number" name="hpn[]" value="${idx-1}"></td>
            <td><input type="number" name="rcn[]" value="${idx-1}"></td>
            <td><input type="number" name="sectorid[]" value="${idx-1}"></td>
            <td><input type="number" name="rxnum[]" value="${rxNum}"></td>
            <td><input type="number" name="txnum[]" value="${txNum}"></td>
            <td><button type="button" class="btn-danger" onclick="this.closest('tr').remove()">✖</button></td>
        `;
    }
</script>
</body>
</html>
